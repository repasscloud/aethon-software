# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# JWT signing key — must be at least 32 characters, keep secret
Auth__JwtKey=

# DataProtection key encryption certificate (X.509 PFX, base64-encoded).
# Generate once with: ./generate-dp-cert.sh
# Reuse the same value across all instances sharing the /keys volume.
DataProtection__CertBase64=

# ── SuperAdmin seed account ───────────────────────────────────────────────────
# Used once on first startup to create the initial SuperAdmin. Change password after first login.
Seed__AdminEmail=
Seed__AdminPassword=

# ── Optional — leave blank to disable ─────────────────────────────────────────

# MailerSend API key for transactional email (invites, claim tokens, apply confirmations)
Email__MailerSendApiKey=
Email__FromEmail=
Email__FromName=
Email__WebBaseUrl=
Email__FromEmailSupport=

# Claude (Anthropic) API key for resume intelligence
Claude__ApiKey=

# ── Defaults (override if needed) ─────────────────────────────────────────────
Auth__Issuer=aethon-api
Auth__Audience=aethon-web
GooglePlaces__ApiKey=

# Stripe secret key (from Stripe Dashboard → Developers → API keys)
# Test keys start with sk_test_  |  Live keys start with sk_live_
Stripe__SecretKey=

# LinkedIn OAuth (for job seeker profile LinkedIn verification)
LinkedIn__ClientId=
LinkedIn__ClientSecret=
LinkedIn__RedirectUri=

# Public (browser-accessible) API URL — used when the browser must navigate to the API directly.
# In Docker this is overridden by docker-compose.yml to https://dev-api.app.aethonsoftware.com.
PublicApiBaseUrl=

# Canonical public base URL of the web frontend (no trailing slash).
# Used for sitemap generation and server-side absolute URL construction.
# Example: https://app.aethonsoftware.com
SiteBaseUrl=