# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# DataProtection key encryption certificate (X.509 PFX, base64-encoded).
# Generate once with: ./generate-dp-cert.sh
# Reuse the same value across Dev / UAT / Prod — all instances sharing the
# /keys volume must use the same cert so they can decrypt each other's keys.
DataProtection__CertBase64=
