        <NavLink class="nav-link aethon-nav-link" href="/account/setup-mfa" Match="NavLinkMatch.All">
            <span class="aethon-nav-icon"><i class="bi bi-shield-lock"></i></span>
            <span>Two-factor auth</span>
        </NavLink>

        <form method="post" action="/account/logout" class="mt-3">
            <input type="hidden" name="returnPath" value="/login" />
            <button type="submit" class="nav-link aethon-nav-link w-100 border-0 bg-transparent text-start">
                <span class="aethon-nav-icon"><i class="bi bi-box-arrow-right"></i></span>
                <span>Logout</span>
            </button>
        </form>
