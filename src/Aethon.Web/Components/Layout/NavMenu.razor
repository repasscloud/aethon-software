@code {
    private bool _ready;
    private bool _isAuthenticated;
    private string _appType = "";
    private string _displayName = "";
    private string _organisationName = "";

    private bool _isEmployer;
    private bool _isRecruiter;
    private bool _isJobSeeker;
    private bool _isSuperAdmin;
    private bool _isAdmin;
    private bool _isSupport;
    private bool _isStaff;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _isAuthenticated = user.Identity?.IsAuthenticated == true;

        if (_isAuthenticated)
        {
            _appType = (user.FindFirstValue(AppClaimTypes.AppType) ?? "").Trim().ToLowerInvariant();
            _displayName = user.FindFirstValue(AppClaimTypes.DisplayName) ?? user.Identity?.Name ?? "Unknown";
            _organisationName = user.FindFirstValue(AppClaimTypes.OrganisationName) ?? "";

            _isEmployer = _appType == "employer";
            _isRecruiter = _appType == "recruiter";
            _isJobSeeker = _appType == "jobseeker";
            _isSuperAdmin = _appType == "superadmin";
            _isAdmin = _appType == "admin";
            _isSupport = _appType == "support";
            _isStaff = _isSuperAdmin || _isAdmin || _isSupport;
        }

        _ready = true;
    }
}