@using System.Security.Claims
@using Aethon.Shared.Auth
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider

<nav class="nav flex-column aethon-nav">
    <div class="aethon-nav-section-label">Navigation</div>

    @if (_ready)
    {
        @if (_isEmployer)
        {
            <NavLink class="nav-link aethon-nav-link" href="/app/employer" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">⌂</span>
                <span>Employer dashboard</span>
            </NavLink>

            <NavLink class="nav-link aethon-nav-link" href="/app/jobs" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">▣</span>
                <span>Jobs</span>
            </NavLink>

            <NavLink class="nav-link aethon-nav-link" href="/app/organisation/profile" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">⌘</span>
                <span>Organisation profile</span>
            </NavLink>

            <NavLink class="nav-link aethon-nav-link" href="/app/organisation/team" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">👥</span>
                <span>Organisation team</span>
            </NavLink>
        }
        else if (_isRecruiter)
        {
            <NavLink class="nav-link aethon-nav-link" href="/app/recruiter" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">⌂</span>
                <span>Recruiter dashboard</span>
            </NavLink>

            <NavLink class="nav-link aethon-nav-link" href="/app/jobs" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">▣</span>
                <span>Jobs</span>
            </NavLink>

            <NavLink class="nav-link aethon-nav-link" href="/app/organisation/profile" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">⌘</span>
                <span>Organisation profile</span>
            </NavLink>

            <NavLink class="nav-link aethon-nav-link" href="/app/organisation/team" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">👥</span>
                <span>Organisation team</span>
            </NavLink>
        }
        else if (_isJobSeeker)
        {
            <NavLink class="nav-link aethon-nav-link" href="/app/jobseeker" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">⌂</span>
                <span>Job seeker dashboard</span>
            </NavLink>

            <NavLink class="nav-link aethon-nav-link" href="/app/applications" Match="NavLinkMatch.Prefix">
                <span class="aethon-nav-icon">▣</span>
                <span>My applications</span>
            </NavLink>
        }

        <NavLink class="nav-link aethon-nav-link" href="/" Match="NavLinkMatch.All">
            <span class="aethon-nav-icon">→</span>
            <span>Role landing</span>
        </NavLink>

        <div class="mt-3 px-2">
            <div class="small text-secondary mb-1">Signed in as</div>
            <div class="fw-semibold text-dark">@_displayName</div>

            @if (!string.IsNullOrWhiteSpace(_organisationName))
            {
                <div class="small text-secondary mt-1">@_organisationName</div>
            }

            @if (!_isEmployer && !_isRecruiter && !_isJobSeeker)
            {
                <div class="small text-danger mt-1">No app type resolved</div>
            }
        </div>
    }

    <form method="post" action="http://localhost:5201/auth/browser-logout" class="mt-3">
        <input type="hidden" name="returnPath" value="/login" />
        <button type="submit" class="nav-link aethon-nav-link w-100 border-0 bg-transparent text-start">
            <span class="aethon-nav-icon">×</span>
            <span>Logout</span>
        </button>
    </form>
</nav>

@code {
    private bool _ready;
    private string _appType = "";
    private string _displayName = "";
    private string _organisationName = "";

    private bool _isEmployer;
    private bool _isRecruiter;
    private bool _isJobSeeker;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _appType = (user.FindFirstValue(AppClaimTypes.AppType) ?? "").Trim().ToLowerInvariant();
        _displayName = user.FindFirstValue(AppClaimTypes.DisplayName) ?? user.Identity?.Name ?? "Unknown";
        _organisationName = user.FindFirstValue(AppClaimTypes.OrganisationName) ?? "";

        _isEmployer = _appType == "employer";
        _isRecruiter = _appType == "recruiter";
        _isJobSeeker = _appType == "jobseeker";

        _ready = true;
    }
}