@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS

<div class="d-flex flex-column min-vh-100">
    <!-- Top nav -->
    <nav class="navbar bg-white border-bottom px-4 py-2">
        <a class="navbar-brand fw-bold text-dark text-decoration-none d-flex align-items-center gap-2" href="/jobs">
            <div class="d-flex align-items-center justify-content-center rounded-3 bg-dark text-white fw-bold" style="width:32px;height:32px;font-size:.9rem;">A</div>
            <span>Aethon</span>
        </a>
        <div class="d-flex gap-2">
            <AuthorizeView>
                <Authorized>
                    <a href="/" class="btn btn-dark btn-sm rounded-4 px-3">Dashboard</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-outline-dark btn-sm rounded-4 px-3">Sign in</a>
                    <a href="/register" class="btn btn-dark btn-sm rounded-4 px-3">Get started</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>

    <!-- Content -->
    <main class="flex-grow-1 container-lg py-4">
        @Body
    </main>

    <!-- Footer -->
    <footer class="border-top bg-white py-4 mt-auto">
        <div class="container-lg">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div class="text-secondary small">
                    &copy; @DateTime.UtcNow.Year Aethon. All rights reserved.
                </div>
                <div class="d-flex flex-wrap gap-3 align-items-center text-secondary small">
                    <a href="/jobs" class="text-decoration-none text-secondary">Browse jobs</a>
                    <a href="/info/equal-opportunity-employer" class="text-decoration-none text-secondary">Equal Opportunity</a>
                    <a href="/info/accessible-workplace" class="text-decoration-none text-secondary">Accessible Workplace</a>
                    <a href="/info/privacy" class="d-inline-flex align-items-center gap-1 text-secondary text-decoration-none">
                        <img src="/img/ccpa-icons/privacyoptions29x14.svg"
                             alt="California Consumer Privacy Act (CCPA) Opt-Out Icon"
                             width="29" height="14" />
                        <span>Your Privacy Choices</span>
                    </a>
                </div>
            </div>
        </div>
    </footer>
</div>

<!-- Scroll-to-top button (shown after scrolling 300 px) -->
<button id="scroll-to-top-btn"
        onclick="window.aethon.scrollToTop()"
        title="Back to top"
        style="display:none; position:fixed; bottom:1.5rem; right:1.5rem; z-index:1050;
               width:44px; height:44px; border-radius:50%; border:none;
               background:#212529; color:#fff; cursor:pointer;
               align-items:center; justify-content:center; box-shadow:0 2px 8px rgba(0,0,0,.25);">
    <i class="bi bi-chevron-up" style="font-size:1.1rem;"></i>
</button>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("aethon.initScrollToTop", "scroll-to-top-btn", 300);
    }
}
