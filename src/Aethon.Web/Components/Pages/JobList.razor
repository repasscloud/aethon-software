@page "/app/jobs"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net
@using System.Net.Http.Json
@using Aethon.Shared.Jobs
@using Microsoft.AspNetCore.Authorization
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Jobs | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h4 fw-bold mb-2">Loading jobs</h1>
            <p class="text-secondary mb-0">Fetching your organisation jobs.</p>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3">
                    <div>
                        <h1 class="h3 fw-bold mb-2">Jobs</h1>
                        <p class="text-secondary mb-0">Manage employer jobs for your organisation.</p>
                    </div>
                    <div>
                        <a class="btn btn-dark rounded-4 px-4 py-2" href="/app/jobs/new">Create job</a>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_pageError))
        {
            <div class="alert alert-danger rounded-4 mb-0">@_pageError</div>
        }

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                @if (_jobs.Count == 0)
                {
                    <p class="text-secondary mb-0">No jobs found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Department</th>
                                    <th>Location</th>
                                    <th>Employment</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var job in _jobs)
                                {
                                    <tr>
                                        <td>
                                            <a class="fw-semibold text-decoration-none" href="/app/jobs/@job.Id">@job.Title</a>
                                        </td>
                                        <td>@(job.Department ?? "-")</td>
                                        <td>@(job.LocationText ?? "-")</td>
                                        <td>@job.EmploymentType</td>
                                        <td>@job.Status</td>
                                        <td>@job.CreatedUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loaded;
    private string? _pageError;
    private List<JobListItemDto> _jobs = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("AethonApi");
            var response = await client.GetAsync("/jobs/my-org");

            if (response.StatusCode == HttpStatusCode.Forbidden)
            {
                _pageError = "You do not have access to employer jobs.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _pageError = "Could not load jobs.";
                return;
            }

            _jobs = await response.Content.ReadFromJsonAsync<List<JobListItemDto>>() ?? [];
        }
        catch
        {
            _pageError = "Could not load jobs.";
        }
        finally
        {
            _loaded = true;
        }
    }
}
