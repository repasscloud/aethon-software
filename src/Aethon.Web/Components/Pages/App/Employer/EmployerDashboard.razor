@page "/app/employer"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Security.Claims
@using Aethon.Shared.Auth
@using Aethon.Shared.Jobs
@using Aethon.Shared.RecruiterCompanies
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AethonApiClient Api

<PageTitle>Employer dashboard | Aethon</PageTitle>

@if (_ready)
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h1 class="h3 fw-bold mb-2">Employer dashboard</h1>
                <p class="text-secondary mb-0">Signed in as @_displayName &mdash; @_organisationName</p>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="small text-secondary mb-2">Open jobs</div>
                        <div class="fw-bold fs-2">@_openJobCount</div>
                        <a href="/app/jobs" class="small text-dark mt-2 d-block">View all jobs →</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="small text-secondary mb-2">Pending approvals</div>
                        <div class="fw-bold fs-2">@_pendingApprovalCount</div>
                        <a href="/company/jobs/pending-approvals" class="small text-dark mt-2 d-block">Review →</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="small text-secondary mb-2">Recruiter partners</div>
                        <div class="fw-bold fs-2">@_recruiterPartnerCount</div>
                        <a href="/company/recruiters" class="small text-dark mt-2 d-block">Manage →</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="small text-secondary mb-2">Your role</div>
                        <div class="fw-semibold fs-5">@_companyRole</div>
                        <div class="text-secondary mt-1 small">Owner: @(_isOwner ? "Yes" : "No")</div>
                    </div>
                </div>
            </div>
        </div>

        @if (_recentJobs.Count > 0)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Recent jobs</h2>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var job in _recentJobs)
                                {
                                    <tr>
                                        <td><a href="/app/jobs/@job.Id">@job.Title</a></td>
                                        <td><span class="badge bg-secondary rounded-pill">@job.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _ready;
    private string _displayName = "";
    private string _organisationName = "";
    private string _companyRole = "";
    private bool _isOwner;

    private int _openJobCount;
    private int _pendingApprovalCount;
    private int _recruiterPartnerCount;
    private List<JobSummaryDto> _recentJobs = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _displayName = user.FindFirstValue(AppClaimTypes.DisplayName) ?? user.Identity?.Name ?? "Unknown";
        _organisationName = user.FindFirstValue(AppClaimTypes.OrganisationName) ?? "Unknown organisation";
        _companyRole = user.FindFirstValue(AppClaimTypes.CompanyRole) ?? "—";
        _isOwner = string.Equals(
            user.FindFirstValue(AppClaimTypes.IsOrganisationOwner),
            "true",
            StringComparison.OrdinalIgnoreCase);

        var client = await Api.CreateAsync();

        try
        {
            var jobs = await client.GetFromJsonAsync<List<JobSummaryDto>>("/api/v1/jobs/my-org", AethonApiClient.JsonOptions) ?? [];
            _openJobCount = jobs.Count(j => string.Equals(j.Status, "Published", StringComparison.OrdinalIgnoreCase));
            _recentJobs = jobs.Take(5).ToList();
        }
        catch { }

        try
        {
            var approvals = await client.GetFromJsonAsync<List<JobSummaryDto>>("/api/v1/company/jobs/approvals", AethonApiClient.JsonOptions) ?? [];
            _pendingApprovalCount = approvals.Count;
        }
        catch { }

        try
        {
            var partners = await client.GetFromJsonAsync<List<RecruiterCompanyRelationshipDto>>("/api/v1/company/recruiters", AethonApiClient.JsonOptions) ?? [];
            _recruiterPartnerCount = partners.Count;
        }
        catch { }

        _ready = true;
    }
}
