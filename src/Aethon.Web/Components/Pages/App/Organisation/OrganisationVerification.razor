@page "/app/organisation/verification"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Security.Claims
@using Aethon.Shared.Auth
@using Aethon.Shared.Billing
@using Aethon.Shared.Enums
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AethonApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Organisation Verification | Aethon</PageTitle>

@if (!_ready)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4" style="max-width:760px; margin:0 auto;">

        @* ── Current status ── *@
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h1 class="h3 fw-bold mb-1">Organisation Verification</h1>
                <p class="text-secondary mb-3">Build trust with candidates. Verified organisations display a trust badge on all job listings.</p>

                @if (_profile?.VerificationTier == VerificationTier.EnhancedTrusted)
                {
                    <div class="alert alert-warning rounded-4 mb-0 d-flex align-items-center gap-3">
                        <i class="bi bi-patch-check-fill fs-4"></i>
                        <div>
                            <div class="fw-semibold">Enhanced Trusted Employer</div>
                            <div class="small">Your organisation holds the highest verification tier.</div>
                        </div>
                    </div>
                }
                else if (_profile?.VerificationTier == VerificationTier.StandardEmployer)
                {
                    <div class="alert alert-primary rounded-4 d-flex align-items-center gap-3">
                        <i class="bi bi-patch-check fs-4"></i>
                        <div>
                            <div class="fw-semibold">Standard Verified Employer</div>
                            <div class="small">You can upgrade to Enhanced Trusted Employer at any time.</div>
                        </div>
                    </div>
                }
                else if (_profile?.VerificationPendingTier != null)
                {
                    <div class="alert alert-warning rounded-4 d-flex align-items-center gap-3">
                        <i class="bi bi-hourglass-split fs-4"></i>
                        <div>
                            <div class="fw-semibold">Verification Pending</div>
                            <div class="small">Your verification request has been received and is being processed. We'll notify you by email once it's been reviewed.</div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary rounded-4 d-flex align-items-center gap-3">
                        <i class="bi bi-building fs-4"></i>
                        <div>
                            <div class="fw-semibold">Not yet verified</div>
                            <div class="small">Choose a verification tier below to get started.</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (_error is not null)
        {
            <div class="alert alert-danger rounded-4">@_error</div>
        }

        @* ── Tier options — hidden while any verification is pending ── *@
        @if (_profile?.VerificationTier != VerificationTier.EnhancedTrusted && _profile?.VerificationPendingTier == null)
        {
            <div class="row g-3">

                @* Standard *@
                @if (_profile?.VerificationTier == VerificationTier.None)
                {
                    <div class="col-12 col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4 d-flex flex-column">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <i class="bi bi-patch-check text-primary fs-4"></i>
                                    <h2 class="h5 fw-bold mb-0">Standard Verified</h2>
                                </div>
                                <ul class="text-secondary small mb-3 flex-grow-1">
                                    <li>Business registration validated</li>
                                    <li>Domain ownership verified</li>
                                    <li>Website and contact checks</li>
                                    <li>Basic fraud screening</li>
                                    <li>Verified badge on all listings</li>
                                    <li>Lower Sticky to Top pricing</li>
                                    @if (_launchPromoEnabled)
                                    {
                                        <li>Unused promo credits upgrade to Premium</li>
                                    }
                                </ul>
                                <div class="fw-bold fs-5 mb-3">A$49 <span class="fw-normal fs-6 text-secondary">/ year</span></div>
                                <button class="btn btn-primary rounded-4 w-100 @(_busy ? "disabled" : "")"
                                        @onclick='() => StartCheckout("standard", false)'>
                                    @if (_busy && _pendingAction == "standard")
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Purchase Standard Verification
                                </button>
                                <a href="/info/standard-verification" target="_blank" class="small text-center mt-2 text-secondary">What's checked? →</a>
                            </div>
                        </div>
                    </div>

                    @* Standard bundle *@
                    <div class="col-12 col-md-6">
                        <div class="card border-primary border-2 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4 d-flex flex-column">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <i class="bi bi-stars text-primary fs-4"></i>
                                    <h2 class="h5 fw-bold mb-0">Standard Bundle</h2>
                                </div>
                                <div class="small text-primary fw-semibold mb-3">Save A$10</div>
                                <ul class="text-secondary small mb-3 flex-grow-1">
                                    <li>Everything in Standard Verification</li>
                                    <li><strong>+1 Standard Job Post credit included</strong></li>
                                </ul>
                                <div class="fw-bold fs-5 mb-3">A$68 <span class="fw-normal fs-6 text-secondary">(A$49 + A$29, save A$10)</span></div>
                                <button class="btn btn-primary rounded-4 w-100 @(_busy ? "disabled" : "")"
                                        @onclick='() => StartCheckout("standard", true)'>
                                    @if (_busy && _pendingAction == "standard-bundle")
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Purchase Standard Bundle
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @* Enhanced *@
                <div class="col-12 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4 d-flex flex-column">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="bi bi-patch-check-fill text-warning fs-4"></i>
                                <h2 class="h5 fw-bold mb-0">Enhanced Trusted</h2>
                            </div>
                            <ul class="text-secondary small mb-3 flex-grow-1">
                                <li>Everything in Standard, plus:</li>
                                <li>Director and officer identity checks</li>
                                <li>Financial stability indicators</li>
                                <li>Employment history and reputation signals</li>
                                <li>Enhanced Trusted badge on all listings</li>
                                <li>Manual admin review process</li>
                            </ul>
                            <div class="fw-bold fs-5 mb-3">A$149 <span class="fw-normal fs-6 text-secondary">/ year</span></div>
                            <button class="btn btn-warning rounded-4 w-100 @(_busy ? "disabled" : "")"
                                    @onclick='() => StartCheckout("enhanced", false)'>
                                @if (_busy && _pendingAction == "enhanced")
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Purchase Enhanced Verification
                            </button>
                            <a href="/info/enhanced-verification" target="_blank" class="small text-center mt-2 text-secondary">What's checked? →</a>
                        </div>
                    </div>
                </div>

                @* Enhanced bundle *@
                @if (_profile?.VerificationTier == VerificationTier.None)
                {
                    <div class="col-12 col-md-6">
                        <div class="card border-warning border-2 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4 d-flex flex-column">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <i class="bi bi-stars text-warning fs-4"></i>
                                    <h2 class="h5 fw-bold mb-0">Enhanced Bundle</h2>
                                </div>
                                <div class="small text-warning fw-semibold mb-3">Save A$10</div>
                                <ul class="text-secondary small mb-3 flex-grow-1">
                                    <li>Everything in Enhanced Verification</li>
                                    <li><strong>+1 Premium Job Post credit included</strong></li>
                                </ul>
                                <div class="fw-bold fs-5 mb-3">A$208 <span class="fw-normal fs-6 text-secondary">(A$149 + A$69, save A$10)</span></div>
                                <button class="btn btn-warning rounded-4 w-100 @(_busy ? "disabled" : "")"
                                        @onclick='() => StartCheckout("enhanced", true)'>
                                    @if (_busy && _pendingAction == "enhanced-bundle")
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Purchase Enhanced Bundle
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (_launchPromoEnabled)
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h3 class="h6 fw-semibold mb-2"><i class="bi bi-info-circle me-2 text-primary"></i>Launch promotion</h3>
                        <p class="text-secondary small mb-0">
                            Your organisation's 10 free Standard Job Post credits (valid 90 days from signup) will automatically
                            upgrade to <strong>Premium Job Post credits</strong> when you complete verification — at no extra cost.
                            Unused credits only. Sticky to Top remains a separate paid add-on.
                        </p>
                    </div>
                </div>
            }
        }

    </div>
}

@* ── Missing fields modal ── *@
<div class="modal fade" id="verificationRequirementsModal" tabindex="-1" aria-labelledby="verificationRequirementsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="verificationRequirementsModalLabel">
                    <i class="bi bi-exclamation-circle text-warning me-2"></i>Complete your profile first
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="text-secondary small mb-3">Please fill in the following required fields before purchasing verification:</p>
                <ul class="mb-0">
                    @foreach (var field in _missingFields)
                    {
                        <li class="small">@field</li>
                    }
                </ul>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary btn-sm rounded-3" data-bs-dismiss="modal">Close</button>
                <a href="/app/organisation/profile" class="btn btn-primary btn-sm rounded-3">Update profile →</a>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _ready;
    private bool _busy;
    private string? _pendingAction;
    private string? _error;
    private OrganisationProfileDto? _profile;
    private bool _launchPromoEnabled = true;
    private List<string> _missingFields = [];

    protected override async Task OnInitializedAsync()
    {
        var client = await Api.CreateAsync();
        try
        {
            _profile = await client.GetFromJsonAsync<OrganisationProfileDto>(
                "/api/v1/organisations/me/profile", AethonApiClient.JsonOptions);
        }
        catch { }
        try
        {
            var features = await client.GetFromJsonAsync<PublicFeaturesDto>(
                "/api/v1/public/features", AethonApiClient.JsonOptions);
            if (features is not null)
                _launchPromoEnabled = features.LaunchPromotionEnabled;
        }
        catch { }
        _ready = true;
    }

    private record PublicFeaturesDto(bool LaunchPromotionEnabled);

    // ── Validation ────────────────────────────────────────────────────────────

    private List<string> GetMissingStandardFields()
    {
        if (_profile is null) return ["Profile not loaded."];
        var missing = new List<string>();

        if (string.IsNullOrWhiteSpace(_profile.WebsiteUrl))
            missing.Add("Website URL");
        if (string.IsNullOrWhiteSpace(_profile.LegalName))
            missing.Add("Legal name");
        if (_profile.Industry is null)
            missing.Add("Industry");
        if (_profile.CompanySize is null)
            missing.Add("Company size");
        if (string.IsNullOrWhiteSpace(_profile.PublicContactEmail))
            missing.Add("Public contact email");

        var hasSocial = !string.IsNullOrWhiteSpace(_profile.LinkedInUrl)
                     || !string.IsNullOrWhiteSpace(_profile.TwitterHandle)
                     || !string.IsNullOrWhiteSpace(_profile.FacebookUrl)
                     || !string.IsNullOrWhiteSpace(_profile.TikTokHandle)
                     || !string.IsNullOrWhiteSpace(_profile.InstagramHandle)
                     || !string.IsNullOrWhiteSpace(_profile.YouTubeUrl);

        if (!hasSocial)
            missing.Add("At least one social media profile (LinkedIn, X/Twitter, Facebook, TikTok, Instagram, or YouTube)");

        return missing;
    }

    private List<string> GetMissingEnhancedFields()
    {
        var missing = GetMissingStandardFields();
        if (_profile is null) return missing;

        if (string.IsNullOrWhiteSpace(_profile.RegisteredAddressLine1))
            missing.Add("Registered address line 1");
        if (string.IsNullOrWhiteSpace(_profile.RegisteredCity))
            missing.Add("City");
        if (string.IsNullOrWhiteSpace(_profile.RegisteredState))
            missing.Add("State / Province");
        if (string.IsNullOrWhiteSpace(_profile.RegisteredPostcode))
            missing.Add("Postcode / ZIP");
        if (string.IsNullOrWhiteSpace(_profile.RegisteredCountry))
            missing.Add("Country");

        var hasRegNumber = !string.IsNullOrWhiteSpace(_profile.TaxRegistrationNumber)
                        || !string.IsNullOrWhiteSpace(_profile.BusinessRegistrationNumber);
        if (!hasRegNumber)
            missing.Add("Tax registration number or Business registration number");

        if (string.IsNullOrWhiteSpace(_profile.PrimaryContactName))
            missing.Add("Primary contact full name");
        if (string.IsNullOrWhiteSpace(_profile.PrimaryContactEmail))
            missing.Add("Primary contact email address");
        if (string.IsNullOrWhiteSpace(_profile.PrimaryContactPhone))
            missing.Add("Primary contact phone number");
        if (!_profile.IsPublicProfileEnabled)
            missing.Add("Public profile must be enabled");

        return missing;
    }

    // ── Checkout ──────────────────────────────────────────────────────────────

    private async Task StartCheckout(string tier, bool bundle)
    {
        _error = null;

        // Validate required fields before proceeding to payment
        var missing = tier == "enhanced"
            ? GetMissingEnhancedFields()
            : GetMissingStandardFields();

        if (missing.Count > 0)
        {
            _missingFields = missing;
            StateHasChanged();
            await JS.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('verificationRequirementsModal')).show()");
            return;
        }

        _busy = true;
        _pendingAction = bundle ? $"{tier}-bundle" : tier;
        StateHasChanged();

        try
        {
            var client = await Api.CreateAsync();
            var endpoint = bundle ? "/api/v1/billing/verification/bundle-checkout" : "/api/v1/billing/verification/checkout";
            var resp = await client.PostAsJsonAsync(endpoint, new VerificationCheckoutRequestDto { Tier = tier });

            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<BillingCheckoutResponseDto>(AethonApiClient.JsonOptions);
                if (!string.IsNullOrEmpty(result?.CheckoutUrl))
                {
                    Nav.NavigateTo(result.CheckoutUrl, forceLoad: true);
                    return;
                }
            }

            _error = "Could not start checkout. Please try again.";
        }
        catch
        {
            _error = "Could not connect to billing service. Please try again.";
        }

        _busy = false;
        _pendingAction = null;
    }
}
