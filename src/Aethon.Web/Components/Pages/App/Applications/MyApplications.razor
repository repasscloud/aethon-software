@page "/app/applications"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using Aethon.Shared.Applications
@using Aethon.Shared.Common
@using Aethon.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api

<PageTitle>My applications | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading applications…</div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-3">My applications</h1>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger rounded-4">@_error</div>
            }
            else if (_items.Count == 0)
            {
                <p class="text-secondary mb-0">No applications yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Job</th>
                                <th>Status</th>
                                <th>AI Match</th>
                                <th>Submitted</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _items)
                            {
                                <tr>
                                    <td><a href="/jobs/@item.JobId">@item.JobTitle</a></td>
                                    <td>@item.Status</td>
                                    <td>@AtsMatchCell(item)</td>
                                    <td class="text-secondary small">@item.SubmittedUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _loaded;
    private string? _error;
    private IReadOnlyList<ApplicationSummaryDto> _items = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = await Api.CreateAsync();
            var paged = await client.GetFromJsonAsync<PagedResult<ApplicationSummaryDto>>("/api/v1/applications/mine", AethonApiClient.JsonOptions);
            _items = paged?.Items ?? [];
        }
        catch
        {
            _error = "Could not load applications.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private RenderFragment AtsMatchCell(ApplicationSummaryDto item) => __builder =>
    {
        if (item.AtsStatus is null || item.AtsStatus == AtsMatchStatus.Pending || item.AtsStatus == AtsMatchStatus.Processing)
        {
            // Candidates see a neutral "pending" indicator — don't reveal score until complete
            if (item.AtsStatus == AtsMatchStatus.Pending || item.AtsStatus == AtsMatchStatus.Processing)
                __builder.AddMarkupContent(0, "<span class=\"badge rounded-pill bg-secondary-subtle text-secondary\">Pending</span>");
            else
                __builder.AddContent(0, "—");
            return;
        }

        if (item.AtsStatus == AtsMatchStatus.Failed)
        {
            __builder.AddMarkupContent(0, "<span class=\"badge rounded-pill bg-danger-subtle text-danger\">Not available</span>");
            return;
        }

        if (item.AtsOverallScore.HasValue)
        {
            var (bg, text) = item.AtsRecommendation switch
            {
                AtsMatchRecommendation.StrongMatch  => ("bg-success-subtle", "text-success"),
                AtsMatchRecommendation.GoodMatch    => ("bg-success-subtle", "text-success"),
                AtsMatchRecommendation.PartialMatch => ("bg-warning-subtle", "text-warning"),
                AtsMatchRecommendation.PoorMatch    => ("bg-danger-subtle",  "text-danger"),
                _                                   => ("bg-danger-subtle",  "text-danger")
            };
            var label = item.AtsRecommendation?.ToString() ?? "";
            __builder.AddMarkupContent(0,
                $"<span class=\"badge rounded-pill {bg} {text}\">{item.AtsOverallScore}% · {label}</span>");
        }
        else
        {
            __builder.AddContent(0, "—");
        }
    };
}
