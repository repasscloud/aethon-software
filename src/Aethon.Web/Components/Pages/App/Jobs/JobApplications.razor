@page "/app/jobs/{JobId}/applications"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net
@using System.Net.Http.Json
@using Aethon.Shared.Applications
@using Aethon.Shared.Common
@using Aethon.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api

<PageTitle>Applications | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading applications…</div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 fw-bold mb-2">Applications</h1>
                        <p class="text-secondary mb-0">Review candidates for this job.</p>
                    </div>
                    <a class="btn btn-outline-secondary rounded-4 px-4" href="/app/jobs/@JobId">Back to job</a>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger rounded-4 mb-0">@_error</div>
        }
        else if (_items.Count == 0)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <p class="text-secondary mb-0">No applications yet.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Applicant</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th>ATS Match</th>
                                    <th>Submitted</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _items)
                                {
                                    <tr>
                                        <td>
                                            @(item.ApplicantDisplayName ?? "—")
                                            @if (item.IsNotSuitable)
                                            {
                                                <span class="badge rounded-pill bg-warning-subtle text-warning ms-1" title="Auto-screened: Not Suitable">Not Suitable</span>
                                            }
                                        </td>
                                        <td class="text-secondary small">@(item.ApplicantEmail ?? "—")</td>
                                        <td>@item.Status</td>
                                        <td>@AtsMatchCell(item)</td>
                                        <td class="text-secondary small">@item.SubmittedUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-dark rounded-4" href="/app/applications/@item.Id">Open</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (_totalCount > _items.Count)
                    {
                        <div class="mt-3 text-secondary small">Showing @_items.Count of @_totalCount applications.</div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string JobId { get; set; } = "";

    private bool _loaded;
    private string? _error;
    private List<ApplicationSummaryDto> _items = [];
    private int _totalCount;

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;
        _error = null;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.GetAsync($"/api/v1/jobs/{JobId}/applications?pageSize=100");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                _error = "Job not found.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not load applications.";
                return;
            }

            var paged = await response.Content.ReadFromJsonAsync<PagedResult<ApplicationSummaryDto>>(AethonApiClient.JsonOptions);
            _items = paged?.Items.ToList() ?? [];
            _totalCount = paged?.TotalCount ?? 0;
        }
        catch
        {
            _error = "Could not load applications.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private RenderFragment AtsMatchCell(ApplicationSummaryDto item) => __builder =>
    {
        if (item.AtsStatus is null)
        {
            __builder.AddContent(0, "—");
            return;
        }

        if (item.AtsStatus == AtsMatchStatus.Pending || item.AtsStatus == AtsMatchStatus.Processing)
        {
            __builder.AddMarkupContent(0, $"<span class=\"badge rounded-pill bg-secondary-subtle text-secondary\">Analysing…</span>");
            return;
        }

        if (item.AtsStatus == AtsMatchStatus.Failed)
        {
            __builder.AddMarkupContent(0, "<span class=\"badge rounded-pill bg-danger-subtle text-danger\">Failed</span>");
            return;
        }

        if (item.AtsOverallScore.HasValue)
        {
            var (bg, text) = item.AtsRecommendation switch
            {
                AtsMatchRecommendation.StrongMatch  => ("bg-success-subtle", "text-success"),
                AtsMatchRecommendation.GoodMatch    => ("bg-success-subtle", "text-success"),
                AtsMatchRecommendation.PartialMatch => ("bg-warning-subtle", "text-warning"),
                AtsMatchRecommendation.PoorMatch    => ("bg-danger-subtle",  "text-danger"),
                _                                   => ("bg-danger-subtle",  "text-danger")
            };
            var label = item.AtsRecommendation?.ToString() ?? "";
            __builder.AddMarkupContent(0,
                $"<span class=\"badge rounded-pill {bg} {text}\">{item.AtsOverallScore}% · {label}</span>");
        }
    };
}
