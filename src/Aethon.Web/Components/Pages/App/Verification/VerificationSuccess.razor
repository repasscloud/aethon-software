@page "/app/verification/success"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization

<PageTitle>Verification Payment Received | Aethon</PageTitle>

<div class="d-flex flex-column gap-4 align-items-center py-5" style="max-width:560px; margin:0 auto; text-align:center;">
    <div class="card border-0 shadow-sm rounded-4 w-100">
        <div class="card-body p-5">
            <div class="mb-4" style="font-size:3.5rem;">
                <i class="bi bi-patch-check-fill text-primary"></i>
            </div>
            <h1 class="h3 fw-bold mb-2">Payment received</h1>
            <p class="text-secondary mb-4">
                Thank you for your verification payment. We are now reviewing your organisation's details.
                Standard verifications are often processed automatically — you will receive a notification once your
                status is updated.
            </p>
            <div class="alert alert-light rounded-4 text-start mb-4">
                <div class="fw-semibold mb-1"><i class="bi bi-info-circle me-2"></i>What happens next?</div>
                <ul class="mb-0 small text-secondary">
                    <li>Standard Verification: automated checks run immediately. You may be verified within minutes.</li>
                    <li>Enhanced Trusted: our team will review your application manually within 2–3 business days.</li>
                    <li>If auto-verification is not possible, you'll hear from us by email.</li>
                    <li>Your 10 free job posting credits (if unused) will upgrade to Premium once verification is confirmed.</li>
                </ul>
            </div>
            <div class="d-flex gap-2 justify-content-center flex-wrap">
                <a href="/app/employer" class="btn btn-primary rounded-4 px-4">Go to dashboard</a>
                <a href="/app/organisation/billing" class="btn btn-outline-secondary rounded-4 px-4">View billing</a>
            </div>
        </div>
    </div>
</div>
