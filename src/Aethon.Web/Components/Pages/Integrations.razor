@page "/app/organisation/integrations"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using System.Net.Http.Json
@using Aethon.Shared.Auth
@using Aethon.Shared.Integrations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Integration settings</PageTitle>

<div class="container-fluid py-4">

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h4 class="fw-semibold mb-0">Integration settings</h4>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_orgError))
    {
        <div class="alert alert-danger rounded-4">@_orgError</div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-semibold mb-3">Webhooks</h5>

                @if (_loading)
                {
                    <p class="text-secondary">Loading...</p>
                }
                else if (_webhooks.Count == 0)
                {
                    <p class="text-secondary">No webhooks configured.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Endpoint</th>
                                    <th>Events</th>
                                    <th>Active</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var wh in _webhooks)
                                {
                                    <tr>
                                        <td>@wh.Name</td>
                                        <td class="text-break">@wh.EndpointUrl</td>
                                        <td>@string.Join(", ", wh.Events)</td>
                                        <td>
                                            @if (wh.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h5 class="fw-semibold mb-3">Add webhook</h5>

                @if (!string.IsNullOrWhiteSpace(_addSuccess))
                {
                    <div class="alert alert-success rounded-3">@_addSuccess</div>
                }

                @if (!string.IsNullOrWhiteSpace(_addError))
                {
                    <div class="alert alert-danger rounded-3">@_addError</div>
                }

                <EditForm Model="_form" OnValidSubmit="HandleAddWebhook">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label fw-medium">Name</label>
                        <InputText class="form-control" @bind-Value="_form.Name" placeholder="My webhook" />
                        <ValidationMessage For="() => _form.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Endpoint URL</label>
                        <InputText class="form-control" @bind-Value="_form.EndpointUrl" placeholder="https://example.com/webhook" />
                        <ValidationMessage For="() => _form.EndpointUrl" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Secret</label>
                        <InputText class="form-control" @bind-Value="_form.Secret" placeholder="Signing secret" />
                        <ValidationMessage For="() => _form.Secret" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Events</label>
                        <InputText class="form-control" @bind-Value="_form.Events" placeholder="application.submitted,application.status_changed" />
                        <div class="form-text">Comma-separated event names</div>
                        <ValidationMessage For="() => _form.Events" />
                    </div>

                    <button type="submit" class="btn btn-primary px-4" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Add webhook
                    </button>
                </EditForm>
            </div>
        </div>
    }

</div>

@code {
    private Guid _orgId;
    private string _orgError = "";
    private bool _loading = true;
    private bool _submitting;
    private List<WebhookSubscriptionDto> _webhooks = new();
    private string _addSuccess = "";
    private string _addError = "";
    private WebhookFormModel _form = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var orgIdStr = user.FindFirstValue(AppClaimTypes.OrganisationId);
        if (string.IsNullOrWhiteSpace(orgIdStr) || !Guid.TryParse(orgIdStr, out _orgId))
        {
            _orgError = "No organisation associated with your account.";
            _loading = false;
            return;
        }

        await LoadWebhooksAsync();
    }

    private async Task LoadWebhooksAsync()
    {
        _loading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("AethonApi");
            var result = await client.GetFromJsonAsync<List<WebhookSubscriptionDto>>(
                $"/api/v1/integrations/organisations/{_orgId}/webhooks");
            _webhooks = result ?? new List<WebhookSubscriptionDto>();
        }
        catch
        {
            _webhooks = new List<WebhookSubscriptionDto>();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleAddWebhook()
    {
        _submitting = true;
        _addSuccess = "";
        _addError = "";

        try
        {
            var events = (_form.Events ?? "")
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

            var payload = new
            {
                organisationId = _orgId,
                name = _form.Name,
                endpointUrl = _form.EndpointUrl,
                secret = _form.Secret,
                events
            };

            var client = HttpClientFactory.CreateClient("AethonApi");
            var response = await client.PostAsJsonAsync(
                $"/api/v1/integrations/organisations/{_orgId}/webhooks", payload);

            if (response.IsSuccessStatusCode)
            {
                _addSuccess = "Webhook added successfully.";
                _form = new WebhookFormModel();
                await LoadWebhooksAsync();
            }
            else
            {
                _addError = $"Failed to add webhook (HTTP {(int)response.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            _addError = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private class WebhookFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Name { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string EndpointUrl { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string Secret { get; set; } = "";

        public string Events { get; set; } = "";
    }
}
