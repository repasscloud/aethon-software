@page "/jobs"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Aethon.Shared.Enums
@using Aethon.Shared.Jobs
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api

<PageTitle>Jobs | Aethon</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-2">Open jobs</h1>
            <p class="text-secondary mb-0">Browse published roles from companies and recruiters on Aethon.</p>
        </div>
    </div>

    <!-- Search filters -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <input class="form-control rounded-4" type="text" placeholder="Search by city or location"
                           @bind="_city" @bind:event="oninput" @onkeyup="OnFilterKeyUp" />
                </div>

                <div class="col-12 col-md-4 col-lg-2">
                    <select class="form-select rounded-4" @bind="_dateRange" @bind:after="LoadAsync">
                        <option value="">Any time</option>
                        <option value="Today">Today</option>
                        <option value="Last3Days">Last 3 days</option>
                        <option value="LastWeek">Last week</option>
                        <option value="Last14Days">Last 14 days</option>
                        <option value="Last30Days">Last 30 days</option>
                        <option value="Last60Days">Last 60 days</option>
                        <option value="Last90Days">Last 90 days</option>
                        <option value="Over90Days">90+ days ago</option>
                    </select>
                </div>

                <div class="col-12 col-md-4 col-lg-2">
                    <select class="form-select rounded-4" @bind="_category" @bind:after="LoadAsync">
                        <option value="">All categories</option>
                        <option value="Accounting">Accounting</option>
                        <option value="AdminSecretarial">Admin &amp; Secretarial</option>
                        <option value="AdvertisingPR">Advertising &amp; PR</option>
                        <option value="Aerospace">Aerospace</option>
                        <option value="AgricultureFishingForestry">Agriculture, Fishing &amp; Forestry</option>
                        <option value="Arts">Arts</option>
                        <option value="Automobile">Automobile</option>
                        <option value="Banking">Banking</option>
                        <option value="BuildingConstruction">Building &amp; Construction</option>
                        <option value="Catering">Catering</option>
                        <option value="Charity">Charity</option>
                        <option value="CustomerService">Customer Service</option>
                        <option value="Design">Design</option>
                        <option value="Education">Education</option>
                        <option value="Engineering">Engineering</option>
                        <option value="ExecutiveManagement">Executive &amp; Management</option>
                        <option value="FinanceInsurance">Finance &amp; Insurance</option>
                        <option value="FoodBeverage">Food &amp; Beverage</option>
                        <option value="Government">Government</option>
                        <option value="GraduateRoles">Graduate Roles</option>
                        <option value="Healthcare">Healthcare</option>
                        <option value="Hospitality">Hospitality</option>
                        <option value="HumanResources">Human Resources</option>
                        <option value="ITSoftware">IT &amp; Software</option>
                        <option value="LegalServices">Legal Services</option>
                        <option value="Logistics">Logistics</option>
                        <option value="Manufacturing">Manufacturing</option>
                        <option value="Marketing">Marketing</option>
                        <option value="MediaJournalism">Media &amp; Journalism</option>
                        <option value="MiningResources">Mining &amp; Resources</option>
                        <option value="PartTimeTemp">Part-time &amp; Temp</option>
                        <option value="Pharmaceuticals">Pharmaceuticals</option>
                        <option value="PropertyRealEstate">Property &amp; Real Estate</option>
                        <option value="PublicRelations">Public Relations</option>
                        <option value="Recruitment">Recruitment</option>
                        <option value="Research">Research</option>
                        <option value="Retail">Retail</option>
                        <option value="Sales">Sales</option>
                        <option value="Science">Science</option>
                        <option value="SecurityIntelligence">Security &amp; Intelligence</option>
                        <option value="SocialWork">Social Work</option>
                        <option value="SportRecreation">Sport &amp; Recreation</option>
                        <option value="TelecommunicationsISP">Telecommunications &amp; ISP</option>
                        <option value="Tourism">Tourism</option>
                        <option value="TransportDistribution">Transport &amp; Distribution</option>
                        <option value="UtilitiesEnergy">Utilities &amp; Energy</option>
                        <option value="Veterinary">Veterinary</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="col-12 col-md-4 col-lg-2">
                    <select class="form-select rounded-4" @bind="_region" @bind:after="LoadAsync">
                        <option value="">All regions</option>
                        <option value="Africa">Africa</option>
                        <option value="Asia">Asia</option>
                        <option value="Europe">Europe</option>
                        <option value="LatinAmerica">Latin America</option>
                        <option value="MiddleEast">Middle East</option>
                        <option value="NorthAmerica">North America</option>
                        <option value="Oceania">Oceania</option>
                        <option value="Worldwide">Worldwide</option>
                    </select>
                </div>

                <div class="col-12 col-md-4 col-lg-2">
                    <input class="form-control rounded-4" type="text" placeholder="Country"
                           @bind="_country" @bind:event="oninput" @onkeyup="OnFilterKeyUp" />
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger rounded-4 mb-0">@_error</div>
    }

    @if (_loading)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 text-secondary">Loading jobs…</div>
        </div>
    }
    else if (_jobs.Count == 0)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <p class="text-secondary mb-0">No jobs found matching your criteria.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var job in _jobs)
            {
                <div class="col-12 col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100 @(job.IsHighlighted ? "border border-warning" : "")">
                        <div class="card-body p-4">
                            @if (job.IsHighlighted)
                            {
                                <span class="badge bg-warning text-dark rounded-pill mb-2 small">Featured</span>
                            }

                            @if (job.IncludeCompanyLogo && !string.IsNullOrWhiteSpace(job.OrganisationLogoUrl))
                            {
                                <img src="@job.OrganisationLogoUrl" alt="@job.OrganisationName"
                                     style="max-height:40px; max-width:140px; object-fit:contain;" class="mb-3 d-block" />
                            }

                            <h2 class="h5 fw-bold mb-1">
                                <a class="text-decoration-none text-dark" href="/jobs/@job.Id">@job.Title</a>
                            </h2>

                            <div class="text-secondary mb-2">
                                @if (!string.IsNullOrWhiteSpace(job.OrganisationSlug))
                                {
                                    <a class="text-decoration-none text-secondary" href="/organisations/@job.OrganisationSlug">@job.OrganisationName</a>
                                }
                                else
                                {
                                    @job.OrganisationName
                                }
                            </div>

                            <div class="d-flex flex-wrap gap-2 mb-2">
                                @if (!string.IsNullOrWhiteSpace(job.LocationText))
                                {
                                    <span class="badge bg-light text-secondary border rounded-pill">@job.LocationText</span>
                                }
                                <span class="badge bg-light text-secondary border rounded-pill">@FormatEnum(job.WorkplaceType.ToString())</span>
                                <span class="badge bg-light text-secondary border rounded-pill">@FormatEnum(job.EmploymentType.ToString())</span>
                                @if (job.Category.HasValue)
                                {
                                    <span class="badge bg-light text-secondary border rounded-pill">@FormatEnum(job.Category.Value.ToString())</span>
                                }
                            </div>

                            @if (job.SalaryFrom.HasValue || job.SalaryTo.HasValue)
                            {
                                <div class="fw-semibold mb-2">
                                    @job.SalaryCurrency @job.SalaryFrom?.ToString("N0") – @job.SalaryTo?.ToString("N0")
                                </div>
                            }

                            @if (job.BenefitsTags.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-1 mt-2">
                                    @foreach (var tag in job.BenefitsTags.Take(4))
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill small">@tag</span>
                                    }
                                    @if (job.BenefitsTags.Count > 4)
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill small">+@(job.BenefitsTags.Count - 4) more</span>
                                    }
                                </div>
                            }

                            <div class="text-secondary small mt-2">
                                @(job.PublishedUtc.HasValue ? job.PublishedUtc.Value.ToLocalTime().ToString("dd MMM yyyy") : "")
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PublicJobListItemDto> _jobs = [];
    private string? _error;
    private bool _loading;

    private string _city = "";
    private string _dateRange = "";
    private string _category = "";
    private string _region = "";
    private string _country = "";

    private System.Timers.Timer? _debounce;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private void OnFilterKeyUp(KeyboardEventArgs _)
    {
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(400);
        _debounce.Elapsed += async (_, _) =>
        {
            _debounce?.Dispose();
            await InvokeAsync(LoadAsync);
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var qs = new List<string>();
            if (!string.IsNullOrWhiteSpace(_city))       qs.Add($"city={Uri.EscapeDataString(_city)}");
            if (!string.IsNullOrWhiteSpace(_dateRange))  qs.Add($"dateRange={_dateRange}");
            if (!string.IsNullOrWhiteSpace(_category))   qs.Add($"category={_category}");
            if (!string.IsNullOrWhiteSpace(_region))     qs.Add($"region={_region}");
            if (!string.IsNullOrWhiteSpace(_country))    qs.Add($"country={Uri.EscapeDataString(_country)}");

            var url = "/api/v1/public/jobs";
            if (qs.Count > 0) url += "?" + string.Join("&", qs);

            var client = await Api.CreateAsync();
            _jobs = await client.GetFromJsonAsync<List<PublicJobListItemDto>>(url, AethonApiClient.JsonOptions) ?? [];
        }
        catch
        {
            _error = "Could not load jobs.";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string FormatEnum(string value)
    {
        // Insert spaces before capital letters: "FullTime" → "Full Time"
        return System.Text.RegularExpressions.Regex.Replace(value, "([A-Z])", " $1").Trim();
    }
}
