@page "/jobs"
@attribute [AllowAnonymous]
@layout PublicLayout
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@using Aethon.Shared.Enums
@using Aethon.Shared.Jobs
@using Aethon.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject IJSRuntime JS

<PageTitle>Jobs | Aethon</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-2">Open jobs</h1>
            <p class="text-secondary mb-0">Browse published roles from companies and recruiters on Aethon.</p>
        </div>
    </div>

    <!-- Search filters -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="row g-3 mb-3">
                <div class="col-12 col-md-5">
                    <input class="form-control rounded-4" type="text" placeholder="Search by keyword, title, or skill"
                           @bind="_keywords" @bind:event="oninput" @onkeyup="OnFilterKeyUp" />
                </div>

                <div class="col-12 col-md-5">
                    <input class="form-control rounded-4" type="text" placeholder="Search by city or location"
                           list="location-suggestions"
                           @bind="_city" @bind:event="oninput" @onkeyup="OnLocationKeyUp" />
                    <datalist id="location-suggestions">
                        @foreach (var loc in _locationSuggestions)
                        {
                            <option value="@loc" />
                        }
                    </datalist>
                </div>

                <div class="col-12 col-md-2 d-flex gap-2">
                    <button class="btn btn-dark rounded-4 px-3 flex-grow-1" @onclick="LoadAsync">Search</button>
                    <button class="btn btn-outline-secondary rounded-4 px-3" title="Search near my location"
                            @onclick="UseMyLocationAsync" disabled="@_locating">
                        @if (_locating)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        }
                        else
                        {
                            <i class="bi bi-geo-alt-fill"></i>
                        }
                    </button>
                </div>
                @if (_nearMeLat.HasValue)
                {
                    <div class="col-12">
                        <div class="alert alert-info rounded-3 py-2 small mb-0 d-flex align-items-center justify-content-between">
                            <span><i class="bi bi-geo-alt-fill me-1"></i>Showing jobs within 25 km of your location</span>
                            <button class="btn btn-sm btn-link text-secondary p-0 ms-2" @onclick="ClearNearMe">Clear</button>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_locatingError))
                {
                    <div class="col-12">
                        <div class="alert alert-warning rounded-3 py-2 small mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>@_locatingError
                        </div>
                    </div>
                }
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-4 col-lg-3">
                    <select class="form-select rounded-4" @bind="_dateRange" @bind:after="LoadAsync">
                        <option value="">Any time</option>
                        <option value="Today">Today</option>
                        <option value="Last3Days">Last 3 days</option>
                        <option value="LastWeek">Last week</option>
                        <option value="Last14Days">Last 14 days</option>
                        <option value="Last30Days">Last 30 days</option>
                        <option value="Last60Days">Last 60 days</option>
                        <option value="Last90Days">Last 90 days</option>
                        <option value="Over90Days">90+ days ago</option>
                    </select>
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <select class="form-select rounded-4" @bind="_category" @bind:after="LoadAsync">
                        <option value="">All categories</option>
                        <option value="Accounting">Accounting</option>
                        <option value="AdminSecretarial">Admin &amp; Secretarial</option>
                        <option value="AdvertisingPR">Advertising &amp; PR</option>
                        <option value="Aerospace">Aerospace</option>
                        <option value="AgricultureFishingForestry">Agriculture, Fishing &amp; Forestry</option>
                        <option value="Arts">Arts</option>
                        <option value="Automobile">Automobile</option>
                        <option value="Banking">Banking</option>
                        <option value="BuildingConstruction">Building &amp; Construction</option>
                        <option value="Catering">Catering</option>
                        <option value="Charity">Charity</option>
                        <option value="CustomerService">Customer Service</option>
                        <option value="Design">Design</option>
                        <option value="Education">Education</option>
                        <option value="Engineering">Engineering</option>
                        <option value="ExecutiveManagement">Executive &amp; Management</option>
                        <option value="FinanceInsurance">Finance &amp; Insurance</option>
                        <option value="FoodBeverage">Food &amp; Beverage</option>
                        <option value="Government">Government</option>
                        <option value="GraduateRoles">Graduate Roles</option>
                        <option value="Healthcare">Healthcare</option>
                        <option value="Hospitality">Hospitality</option>
                        <option value="HumanResources">Human Resources</option>
                        <option value="ITSoftware">IT &amp; Software</option>
                        <option value="LegalServices">Legal Services</option>
                        <option value="Logistics">Logistics</option>
                        <option value="Manufacturing">Manufacturing</option>
                        <option value="Marketing">Marketing</option>
                        <option value="MediaJournalism">Media &amp; Journalism</option>
                        <option value="MiningResources">Mining &amp; Resources</option>
                        <option value="PartTimeTemp">Part-time &amp; Temp</option>
                        <option value="Pharmaceuticals">Pharmaceuticals</option>
                        <option value="PropertyRealEstate">Property &amp; Real Estate</option>
                        <option value="PublicRelations">Public Relations</option>
                        <option value="Recruitment">Recruitment</option>
                        <option value="Research">Research</option>
                        <option value="Retail">Retail</option>
                        <option value="Sales">Sales</option>
                        <option value="Science">Science</option>
                        <option value="SecurityIntelligence">Security &amp; Intelligence</option>
                        <option value="SocialWork">Social Work</option>
                        <option value="SportRecreation">Sport &amp; Recreation</option>
                        <option value="TelecommunicationsISP">Telecommunications &amp; ISP</option>
                        <option value="Tourism">Tourism</option>
                        <option value="TransportDistribution">Transport &amp; Distribution</option>
                        <option value="UtilitiesEnergy">Utilities &amp; Energy</option>
                        <option value="Veterinary">Veterinary</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <select class="form-select rounded-4" @bind="_region" @bind:after="LoadAsync">
                        <option value="">All regions</option>
                        <option value="Africa">Africa</option>
                        <option value="Asia">Asia</option>
                        <option value="Europe">Europe</option>
                        <option value="LatinAmerica">Latin America</option>
                        <option value="MiddleEast">Middle East</option>
                        <option value="NorthAmerica">North America</option>
                        <option value="Oceania">Oceania</option>
                        <option value="Worldwide">Worldwide</option>
                    </select>
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <select class="form-select rounded-4" @bind="_country" @bind:after="LoadAsync">
                        <option value="">All countries</option>
                        <option value="Afghanistan">Afghanistan</option>
                        <option value="Albania">Albania</option>
                        <option value="Algeria">Algeria</option>
                        <option value="Argentina">Argentina</option>
                        <option value="Australia">Australia</option>
                        <option value="Austria">Austria</option>
                        <option value="Bangladesh">Bangladesh</option>
                        <option value="Belgium">Belgium</option>
                        <option value="Bolivia">Bolivia</option>
                        <option value="Brazil">Brazil</option>
                        <option value="Cambodia">Cambodia</option>
                        <option value="Canada">Canada</option>
                        <option value="Chile">Chile</option>
                        <option value="China">China</option>
                        <option value="Colombia">Colombia</option>
                        <option value="Croatia">Croatia</option>
                        <option value="Czech Republic">Czech Republic</option>
                        <option value="Denmark">Denmark</option>
                        <option value="Ecuador">Ecuador</option>
                        <option value="Egypt">Egypt</option>
                        <option value="Estonia">Estonia</option>
                        <option value="Ethiopia">Ethiopia</option>
                        <option value="Finland">Finland</option>
                        <option value="France">France</option>
                        <option value="Germany">Germany</option>
                        <option value="Ghana">Ghana</option>
                        <option value="Greece">Greece</option>
                        <option value="Guatemala">Guatemala</option>
                        <option value="Hungary">Hungary</option>
                        <option value="India">India</option>
                        <option value="Indonesia">Indonesia</option>
                        <option value="Ireland">Ireland</option>
                        <option value="Israel">Israel</option>
                        <option value="Italy">Italy</option>
                        <option value="Japan">Japan</option>
                        <option value="Jordan">Jordan</option>
                        <option value="Kenya">Kenya</option>
                        <option value="Latvia">Latvia</option>
                        <option value="Lithuania">Lithuania</option>
                        <option value="Malaysia">Malaysia</option>
                        <option value="Mexico">Mexico</option>
                        <option value="Morocco">Morocco</option>
                        <option value="Netherlands">Netherlands</option>
                        <option value="New Zealand">New Zealand</option>
                        <option value="Nigeria">Nigeria</option>
                        <option value="Norway">Norway</option>
                        <option value="Pakistan">Pakistan</option>
                        <option value="Panama">Panama</option>
                        <option value="Peru">Peru</option>
                        <option value="Philippines">Philippines</option>
                        <option value="Poland">Poland</option>
                        <option value="Portugal">Portugal</option>
                        <option value="Romania">Romania</option>
                        <option value="Russia">Russia</option>
                        <option value="Saudi Arabia">Saudi Arabia</option>
                        <option value="Serbia">Serbia</option>
                        <option value="Singapore">Singapore</option>
                        <option value="Slovakia">Slovakia</option>
                        <option value="Slovenia">Slovenia</option>
                        <option value="South Africa">South Africa</option>
                        <option value="South Korea">South Korea</option>
                        <option value="Spain">Spain</option>
                        <option value="Sri Lanka">Sri Lanka</option>
                        <option value="Sweden">Sweden</option>
                        <option value="Switzerland">Switzerland</option>
                        <option value="Taiwan">Taiwan</option>
                        <option value="Thailand">Thailand</option>
                        <option value="Turkey">Turkey</option>
                        <option value="Ukraine">Ukraine</option>
                        <option value="United Arab Emirates">United Arab Emirates</option>
                        <option value="United Kingdom">United Kingdom</option>
                        <option value="United States">United States</option>
                        <option value="Uruguay">Uruguay</option>
                        <option value="Venezuela">Venezuela</option>
                        <option value="Vietnam">Vietnam</option>
                    </select>
                </div>
            </div>

            <!-- Advanced filters toggle -->
            <button class="btn btn-link text-secondary p-0 small" @onclick="() => _showAdvanced = !_showAdvanced">
                <i class="bi @(_showAdvanced ? "bi-chevron-up" : "bi-sliders") me-1"></i>
                @(_showAdvanced ? "Hide advanced filters" : "Advanced filters")
            </button>

            @if (_showAdvanced)
            {
                <div class="row g-3 mt-2 border-top pt-3">
                    <div class="col-12 col-md-3">
                        <label class="form-label small fw-semibold text-secondary">Min salary</label>
                        <input class="form-control rounded-4" type="number" placeholder="e.g. 60000"
                               @bind="_salaryMin" @bind:event="oninput" @onkeyup="OnFilterKeyUp" />
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label small fw-semibold text-secondary">Max salary</label>
                        <input class="form-control rounded-4" type="number" placeholder="e.g. 120000"
                               @bind="_salaryMax" @bind:event="oninput" @onkeyup="OnFilterKeyUp" />
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label small fw-semibold text-secondary">Workplace type</label>
                        <select class="form-select rounded-4" @bind="_workplaceType" @bind:after="LoadAsync">
                            <option value="">Any</option>
                            <option value="OnSite">On-site</option>
                            <option value="Hybrid">Hybrid</option>
                            <option value="Remote">Remote</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-3 d-flex flex-column gap-2 justify-content-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="immediateStartCheck"
                                   checked="@_immediateStart"
                                   @onchange="e => { _immediateStart = (bool)(e.Value ?? false); _ = LoadAsync(); }" />
                            <label class="form-check-label small" for="immediateStartCheck">
                                <span class="badge bg-success rounded-pill me-1" style="font-size:.7rem;">Start</span>
                                Immediate Start only
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="verifiedCheck"
                                   checked="@_verifiedOnly"
                                   @onchange="e => { _verifiedOnly = (bool)(e.Value ?? false); _ = LoadAsync(); }" />
                            <label class="form-check-label small" for="verifiedCheck">
                                <i class="bi bi-patch-check-fill text-primary me-1"></i>Verified employers only
                            </label>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger rounded-4 mb-0">@_error</div>
    }

    @if (_loading)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 text-secondary">Loading jobs…</div>
        </div>
    }
    else if (_jobs.Count == 0)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <p class="text-secondary mb-0">No jobs found matching your criteria.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var job in _jobs)
            {
                <div class="col-12 col-lg-6">
                    <a href="@JobUrl(job)" class="text-decoration-none">
                        <div class="card border-0 shadow-sm rounded-4 h-100" style="@(job.IsHighlighted ? "background:linear-gradient(135deg,#fffbea 0%,#fff8d6 100%); border:1px solid #ffe066 !important;" : "")">
                            <div class="card-body p-4 d-flex flex-column">

                                <!-- Header: content left, logo right -->
                                <div class="d-flex gap-3 mb-2">
                                    <div class="flex-grow-1 min-w-0">
                                        <div class="d-flex align-items-start gap-2 flex-wrap mb-1">
                                            <h2 class="h5 fw-bold mb-0 text-dark">@job.Title</h2>
                                            @if (job.IsImmediateStart)
                                            {
                                                <span class="badge bg-success rounded-pill align-self-center" style="font-size:.65rem; white-space:nowrap;"><i class="bi bi-lightning-fill me-1"></i>Immediate Start</span>
                                            }
                                        </div>
                                        <div class="d-flex align-items-center flex-wrap gap-2">
                                            <span class="text-secondary small">@job.OrganisationName</span>
                                            @if (job.OrganisationIsVerified)
                                            {
                                                <span class="badge bg-primary rounded-pill" style="font-size:.65rem;"><i class="bi bi-patch-check-fill me-1"></i>Verified</span>
                                            }
                                        </div>
                                    </div>
                                    @if (job.IncludeCompanyLogo && !string.IsNullOrWhiteSpace(job.OrganisationLogoUrl))
                                    {
                                        <div class="flex-shrink-0">
                                            <img src="@job.OrganisationLogoUrl" alt="@job.OrganisationName"
                                                 style="max-height:48px; max-width:80px; object-fit:contain;" />
                                        </div>
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(job.Summary))
                                {
                                    <p class="text-secondary small mb-2" style="overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">@job.Summary</p>
                                }

                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    @if (!string.IsNullOrWhiteSpace(job.LocationText))
                                    {
                                        <span class="badge bg-light text-secondary border rounded-pill"><i class="bi bi-geo-alt-fill text-danger me-1" style="font-size:.7rem;"></i>@job.LocationText</span>
                                    }
                                    @if (job.DistanceKm.HasValue)
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill" style="font-size:.7rem;">
                                            <i class="bi bi-bullseye me-1"></i>@job.DistanceKm.Value.ToString("F1") km away
                                        </span>
                                    }
                                    <span class="badge bg-light text-secondary border rounded-pill">
                                        @switch (job.WorkplaceType)
                                        {
                                            case WorkplaceType.OnSite:
                                                <i class="bi bi-building-fill me-1" style="font-size:.7rem; color:#e67e22;"></i>
                                                break;
                                            case WorkplaceType.Hybrid:
                                                <i class="bi bi-shuffle me-1" style="font-size:.7rem; color:#8e44ad;"></i>
                                                break;
                                            case WorkplaceType.Remote:
                                                <i class="bi bi-house-fill me-1" style="font-size:.7rem; color:#16a085;"></i>
                                                break;
                                        }
                                        @FormatEnum(job.WorkplaceType.ToString())
                                    </span>
                                    <span class="badge bg-light text-secondary border rounded-pill">
                                        @switch (job.EmploymentType)
                                        {
                                            case EmploymentType.FullTime:
                                                <i class="bi bi-clock-fill me-1" style="font-size:.7rem; color:#2980b9;"></i>
                                                break;
                                            case EmploymentType.PartTime:
                                                <i class="bi bi-clock-history me-1" style="font-size:.7rem; color:#7f8c8d;"></i>
                                                break;
                                            case EmploymentType.Contract:
                                                <i class="bi bi-file-earmark-text-fill me-1" style="font-size:.7rem; color:#d35400;"></i>
                                                break;
                                            case EmploymentType.Temporary:
                                                <i class="bi bi-hourglass-split me-1" style="font-size:.7rem; color:#f39c12;"></i>
                                                break;
                                            case EmploymentType.Casual:
                                                <i class="bi bi-sun-fill me-1" style="font-size:.7rem; color:#27ae60;"></i>
                                                break;
                                            case EmploymentType.Internship:
                                                <i class="bi bi-mortarboard-fill me-1" style="font-size:.7rem; color:#8e44ad;"></i>
                                                break;
                                        }
                                        @FormatEnum(job.EmploymentType.ToString())
                                    </span>
                                    @if (job.Category.HasValue)
                                    {
                                        <span class="badge bg-light text-secondary border rounded-pill"><i class="bi bi-tag-fill text-success me-1" style="font-size:.7rem;"></i>@FormatEnum(job.Category.Value.ToString())</span>
                                    }
                                    @foreach (var region in job.Regions)
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill" style="font-size:.7rem;"><i class="bi bi-globe2 me-1"></i>@FormatRegion(region)</span>
                                    }
                                    @foreach (var country in job.Countries)
                                    {
                                        <span class="badge bg-light text-secondary border rounded-pill" style="font-size:.75rem;" title="@country">@CountryFlag(country) @country</span>
                                    }
                                </div>

                                @if (job.SalaryFrom.HasValue || job.SalaryTo.HasValue || job.HasCommission)
                                {
                                    <div class="fw-semibold small mb-2 text-dark">
                                        @if (job.SalaryFrom.HasValue && job.SalaryTo.HasValue)
                                        {
                                            <span>@job.SalaryCurrency @job.SalaryFrom?.ToString("N0") – @job.SalaryTo?.ToString("N0")</span>
                                        }
                                        else if (job.SalaryFrom.HasValue)
                                        {
                                            <span>From @job.SalaryCurrency @job.SalaryFrom?.ToString("N0")</span>
                                        }
                                        @if (job.HasCommission && job.OteFrom.HasValue && job.OteTo.HasValue)
                                        {
                                            <span class="ms-2 text-success">· OTE @job.SalaryCurrency @job.OteFrom?.ToString("N0") – @job.OteTo?.ToString("N0")</span>
                                        }
                                        else if (job.HasCommission)
                                        {
                                            <span class="ms-2 text-success">+ Commission</span>
                                        }
                                    </div>
                                }

                                <div class="mt-auto pt-2 d-flex justify-content-between align-items-center">
                                    @if (job.BenefitsTags.Count > 0)
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var tag in job.BenefitsTags.Take(3))
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill" style="font-size:.7rem;">@tag</span>
                                            }
                                            @if (job.BenefitsTags.Count > 3)
                                            {
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill" style="font-size:.7rem;">+@(job.BenefitsTags.Count - 3) more</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span></span>
                                    }
                                    <div class="text-secondary" style="font-size:.75rem; white-space:nowrap;">
                                        @(job.PublishedUtc.HasValue ? job.PublishedUtc.Value.ToLocalTime().ToString("dd MMM yyyy") : "")
                                    </div>
                                </div>

                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PublicJobListItemDto> _jobs = [];
    private List<string> _locationSuggestions = [];
    private string? _error;
    private bool _loading;
    private bool _showAdvanced;

    private string _keywords = "";
    private string _city = "";
    private string _dateRange = "";
    private string _category = "";
    private string _region = "";
    private string _country = "";
    private string _workplaceType = "";
    private decimal? _salaryMin;
    private decimal? _salaryMax;
    private bool _verifiedOnly;
    private bool _immediateStart;

    private double? _nearMeLat;
    private double? _nearMeLng;
    private bool _locating;
    private string? _locatingError;

    private System.Timers.Timer? _debounce;
    private System.Timers.Timer? _locationDebounce;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private void OnLocationKeyUp(KeyboardEventArgs _)
    {
        _locationDebounce?.Dispose();
        _locationDebounce = new System.Timers.Timer(300);
        _locationDebounce.Elapsed += async (_, _) =>
        {
            _locationDebounce?.Dispose();
            await InvokeAsync(LoadLocationSuggestionsAsync);
        };
        _locationDebounce.AutoReset = false;
        _locationDebounce.Start();

        OnFilterKeyUp(_);
    }

    private void OnFilterKeyUp(KeyboardEventArgs _)
    {
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(400);
        _debounce.Elapsed += async (_, _) =>
        {
            _debounce?.Dispose();
            await InvokeAsync(LoadAsync);
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    private async Task LoadLocationSuggestionsAsync()
    {
        if (string.IsNullOrWhiteSpace(_city))
        {
            _locationSuggestions = [];
            StateHasChanged();
            return;
        }

        try
        {
            var client = await Api.CreateAsync();
            var url = $"/api/v1/public/jobs/locations?q={Uri.EscapeDataString(_city)}";
            _locationSuggestions = await client.GetFromJsonAsync<List<string>>(url, AethonApiClient.JsonOptions) ?? [];
        }
        catch
        {
            _locationSuggestions = [];
        }

        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var qs = new List<string>();
            if (!string.IsNullOrWhiteSpace(_keywords))    qs.Add($"keywords={Uri.EscapeDataString(_keywords)}");
            if (!string.IsNullOrWhiteSpace(_city))        qs.Add($"city={Uri.EscapeDataString(_city)}");
            if (!string.IsNullOrWhiteSpace(_dateRange))   qs.Add($"dateRange={_dateRange}");
            if (!string.IsNullOrWhiteSpace(_category))    qs.Add($"category={_category}");
            if (!string.IsNullOrWhiteSpace(_region))      qs.Add($"region={_region}");
            if (!string.IsNullOrWhiteSpace(_country))     qs.Add($"country={Uri.EscapeDataString(_country)}");
            if (!string.IsNullOrWhiteSpace(_workplaceType)) qs.Add($"workplaceType={_workplaceType}");
            if (_salaryMin.HasValue)                      qs.Add($"salaryMin={_salaryMin.Value}");
            if (_salaryMax.HasValue)                      qs.Add($"salaryMax={_salaryMax.Value}");
            if (_verifiedOnly)                            qs.Add("verifiedOnly=true");
            if (_immediateStart)                          qs.Add("immediateStart=true");
            if (_nearMeLat.HasValue && _nearMeLng.HasValue)
            {
                qs.Add($"latitude={_nearMeLat.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
                qs.Add($"longitude={_nearMeLng.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
                qs.Add("radiusKm=25");
            }

            var url = "/api/v1/public/jobs";
            if (qs.Count > 0) url += "?" + string.Join("&", qs);

            var client = await Api.CreateAsync();
            _jobs = await client.GetFromJsonAsync<List<PublicJobListItemDto>>(url, AethonApiClient.JsonOptions) ?? [];
        }
        catch
        {
            _error = "Could not load jobs.";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task UseMyLocationAsync()
    {
        _locating = true;
        _locatingError = null;
        StateHasChanged();

        try
        {
            var coords = await JS.InvokeAsync<double[]>("aethon.getLocation");
            _nearMeLat = coords[0];
            _nearMeLng = coords[1];
            await LoadAsync();
        }
        catch (JSException)
        {
            _locatingError = "Location access was denied or is unavailable. Please allow location access in your browser.";
        }
        catch
        {
            _locatingError = "Could not determine your location.";
        }
        finally
        {
            _locating = false;
            StateHasChanged();
        }
    }

    private async Task ClearNearMe()
    {
        _nearMeLat = null;
        _nearMeLng = null;
        _locatingError = null;
        await LoadAsync();
    }

    private static string FormatEnum(string value)
    {
        return Regex.Replace(value, "([A-Z])", " $1").Trim();
    }

    private static string FormatRegion(JobRegion r) => r switch
    {
        JobRegion.LatinAmerica  => "Latin America",
        JobRegion.MiddleEast    => "Middle East",
        JobRegion.NorthAmerica  => "North America",
        _                       => r.ToString()
    };

    private static string CountryFlag(string country)
    {
        var code = country switch
        {
            "Afghanistan"          => "AF", "Albania"            => "AL", "Algeria"          => "DZ",
            "Argentina"            => "AR", "Australia"          => "AU", "Austria"          => "AT",
            "Bangladesh"           => "BD", "Belgium"            => "BE", "Bolivia"          => "BO",
            "Brazil"               => "BR", "Cambodia"           => "KH", "Canada"           => "CA",
            "Chile"                => "CL", "China"              => "CN", "Colombia"         => "CO",
            "Croatia"              => "HR", "Czech Republic"     => "CZ", "Denmark"          => "DK",
            "Ecuador"              => "EC", "Egypt"              => "EG", "Estonia"          => "EE",
            "Ethiopia"             => "ET", "Finland"            => "FI", "France"           => "FR",
            "Germany"              => "DE", "Ghana"              => "GH", "Greece"           => "GR",
            "Guatemala"            => "GT", "Hungary"            => "HU", "India"            => "IN",
            "Indonesia"            => "ID", "Ireland"            => "IE", "Israel"           => "IL",
            "Italy"                => "IT", "Japan"              => "JP", "Jordan"           => "JO",
            "Kenya"                => "KE", "Latvia"             => "LV", "Lithuania"        => "LT",
            "Malaysia"             => "MY", "Mexico"             => "MX", "Morocco"          => "MA",
            "Netherlands"          => "NL", "New Zealand"        => "NZ", "Nigeria"          => "NG",
            "Norway"               => "NO", "Pakistan"           => "PK", "Panama"           => "PA",
            "Peru"                 => "PE", "Philippines"        => "PH", "Poland"           => "PL",
            "Portugal"             => "PT", "Romania"            => "RO", "Russia"           => "RU",
            "Saudi Arabia"         => "SA", "Serbia"             => "RS", "Singapore"        => "SG",
            "Slovakia"             => "SK", "Slovenia"           => "SI", "South Africa"     => "ZA",
            "South Korea"          => "KR", "Spain"              => "ES", "Sri Lanka"        => "LK",
            "Sweden"               => "SE", "Switzerland"        => "CH", "Taiwan"           => "TW",
            "Thailand"             => "TH", "Turkey"             => "TR", "Ukraine"          => "UA",
            "United Arab Emirates" => "AE", "United Kingdom"     => "GB", "United States"    => "US",
            "Uruguay"              => "UY", "Venezuela"          => "VE", "Vietnam"          => "VN",
            _ => null
        };
        if (code is null) return "🌐";
        return string.Concat(code.Select(c => char.ConvertFromUtf32(c - 'A' + 0x1F1E6)));
    }

    private static string JobUrl(PublicJobListItemDto job)
    {
        if (!string.IsNullOrEmpty(job.OrganisationSlug))
        {
            var clean = Regex.Replace(job.Title.ToLowerInvariant(), @"[^a-z0-9\s_]", "");
            var slug = Regex.Replace(clean.Trim(), @"\s+", "-");
            return $"/jobs/{job.OrganisationSlug}/{slug}-{job.Id}";
        }
        return $"/jobs/{job.Id}";
    }
}
