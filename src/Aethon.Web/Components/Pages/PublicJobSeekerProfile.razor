@page "/job-seeker/{Identifier}"
@attribute [AllowAnonymous]
@layout PublicLayout
@rendermode InteractiveServer
@using System.Net
@using System.Net.Http.Json
@using Aethon.Shared.Candidates
@using Aethon.Shared.Enums
@using Aethon.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject NavigationManager NavigationManager

<PageTitle>@(_profile is not null ? $"{DisplayName} | Aethon" : "Job seeker profile | Aethon")</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading profile…</div>
    </div>
}
else if (_profile is null)
{
    <div class="alert alert-danger rounded-4 mb-0">@(_error ?? "Profile not found.")</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <!-- Header -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-start gap-3 flex-wrap">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                            <h1 class="h3 fw-bold mb-0">@DisplayName</h1>
                            @if (_profile.OpenToWork)
                            {
                                <span class="badge bg-success rounded-pill" style="font-size:.8rem;">
                                    <i class="bi bi-briefcase-fill me-1"></i>Open to work
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_profile.Headline))
                        {
                            <p class="text-secondary mb-2">@_profile.Headline</p>
                        }
                        <div class="d-flex flex-wrap gap-3">
                            @if (!string.IsNullOrWhiteSpace(_profile.CurrentLocation))
                            {
                                <span class="text-secondary small"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@_profile.CurrentLocation</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_profile.LinkedInUrl))
                            {
                                <a href="@_profile.LinkedInUrl" target="_blank" rel="noopener noreferrer" class="text-secondary small text-decoration-none">
                                    <i class="bi bi-linkedin me-1" style="color:#0a66c2;"></i>LinkedIn
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_profile.Summary))
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">About</h2>
                    <div class="rich-content">@((MarkupString)_profile.Summary)</div>
                </div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_profile.AboutMe))
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">About</h2>
                    <p class="mb-0">@_profile.AboutMe</p>
                </div>
            </div>
        }

        @if (_profile.LastProfileUpdatedUtc.HasValue)
        {
            <div class="text-secondary small text-end">
                Profile updated @_profile.LastProfileUpdatedUtc.Value.ToLocalTime().ToString("dd MMM yyyy")
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Identifier { get; set; } = "";

    private bool _loaded;
    private string? _error;
    private PublicJobSeekerProfileDto? _profile;

    private string DisplayName =>
        _profile is null ? "" :
        !string.IsNullOrWhiteSpace(_profile.FirstName) || !string.IsNullOrWhiteSpace(_profile.LastName)
            ? $"{_profile.FirstName} {_profile.LastName}".Trim()
            : "Job seeker";

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;
        _error = null;
        _profile = null;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.GetAsync($"/api/v1/public/job-seekers/{Uri.EscapeDataString(Identifier)}");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                _error = "Profile not found.";
                return;
            }

            if (response.StatusCode is HttpStatusCode.Forbidden or HttpStatusCode.Unauthorized)
            {
                _error = "You do not have permission to view this profile.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not load this profile.";
                return;
            }

            _profile = await response.Content.ReadFromJsonAsync<PublicJobSeekerProfileDto>(AethonApiClient.JsonOptions);
        }
        catch
        {
            _error = "Could not load this profile.";
        }
        finally
        {
            _loaded = true;
        }
    }
}
