@page "/app/jobs/{JobId:guid}/checkout-success"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using Aethon.Shared.Jobs
@using Aethon.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@implements IDisposable
@inject AethonApiClient Api
@inject NavigationManager Nav

<PageTitle>Job Publishing | Aethon</PageTitle>

<div class="d-flex flex-column gap-4 align-items-center py-5" style="max-width:560px; margin:0 auto; text-align:center;">
    <div class="card border-0 shadow-sm rounded-4 w-100">
        <div class="card-body p-5">

            @if (_published)
            {
                <div class="mb-4" style="font-size:3.5rem;">
                    <i class="bi bi-check-circle-fill text-success"></i>
                </div>
                <h1 class="h3 fw-bold mb-2">Your job is now live!</h1>
                <p class="text-secondary mb-4">Payment confirmed. Your listing is published and visible to candidates.</p>
                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <a href="/app/jobs/@JobId" class="btn btn-primary rounded-4 px-4">View listing</a>
                    <a href="/app/employer" class="btn btn-outline-secondary rounded-4 px-4">Dashboard</a>
                </div>
            }
            else if (_timedOut)
            {
                <div class="mb-4" style="font-size:3.5rem;">
                    <i class="bi bi-clock-history text-warning"></i>
                </div>
                <h1 class="h3 fw-bold mb-2">Payment received</h1>
                <p class="text-secondary mb-4">
                    Your payment was successful. Your job will go live shortly once the payment is confirmed by our system.
                </p>
                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <a href="/app/employer" class="btn btn-primary rounded-4 px-4">Go to dashboard</a>
                    <a href="/app/jobs/@JobId" class="btn btn-outline-secondary rounded-4 px-4">View draft</a>
                </div>
            }
            else
            {
                <div class="mb-4">
                    <div class="spinner-border text-primary" role="status" style="width:3rem; height:3rem;"></div>
                </div>
                <h1 class="h3 fw-bold mb-2">Confirming your payment…</h1>
                <p class="text-secondary mb-0">Please wait while we confirm your payment and publish your listing.</p>
            }

        </div>
    </div>
</div>

@code {
    [Parameter] public Guid JobId { get; set; }

    private bool _published;
    private bool _timedOut;
    private CancellationTokenSource _cts = new();
    private int _pollCount;
    private const int MaxPolls = 10;   // 10 × 2 s = 20 s

    protected override async Task OnInitializedAsync()
    {
        await PollUntilPublishedAsync();
    }

    private async Task PollUntilPublishedAsync()
    {
        var client = await Api.CreateAsync();

        while (_pollCount < MaxPolls && !_cts.IsCancellationRequested)
        {
            await Task.Delay(2000, _cts.Token).ConfigureAwait(false);
            _pollCount++;

            try
            {
                var job = await client.GetFromJsonAsync<JobDetailDto>(
                    $"/api/v1/jobs/{JobId}", AethonApiClient.JsonOptions, _cts.Token);

                if (job?.Status == JobStatus.Published)
                {
                    _published = true;
                    await InvokeAsync(StateHasChanged);
                    return;
                }
            }
            catch
            {
                // Ignore transient errors and keep polling
            }

            await InvokeAsync(StateHasChanged);
        }

        _timedOut = true;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
