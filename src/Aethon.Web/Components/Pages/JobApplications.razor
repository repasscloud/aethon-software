@page "/app/jobs/{JobId}/applications"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net
@using System.Net.Http.Json
@using Aethon.Shared.Jobs
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api

<PageTitle>Applications | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading applications…</div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 fw-bold mb-2">Applications</h1>
                        <p class="text-secondary mb-0">Review candidates for this job.</p>
                    </div>
                    <a class="btn btn-outline-secondary rounded-4 px-4" href="/app/jobs/@JobId">Back to job</a>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger rounded-4 mb-0">@_error</div>
        }
        else if (_items.Count == 0)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <p class="text-secondary mb-0">No applications yet.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Applicant</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th>Submitted</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _items)
                                {
                                    <tr>
                                        <td>@item.ApplicantDisplayName</td>
                                        <td>@item.ApplicantEmail</td>
                                        <td>@item.Status</td>
                                        <td>@item.SubmittedUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-dark rounded-4" href="/app/applications/@item.Id">Open</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string JobId { get; set; } = "";

    private bool _loaded;
    private string? _error;
    private List<EmployerJobApplicationListItemDto> _items = [];

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;
        _error = null;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.GetAsync($"/api/v1/jobs/{JobId}/applications");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                _error = "Job not found.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not load applications.";
                return;
            }

            _items = await response.Content.ReadFromJsonAsync<List<EmployerJobApplicationListItemDto>>(AethonApiClient.JsonOptions) ?? [];
        }
        catch
        {
            _error = "Could not load applications.";
        }
        finally
        {
            _loaded = true;
        }
    }
}
