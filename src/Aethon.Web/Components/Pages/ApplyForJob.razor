@page "/jobs/{Id}/apply"
@page "/jobs/{OrgSlug}/{Slug}/apply"
@attribute [AllowAnonymous]
@layout PublicLayout
@rendermode InteractiveServer
@using System.Net
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.RegularExpressions
@using Aethon.Shared.Auth
@using Aethon.Shared.Enums
@using Aethon.Shared.Jobs
@using Aethon.Shared.Organisations
@using Aethon.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@inject AethonApiClient Api
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Apply — @(_job?.Title ?? "Job") | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading…</div>
    </div>
}
else if (_job is null)
{
    <div class="alert alert-danger rounded-4 mb-0">@(_error ?? "Job not found.")</div>
}
else if (!string.IsNullOrWhiteSpace(_job.ExternalApplicationUrl))
{
    <!-- External application — redirect notice -->
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <a href="@JobDetailUrl()" class="text-decoration-none text-secondary small"><i class="bi bi-arrow-left me-1"></i> Back to job</a>
                <h1 class="h4 fw-bold mt-3 mb-1">@_job.Title</h1>
                <div class="text-secondary mb-3">
                    <a class="text-decoration-none" href="/organisations/@_job.Organisation.Slug">@_job.Organisation.Name</a>
                </div>
            </div>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 text-center py-5">
                <i class="bi bi-box-arrow-up-right display-4 text-secondary mb-3 d-block"></i>
                <h2 class="h5 fw-bold mb-2">Apply on the company website</h2>
                <p class="text-secondary mb-4">This job uses an external application process. You will be taken to the company's own site to apply.</p>
                <a class="btn btn-dark rounded-4 px-5" href="@_job.ExternalApplicationUrl" target="_blank" rel="noopener noreferrer">
                    <i class="bi bi-box-arrow-up-right me-2"></i>Go to application
                </a>
            </div>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <!-- Job summary -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <a href="@JobDetailUrl()" class="text-decoration-none text-secondary small"><i class="bi bi-arrow-left me-1"></i> Back to job</a>
                <h1 class="h4 fw-bold mt-3 mb-1">Apply for @_job.Title</h1>
                <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
                    <a class="text-decoration-none text-secondary small" href="/organisations/@_job.Organisation.Slug">@_job.Organisation.Name</a>
                    @if (_job.Organisation.IsVerified)
                    {
                        @if (_job.Organisation.VerificationTier == VerificationTier.EnhancedTrusted)
                        {
                            <a href="/info/enhanced-verification" class="badge bg-success rounded-pill text-decoration-none" style="font-size:.7rem;" title="Enhanced Trusted Employer">
                                <i class="bi bi-shield-fill-check me-1"></i>Enhanced Trusted
                            </a>
                        }
                        else
                        {
                            <a href="/info/standard-verification" class="badge bg-primary rounded-pill text-decoration-none" style="font-size:.7rem;" title="Verified Employer">
                                <i class="bi bi-patch-check-fill me-1"></i>Verified
                            </a>
                        }
                    }
                </div>

                <!-- Key attributes row -->
                <div class="d-flex flex-wrap gap-3 mb-3">
                    @if (!string.IsNullOrWhiteSpace(_job.LocationText))
                    {
                        <span class="d-flex align-items-center gap-1 text-secondary">
                            <i class="bi bi-geo-alt-fill text-danger" style="font-size:.9rem;"></i>
                            <span>@_job.LocationText</span>
                        </span>
                    }
                    <span class="d-flex align-items-center gap-1 text-secondary">
                        <i class="bi bi-building text-primary" style="font-size:.9rem;"></i>
                        <span>@FormatEnum(_job.WorkplaceType.ToString())</span>
                    </span>
                    <span class="d-flex align-items-center gap-1 text-secondary">
                        <i class="bi bi-briefcase-fill text-secondary" style="font-size:.9rem;"></i>
                        <span>@FormatEnum(_job.EmploymentType.ToString())</span>
                    </span>
                    @if (_job.Category.HasValue)
                    {
                        <span class="d-flex align-items-center gap-1 text-secondary">
                            <i class="bi bi-tag-fill text-success" style="font-size:.9rem;"></i>
                            <span>@FormatCategory(_job.Category.Value)</span>
                        </span>
                    }
                    @if (!string.IsNullOrWhiteSpace(_job.Department))
                    {
                        <span class="d-flex align-items-center gap-1 text-secondary">
                            <i class="bi bi-diagram-3-fill text-warning" style="font-size:.9rem;"></i>
                            <span>@_job.Department</span>
                        </span>
                    }
                    @if (_job.SalaryFrom.HasValue || _job.SalaryTo.HasValue)
                    {
                        <span class="d-flex align-items-center gap-1">
                            <i class="bi bi-cash-coin text-success" style="font-size:.9rem;"></i>
                            @if (_job.SalaryFrom.HasValue && _job.SalaryTo.HasValue)
                            {
                                <span class="fw-semibold text-dark">@_job.SalaryCurrency @_job.SalaryFrom?.ToString("N0") – @_job.SalaryTo?.ToString("N0")</span>
                            }
                            else if (_job.SalaryFrom.HasValue)
                            {
                                <span class="fw-semibold text-dark">From @_job.SalaryCurrency @_job.SalaryFrom?.ToString("N0")</span>
                            }
                            @if (_job.HasCommission && _job.OteFrom.HasValue && _job.OteTo.HasValue)
                            {
                                <span class="ms-1 text-success fw-semibold">· OTE @_job.SalaryCurrency @_job.OteFrom?.ToString("N0") – @_job.OteTo?.ToString("N0")</span>
                            }
                            else if (_job.HasCommission)
                            {
                                <span class="ms-1 text-success">+ Commission</span>
                            }
                        </span>
                    }
                    else if (_job.HasCommission)
                    {
                        <span class="d-flex align-items-center gap-1 text-success">
                            <i class="bi bi-cash-coin" style="font-size:.9rem;"></i>
                            @if (_job.OteFrom.HasValue && _job.OteTo.HasValue)
                            {
                                <span class="fw-semibold">OTE @_job.SalaryCurrency @_job.OteFrom?.ToString("N0") – @_job.OteTo?.ToString("N0")</span>
                            }
                            else
                            {
                                <span>Commission available</span>
                            }
                        </span>
                    }
                    @if (_job.Regions.Count > 0)
                    {
                        <span class="d-flex align-items-center gap-1 text-secondary">
                            <i class="bi bi-globe2 text-info" style="font-size:.9rem;"></i>
                            <span>@string.Join(", ", _job.Regions.Select(FormatRegion))</span>
                        </span>
                    }
                </div>

                <!-- EOE / Accessible / Verification badges -->
                @if (_job.Organisation.IsEqualOpportunityEmployer || _job.Organisation.IsAccessibleWorkplace)
                {
                    <div class="d-flex flex-wrap gap-2">
                        @if (_job.Organisation.IsEqualOpportunityEmployer)
                        {
                            <a href="/info/equal-opportunity-employer" class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 text-decoration-none" style="font-size:.8rem;">
                                <i class="bi bi-people-fill me-1"></i>Equal Opportunity Employer
                            </a>
                        }
                        @if (_job.Organisation.IsAccessibleWorkplace)
                        {
                            <a href="/info/accessible-workplace" class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 text-decoration-none" style="font-size:.8rem;">
                                <i class="bi bi-universal-access me-1"></i>Accessible Workplace
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_job.ApplicationSpecialRequirements))
        {
            <div class="card border-0 shadow-sm rounded-4 border-warning">
                <div class="card-body p-4">
                    <h2 class="h6 fw-bold mb-3"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Special requirements for applicants</h2>
                    <div class="rich-content">@((MarkupString)_job.ApplicationSpecialRequirements)</div>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_job.ApplicationEmail))
        {
            <!-- Email apply form -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-1">Your application</h2>
                    <p class="text-secondary small mb-4">Your details and CV will be sent directly to the employer by email.</p>

                    @if (!string.IsNullOrWhiteSpace(_applyMessage))
                    {
                        <div class="alert alert-success rounded-4">@_applyMessage</div>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(_applyError))
                        {
                            <div class="alert alert-danger rounded-4">@_applyError</div>
                        }

                        <EditForm Model="_emailModel" OnValidSubmit="EmailApplyAsync">
                            <DataAnnotationsValidator />

                            <div class="row g-3 mb-3">
                                <div class="col-12 col-md-6">
                                    <label class="form-label fw-semibold">Full name <span class="text-danger">*</span></label>
                                    <InputText @bind-Value="_emailModel.ApplicantName" class="form-control rounded-4" placeholder="Jane Smith" />
                                    <ValidationMessage For="@(() => _emailModel.ApplicantName)" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label fw-semibold">Email address <span class="text-danger">*</span></label>
                                    <InputText @bind-Value="_emailModel.ApplicantEmail" class="form-control rounded-4" placeholder="jane@example.com" />
                                    <ValidationMessage For="@(() => _emailModel.ApplicantEmail)" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Phone number</label>
                                <InputText @bind-Value="_emailModel.ApplicantPhone" class="form-control rounded-4" placeholder="+1 555 000 0000" />
                                <ValidationMessage For="@(() => _emailModel.ApplicantPhone)" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Cover letter</label>
                                <InputTextArea @bind-Value="_emailModel.CoverLetter" class="form-control rounded-4" rows="8"
                                               placeholder="Tell the employer why you're the right person for this role…" />
                                <ValidationMessage For="@(() => _emailModel.CoverLetter)" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Resume / CV</label>
                                <InputFile OnChange="OnFileSelected" class="form-control rounded-4" accept=".pdf,.doc,.docx,.txt" />
                                @if (!string.IsNullOrWhiteSpace(_selectedFileName))
                                {
                                    <div class="text-secondary small mt-1"><i class="bi bi-paperclip me-1"></i>@_selectedFileName</div>
                                }
                                <div class="form-text">PDF, Word, or plain text. Max 5 MB.</div>
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-dark rounded-4 px-4" type="submit" disabled="@_applying">
                                    @(_applying ? "Sending…" : "Send application")
                                </button>
                                <a class="btn btn-outline-secondary rounded-4 px-4" href="@JobDetailUrl()">Cancel</a>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        }
        else
        {
            <!-- Internal ATS apply form -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Your application</h2>

                    @if (!string.IsNullOrWhiteSpace(_applyMessage))
                    {
                        <div class="alert alert-success rounded-4">@_applyMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(_applyError))
                    {
                        <div class="alert alert-danger rounded-4">@_applyError</div>
                    }

                    @if (!_isAuthenticated)
                    {
                        <p class="text-secondary mb-3">You need to sign in as a job seeker to apply for this role.</p>
                        <a class="btn btn-dark rounded-4 px-4" href="/login?returnUrl=@Uri.EscapeDataString(NavigationManager.Uri)">Sign in to apply</a>
                    }
                    else if (!_canApply)
                    {
                        <div class="alert alert-warning rounded-4 mb-0">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            Applying for jobs is not available for your account type. Job applications are for job seeker accounts only.
                        </div>
                    }
                    else
                    {
                        @if (string.IsNullOrWhiteSpace(_applyMessage))
                        {
                            <EditForm Model="_applyModel" OnValidSubmit="ApplyAsync">
                                <DataAnnotationsValidator />

                                @if (_screeningConfig is not null)
                                {
                                    @* ── Screening questions ── *@
                                    @if (_screeningConfig.WorkRights.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">@(string.IsNullOrEmpty(_sqCountry) ? "Right to work" : $"Which of the following best describes your right to work in {_sqCountry}?")</label>
                                            <select class="form-select rounded-4" value="@_answers.WorkRights"
                                                    @onchange="e => _answers.WorkRights = e.Value?.ToString()">
                                                <option value="">Select an answer</option>
                                                @foreach (var opt in _workRightsAnswers) { <option value="@opt">@opt</option> }
                                            </select>
                                        </div>
                                    }
                                    @if (_screeningConfig.YearsExperience.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">@(string.IsNullOrEmpty(_sqIndustry) ? "How many years of experience do you have?" : $"How many years of experience do you have in {_sqIndustry}?")</label>
                                            <select class="form-select rounded-4" value="@_answers.YearsExperience"
                                                    @onchange="e => _answers.YearsExperience = e.Value?.ToString()">
                                                <option value="">Select an answer</option>
                                                @foreach (var opt in _yearsExpAnswers) { <option value="@opt">@opt</option> }
                                            </select>
                                        </div>
                                    }
                                    @if (_screeningConfig.Salary.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">What is your expected annual base salary?</label>
                                            <div class="row g-2">
                                                <div class="col-6">
                                                    <label class="form-label small text-secondary">Minimum</label>
                                                    <select class="form-select rounded-4" value="@_answers.SalaryMin"
                                                            @onchange="e => _answers.SalaryMin = e.Value?.ToString()">
                                                        <option value="">Select minimum</option>
                                                        @foreach (var opt in _salaryOptions) { <option value="@opt">@opt</option> }
                                                    </select>
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small text-secondary">Maximum</label>
                                                    <select class="form-select rounded-4" value="@_answers.SalaryMax"
                                                            @onchange="e => _answers.SalaryMax = e.Value?.ToString()">
                                                        <option value="">Select maximum</option>
                                                        @foreach (var opt in _salaryOptionsMax) { <option value="@opt">@opt</option> }
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    @if (_screeningConfig.NoticePeriod.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">How much notice are you required to give your current employer?</label>
                                            <select class="form-select rounded-4" value="@_answers.NoticePeriod"
                                                    @onchange="e => _answers.NoticePeriod = e.Value?.ToString()">
                                                <option value="">Select an answer</option>
                                                @foreach (var opt in _noticePeriodAnswers) { <option value="@opt">@opt</option> }
                                            </select>
                                        </div>
                                    }
                                    @if (_screeningConfig.PoliceCheck.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Do you have a current police check for employment?</label>
                                            <select class="form-select rounded-4" value="@_answers.PoliceCheck"
                                                    @onchange="e => _answers.PoliceCheck = e.Value?.ToString()">
                                                <option value="">Select an answer</option>
                                                @foreach (var opt in _policeCheckAnswers) { <option value="@opt">@opt</option> }
                                            </select>
                                        </div>
                                    }
                                    @if (_screeningConfig.WorkingWithChildren.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Do you have a current Working with Children Check for employment?</label>
                                            <select class="form-select rounded-4" value="@_answers.WorkingWithChildren"
                                                    @onchange="e => _answers.WorkingWithChildren = e.Value?.ToString()">
                                                <option value="">Select an answer</option>
                                                @foreach (var opt in _wwcAnswers) { <option value="@opt">@opt</option> }
                                            </select>
                                        </div>
                                    }
                                    @if (_screeningConfig.MedicalCheck.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Are you willing to undergo a pre-employment medical check?</label>
                                            <select class="form-select rounded-4" value="@_answers.MedicalCheck"
                                                    @onchange="e => _answers.MedicalCheck = e.Value?.ToString()">
                                                <option value="">Select an answer</option>
                                                <option value="Yes">Yes</option>
                                                <option value="No">No</option>
                                            </select>
                                        </div>
                                    }
                                    @if (_screeningConfig.DriversLicence.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Do you currently hold a valid driver's licence?</label>
                                            <select class="form-select rounded-4" value="@_answers.DriversLicence"
                                                    @onchange="e => _answers.DriversLicence = e.Value?.ToString()">
                                                <option value="">Select an answer</option>
                                                <option value="Yes">Yes</option>
                                                <option value="No">No</option>
                                            </select>
                                        </div>
                                    }
                                    @if (_screeningConfig.CarAccess.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Do you own or have regular access to a car?</label>
                                            <select class="form-select rounded-4" value="@_answers.CarAccess"
                                                    @onchange="e => _answers.CarAccess = e.Value?.ToString()">
                                                <option value="">Select an answer</option>
                                                <option value="Yes">Yes</option>
                                                <option value="No">No</option>
                                            </select>
                                        </div>
                                    }
                                    @if (_screeningConfig.PublicHolidays.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Are you available to work on public holidays?</label>
                                            <select class="form-select rounded-4" value="@_answers.PublicHolidays"
                                                    @onchange="e => _answers.PublicHolidays = e.Value?.ToString()">
                                                <option value="">Select an answer</option>
                                                <option value="Yes">Yes</option>
                                                <option value="No">No</option>
                                            </select>
                                        </div>
                                    }
                                    @if (_screeningConfig.Qualification.Enabled)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">@(string.IsNullOrEmpty(_sqIndustry) ? "Do you hold a relevant qualification?" : $"Do you hold a qualification in {_sqIndustry}?")</label>
                                            @foreach (var opt in _qualificationAnswers)
                                            {
                                                <div class="form-check">
                                                    <input type="checkbox" class="form-check-input" id="@($"sqQual{opt.GetHashCode()}")"
                                                           checked="@_answers.Qualification.Contains(opt)"
                                                           @onchange="e => { if ((bool)e.Value!) { if (!_answers.Qualification.Contains(opt)) _answers.Qualification.Add(opt); } else _answers.Qualification.Remove(opt); }" />
                                                    <label class="form-check-label" for="@($"sqQual{opt.GetHashCode()}")">@opt</label>
                                                </div>
                                            }
                                        </div>
                                    }
                                }

                                <div class="mb-4">
                                    <label class="form-label fw-semibold">Cover letter</label>
                                    <InputTextArea @bind-Value="_applyModel.CoverLetter" class="form-control rounded-4" rows="8"
                                                   placeholder="Tell the employer why you're the right person for this role…" />
                                </div>

                                <div class="d-flex gap-2">
                                    <button class="btn btn-dark rounded-4 px-4" type="submit" disabled="@_applying">
                                        @(_applying ? "Submitting…" : "Submit application")
                                    </button>
                                    <a class="btn btn-outline-secondary rounded-4 px-4" href="@JobDetailUrl()">Cancel</a>
                                </div>
                            </EditForm>
                        }
                    }
                </div>
            </div>
        }

    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";
    [Parameter] public string OrgSlug { get; set; } = "";
    [Parameter] public string Slug { get; set; } = "";

    private bool _loaded;
    private bool _isAuthenticated;
    private bool _canApply;
    private bool _applying;
    private string? _error;
    private string? _applyMessage;
    private string? _applyError;
    private PublicJobDetailDto? _job;
    private Guid _jobId;

    // Internal ATS apply
    private readonly CreateJobApplicationRequestDto _applyModel = new();

    // Email apply
    private readonly EmailJobApplicationRequestDto _emailModel = new();
    private string? _selectedFileName;

    // Screening questions
    private ScreeningConfig? _screeningConfig;
    private readonly ScreeningAnswers _answers = new();
    private string _sqCountry = "";
    private string _sqIndustry = "";

    private static readonly string[] _workRightsAnswers =
    [
        "I have permanent work rights with no restrictions",
        "I have temporary work rights with no restrictions",
        "I have temporary work rights limited to designated locations",
        "I have temporary work rights with limitations on work hours",
        "I have temporary work rights limited to specific industries",
        "I require sponsorship to work for a new employer"
    ];
    private static readonly string[] _yearsExpAnswers =
        ["No experience", "Less than 1 year", "1 year", "2 years", "3 years", "4 years", "5 years", "5+ years"];
    private static readonly string[] _salaryOptions =
    [
        "$30,000","$35,000","$40,000","$45,000","$50,000","$55,000","$60,000","$65,000","$70,000",
        "$80,000","$90,000","$100,000","$110,000","$120,000","$130,000","$140,000","$150,000",
        "$170,000","$200,000","$250,000","$300,000","$350,000"
    ];
    private static readonly string[] _salaryOptionsMax =
    [
        "$30,000","$35,000","$40,000","$45,000","$50,000","$55,000","$60,000","$65,000","$70,000",
        "$80,000","$90,000","$100,000","$110,000","$120,000","$130,000","$140,000","$150,000",
        "$170,000","$200,000","$250,000","$300,000","$350,000","$350,000+"
    ];
    private static readonly string[] _noticePeriodAnswers =
        ["None, I can start immediately", "1 week", "2 weeks", "3 weeks", "4 weeks", "5 weeks", "5 or more weeks"];
    private static readonly string[] _policeCheckAnswers =
        ["Yes, I have a current police check", "I am willing to undertake a police check", "No"];
    private static readonly string[] _wwcAnswers =
        ["Yes, I have a current Working with Children Check", "I am willing to undertake a Working with Children Check", "No"];
    private string[] _qualificationAnswers = [];

    private static string FormatEnum(string value) =>
        System.Text.RegularExpressions.Regex.Replace(value, @"(?<!^)([A-Z])", " $1");

    private static string FormatRegion(JobRegion r) => r switch
    {
        JobRegion.LatinAmerica => "Latin America",
        JobRegion.MiddleEast => "Middle East",
        JobRegion.NorthAmerica => "North America",
        _ => r.ToString()
    };

    private static string FormatCategory(JobCategory? c) => c switch
    {
        JobCategory.AdminSecretarial => "Admin & Secretarial",
        JobCategory.AdvertisingPR => "Advertising & PR",
        JobCategory.AgricultureFishingForestry => "Agriculture, Fishing & Forestry",
        JobCategory.BuildingConstruction => "Building & Construction",
        JobCategory.CustomerService => "Customer Service",
        JobCategory.ExecutiveManagement => "Executive & Management",
        JobCategory.FinanceInsurance => "Finance & Insurance",
        JobCategory.FoodBeverage => "Food & Beverage",
        JobCategory.GraduateRoles => "Graduate Roles",
        JobCategory.HumanResources => "Human Resources",
        JobCategory.ITSoftware => "IT & Software",
        JobCategory.LegalServices => "Legal Services",
        JobCategory.MediaJournalism => "Media & Journalism",
        JobCategory.MiningResources => "Mining & Resources",
        JobCategory.PartTimeTemp => "Part-time & Temp",
        JobCategory.PropertyRealEstate => "Property & Real Estate",
        JobCategory.PublicRelations => "Public Relations",
        JobCategory.SecurityIntelligence => "Security & Intelligence",
        JobCategory.SocialWork => "Social Work",
        JobCategory.SportRecreation => "Sport & Recreation",
        JobCategory.TelecommunicationsISP => "Telecommunications & ISP",
        JobCategory.TransportDistribution => "Transport & Distribution",
        JobCategory.UtilitiesEnergy => "Utilities & Energy",
        not null => c.Value.ToString(),
        _ => ""
    };

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;
        _error = null;
        _applyMessage = null;
        _applyError = null;

        // Resolve job ID from either route pattern
        if (!string.IsNullOrEmpty(Slug))
        {
            var guidStr = Slug.Length >= 36 ? Slug[^36..] : "";
            if (!Guid.TryParse(guidStr, out _jobId))
            {
                _error = "Invalid job URL.";
                _loaded = true;
                return;
            }
        }
        else if (!Guid.TryParse(Id, out _jobId))
        {
            _error = "Invalid job URL.";
            _loaded = true;
            return;
        }

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
            if (_isAuthenticated)
            {
                var appType = authState.User.FindFirst(AppClaimTypes.AppType)?.Value ?? "";
                _canApply = appType == "jobseeker";
            }
            else
            {
                _canApply = false; // must sign in first
            }

            var client = await Api.CreateAsync();
            var response = await client.GetAsync($"/api/v1/public/jobs/{_jobId}");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                _error = "Job not found.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not load this job posting.";
                return;
            }

            _job = await response.Content.ReadFromJsonAsync<PublicJobDetailDto>(AethonApiClient.JsonOptions);

            // Parse screening questions config
            if (_job is not null && !string.IsNullOrWhiteSpace(_job.ScreeningQuestionsJson))
            {
                try
                {
                    _screeningConfig = JsonSerializer.Deserialize<ScreeningConfig>(
                        _job.ScreeningQuestionsJson,
                        new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                }
                catch { _screeningConfig = null; }
            }
            if (_job is not null)
            {
                _sqIndustry = FormatCategory(_job.Category);
                _qualificationAnswers =
                [
                    "Yes, Bachelor degree",
                    "Yes, Bachelor degree with honours",
                    "Yes, Graduate certificate",
                    "Yes, Graduate diploma",
                    "Yes, Master's degree",
                    "Yes, Doctoral degree",
                    string.IsNullOrEmpty(_sqIndustry) ? "I have a relevant qualification that is not listed" : $"I have a qualification in {_sqIndustry} that is not listed",
                    string.IsNullOrEmpty(_sqIndustry) ? "I do not have a relevant qualification" : $"I do not have a qualification in {_sqIndustry}"
                ];
            }

            // Auto-fill email form if authenticated
            if (_isAuthenticated && !string.IsNullOrWhiteSpace(_job?.ApplicationEmail))
            {
                await TryPrefillEmailFormAsync(client);
            }
        }
        catch
        {
            _error = "Could not load this job posting.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private async Task TryPrefillEmailFormAsync(HttpClient client)
    {
        try
        {
            var profileResponse = await client.GetAsync("/api/v1/candidates/profile");
            if (!profileResponse.IsSuccessStatusCode) return;

            var profile = await profileResponse.Content.ReadFromJsonAsync<JobSeekerProfileDto>(AethonApiClient.JsonOptions);
            if (profile is null) return;

            var fullName = string.Join(" ", new[] { profile.FirstName, profile.LastName }
                .Where(s => !string.IsNullOrWhiteSpace(s)));

            if (!string.IsNullOrWhiteSpace(fullName))
                _emailModel.ApplicantName = fullName;

            if (!string.IsNullOrWhiteSpace(profile.PhoneNumber))
                _emailModel.ApplicantPhone = profile.PhoneNumber;
        }
        catch { /* Best-effort prefill */ }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        _selectedFileName = null;
        _emailModel.ResumeFileName = null;
        _emailModel.ResumeContentBase64 = null;
        _emailModel.ResumeContentType = null;

        if (file is null) return;

        const long maxBytes = 5 * 1024 * 1024; // 5 MB
        if (file.Size > maxBytes)
        {
            _applyError = "File is too large. Maximum size is 5 MB.";
            return;
        }

        var allowed = new[] { ".pdf", ".doc", ".docx", ".txt" };
        var ext = System.IO.Path.GetExtension(file.Name).ToLowerInvariant();
        if (!allowed.Contains(ext))
        {
            _applyError = "Only PDF, Word (.doc/.docx), or plain text files are accepted.";
            return;
        }

        _applyError = null;

        using var ms = new System.IO.MemoryStream();
        await using var stream = file.OpenReadStream(maxBytes);
        await stream.CopyToAsync(ms);

        _emailModel.ResumeFileName = file.Name;
        _emailModel.ResumeContentBase64 = Convert.ToBase64String(ms.ToArray());
        _emailModel.ResumeContentType = file.ContentType;
        _selectedFileName = file.Name;
    }

    private async Task EmailApplyAsync()
    {
        _applyError = null;
        _applyMessage = null;
        _applying = true;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsJsonAsync($"/api/v1/public/jobs/{_jobId}/apply-email", _emailModel);

            if (response.IsSuccessStatusCode)
            {
                _applyMessage = "Your application has been sent to the employer. Good luck!";
                return;
            }

            _applyError = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(_applyError))
                _applyError = "Your application could not be sent. Please try again.";
        }
        catch
        {
            _applyError = "Your application could not be sent. Please try again.";
        }
        finally
        {
            _applying = false;
        }
    }

    private async Task ApplyAsync()
    {
        _applyError = null;
        _applyMessage = null;
        _applying = true;

        if (_screeningConfig is not null)
            _applyModel.ScreeningAnswersJson = JsonSerializer.Serialize(_answers);

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsJsonAsync($"/api/v1/public/jobs/{_jobId}/apply", _applyModel);

            if (response.IsSuccessStatusCode)
            {
                _applyMessage = "Your application has been submitted successfully. Good luck!";
                return;
            }

            _applyError = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(_applyError))
                _applyError = "Your application could not be submitted. Please try again.";
        }
        catch
        {
            _applyError = "Your application could not be submitted. Please try again.";
        }
        finally
        {
            _applying = false;
        }
    }

    private string JobDetailUrl()
    {
        if (_job is null) return "/jobs";
        var orgSlug = _job.Organisation.Slug;
        if (!string.IsNullOrEmpty(orgSlug))
            return $"/jobs/{orgSlug}/{JobSlug(_job.Title, _jobId)}";
        return $"/jobs/{_jobId}";
    }

    private static string JobSlug(string title, Guid id)
    {
        var clean = Regex.Replace(title.ToLowerInvariant(), @"[^a-z0-9\s_]", "");
        var slug = Regex.Replace(clean.Trim(), @"\s+", "-");
        return $"{slug}-{id}";
    }
