@page "/app/jobseeker"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Security.Claims
@using Aethon.Shared.Auth
@using Aethon.Shared.Applications
@using Aethon.Shared.Common
@using Aethon.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AethonApiClient Api

<PageTitle>Job seeker dashboard | Aethon</PageTitle>

@if (_ready)
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h1 class="h3 fw-bold mb-2">Job seeker dashboard</h1>
                <p class="text-secondary mb-0">Signed in as @_displayName</p>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="small text-secondary mb-2">Applications</div>
                        <div class="fw-bold fs-2">@_applicationCount</div>
                        <a href="/app/applications" class="small text-dark mt-2 d-block">View all →</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="small text-secondary mb-2">Profile status</div>
                        <div class="fw-semibold fs-5">@(_hasProfile ? "Complete" : "Incomplete")</div>
                        <a href="/app/jobseeker/profile" class="small text-dark mt-2 d-block">Edit profile →</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="small text-secondary mb-2">Email</div>
                        <div class="fw-semibold fs-5 text-truncate">@_email</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="small text-secondary mb-2">Browse jobs</div>
                        <div class="text-secondary">Find your next opportunity.</div>
                        <a href="/jobs" class="small text-dark mt-2 d-block">Browse jobs →</a>
                    </div>
                </div>
            </div>
        </div>

        @if (_recentApplications.Count > 0)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Recent applications</h2>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Job</th>
                                    <th>Status</th>
                                    <th>Applied</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in _recentApplications)
                                {
                                    <tr>
                                        <td><a href="/app/applications/@app.Id">@app.JobTitle</a></td>
                                        <td><span class="badge bg-secondary rounded-pill">@app.Status</span></td>
                                        <td>@app.SubmittedUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _ready;
    private bool _hasProfile;
    private string _displayName = "";
    private string _email = "";
    private int _applicationCount;
    private List<ApplicationSummaryDto> _recentApplications = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _displayName = user.FindFirstValue(AppClaimTypes.DisplayName) ?? user.Identity?.Name ?? "Unknown";
        _email = user.FindFirstValue(ClaimTypes.Email) ?? "";

        var client = await Api.CreateAsync();

        try
        {
            var profile = await client.GetFromJsonAsync<object>("/api/v1/me/profile", AethonApiClient.JsonOptions);
            _hasProfile = profile is not null;
        }
        catch { }

        try
        {
            var paged = await client.GetFromJsonAsync<PagedResult<ApplicationSummaryDto>>("/api/v1/applications/mine", AethonApiClient.JsonOptions);
            var applications = paged?.Items ?? [];
            _applicationCount = paged?.TotalCount ?? applications.Count;
            _recentApplications = applications.Take(5).ToList();
        }
        catch { }

        _ready = true;
    }
}
