@page "/app/organisation/team/{UserId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject NavigationManager Nav

<PageTitle>@(_member?.DisplayName ?? "Team member") | Organisation | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading…</div>
    </div>
}
else if (_member is null)
{
    <div class="alert alert-danger rounded-4">Member not found or access denied.</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <!-- Header -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <a href="/app/organisation/team" class="text-secondary small text-decoration-none">← Organisation team</a>
                <div class="d-flex align-items-start gap-3 flex-wrap mt-2">
                    <div class="flex-grow-1">
                        <h1 class="h3 fw-bold mb-1">@_member.DisplayName</h1>
                        <div class="d-flex flex-wrap gap-2 align-items-center">
                            <span class="badge bg-secondary rounded-pill">@(_member.CompanyRole ?? _member.RecruiterRole ?? "—")</span>
                            <span class="badge @StatusBadge(_member.MembershipStatus) rounded-pill">@_member.MembershipStatus</span>
                            @if (_member.IsOwner)
                            {
                                <span class="badge bg-dark rounded-pill">Owner</span>
                            }
                            @if (_member.IsIdentityVerified)
                            {
                                <span class="badge bg-success rounded-pill"><i class="bi bi-patch-check-fill me-1"></i>ID Verified</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_pageError))
        {
            <div class="alert alert-danger rounded-4">@_pageError</div>
        }
        @if (!string.IsNullOrEmpty(_successMsg))
        {
            <div class="alert alert-success rounded-4">@_successMsg</div>
        }

        <!-- Member info -->
        <div class="row g-3">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3">Account</h2>
                        <dl class="row mb-0 small">
                            <dt class="col-5 text-secondary">Email</dt>
                            <dd class="col-7">@_member.Email</dd>
                            <dt class="col-5 text-secondary">Email confirmed</dt>
                            <dd class="col-7">@(_member.EmailConfirmed ? "Yes" : "No")</dd>
                            <dt class="col-5 text-secondary">ID verified</dt>
                            <dd class="col-7">@(_member.IsIdentityVerified ? "Yes" : "No")</dd>
                            <dt class="col-5 text-secondary">Joined</dt>
                            <dd class="col-7">@_member.JoinedUtc.ToLocalTime().ToString("dd MMM yyyy")</dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3">Team profile</h2>
                        @if (_member.Profile is null)
                        {
                            <p class="text-secondary small mb-0">This member has not set up a team profile yet.</p>
                        }
                        else
                        {
                            <dl class="row mb-0 small">
                                <dt class="col-5 text-secondary">Job title</dt>
                                <dd class="col-7">@(_member.Profile.JobTitle ?? "—")</dd>
                                <dt class="col-5 text-secondary">Public email</dt>
                                <dd class="col-7">@(_member.Profile.PublicEmail ?? "—")</dd>
                                <dt class="col-5 text-secondary">Public phone</dt>
                                <dd class="col-7">@(_member.Profile.PublicPhone ?? "—")</dd>
                                <dt class="col-5 text-secondary">LinkedIn</dt>
                                <dd class="col-7">@(_member.Profile.LinkedInUrl ?? "—")</dd>
                                <dt class="col-5 text-secondary">Slug</dt>
                                <dd class="col-7">@(_member.Profile.Slug ?? "—")</dd>
                                <dt class="col-5 text-secondary">Publicly visible</dt>
                                <dd class="col-7">@(_member.Profile.IsPublicProfileEnabled ? "Yes" : "No")</dd>
                            </dl>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (_member.ViewerCanManage)
        {
            <!-- Role management -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Role</h2>
                    @if (_member.IsOwner)
                    {
                        <p class="text-secondary small mb-0">The organisation owner's role cannot be changed.</p>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2 align-items-end">
                            @if (_member.OrganisationType == "company")
                            {
                                <div>
                                    <label class="form-label small fw-semibold mb-1">Company role</label>
                                    <select class="form-select form-select-sm rounded-3" @bind="_selectedCompanyRole">
                                        <option value="Admin">Admin</option>
                                        <option value="Recruiter">Recruiter</option>
                                        <option value="HiringManager">HiringManager</option>
                                        <option value="Interviewer">Interviewer</option>
                                        <option value="Viewer">Viewer</option>
                                    </select>
                                </div>
                            }
                            else
                            {
                                <div>
                                    <label class="form-label small fw-semibold mb-1">Recruiter role</label>
                                    <select class="form-select form-select-sm rounded-3" @bind="_selectedRecruiterRole">
                                        <option value="Admin">Admin</option>
                                        <option value="Recruiter">Recruiter</option>
                                        <option value="TeamLead">TeamLead</option>
                                        <option value="Viewer">Viewer</option>
                                    </select>
                                </div>
                            }
                            <button class="btn btn-sm btn-primary rounded-pill" @onclick="SaveRoleAsync" disabled="@_saving">
                                @(_saving ? "Saving…" : "Save role")
                            </button>
                        </div>
                    }
                </div>
            </div>

            <!-- Status management -->
            @if (!_member.IsOwner)
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3">Status</h2>
                        <div class="d-flex flex-wrap gap-2">
                            @if (_member.MembershipStatus != "Active")
                            {
                                <button class="btn btn-sm btn-outline-success rounded-pill" @onclick='() => SetStatusAsync("Active")'>
                                    Reactivate
                                </button>
                            }
                            @if (_member.MembershipStatus != "Suspended")
                            {
                                <button class="btn btn-sm btn-outline-warning rounded-pill" @onclick='() => SetStatusAsync("Suspended")'>
                                    Suspend
                                </button>
                            }
                            @if (_member.MembershipStatus != "Revoked")
                            {
                                <button class="btn btn-sm btn-outline-danger rounded-pill" @onclick='() => SetStatusAsync("Revoked")'>
                                    Revoke access
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Identity verification (owner only) -->
            @if (_member.ViewerIsOwner && !_member.IsIdentityVerified)
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3">Identity verification</h2>
                        <p class="small text-secondary mb-3">
                            As the organisation owner you can manually verify this member's identity.
                            This creates an audit record.
                        </p>
                        <button class="btn btn-sm btn-success rounded-pill" @onclick="VerifyIdentityAsync" disabled="@_saving">
                            <i class="bi bi-patch-check me-1"></i>@(_saving ? "Verifying…" : "Verify identity")
                        </button>
                    </div>
                </div>
            }

            <!-- Remove member -->
            @if (!_member.IsOwner)
            {
                <div class="card border-0 shadow-sm rounded-4 border-danger-subtle">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3 text-danger">Remove from organisation</h2>
                        <p class="small text-secondary mb-3">This will revoke the member's access immediately.</p>
                        @if (!_confirmRemove)
                        {
                            <button class="btn btn-sm btn-outline-danger rounded-pill" @onclick="() => _confirmRemove = true">
                                Remove member
                            </button>
                        }
                        else
                        {
                            <div class="d-flex gap-2 align-items-center">
                                <span class="small text-danger fw-semibold">Are you sure?</span>
                                <button class="btn btn-sm btn-danger rounded-pill" @onclick="RemoveMemberAsync" disabled="@_saving">
                                    @(_saving ? "Removing…" : "Yes, remove")
                                </button>
                                <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick="() => _confirmRemove = false">
                                    Cancel
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        }

    </div>
}

@code {
    [Parameter] public Guid UserId { get; set; }

    private bool _loaded;
    private bool _saving;
    private bool _confirmRemove;
    private string? _pageError;
    private string? _successMsg;
    private OrganisationMemberDetailDto? _member;
    private string _selectedCompanyRole = "Viewer";
    private string _selectedRecruiterRole = "Viewer";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _pageError = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.GetAsync($"/api/v1/organisations/me/members/{UserId}");
            if (resp.IsSuccessStatusCode)
            {
                _member = await resp.Content.ReadFromJsonAsync<OrganisationMemberDetailDto>(AethonApiClient.JsonOptions);
                if (_member is not null)
                {
                    _selectedCompanyRole = _member.CompanyRole ?? "Viewer";
                    _selectedRecruiterRole = _member.RecruiterRole ?? "Viewer";
                }
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Forbidden ||
                     resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _member = null;
            }
            else
            {
                _pageError = "Could not load member details.";
            }
        }
        catch { _pageError = "Could not load member details."; }
        finally { _loaded = true; }
    }

    private async Task SaveRoleAsync()
    {
        _saving = true; _pageError = null; _successMsg = null;
        try
        {
            var client = await Api.CreateAsync();
            string? companyRole = _member!.OrganisationType == "company" ? _selectedCompanyRole : null;
            string? recruiterRole = _member.OrganisationType == "company" ? null : _selectedRecruiterRole;
            var body = new { companyRole, recruiterRole };
            var resp = await client.PutAsJsonAsync($"/api/v1/organisations/me/members/{UserId}/role", body);
            if (resp.IsSuccessStatusCode) { _successMsg = "Role updated."; await LoadAsync(); }
            else _pageError = "Could not update role.";
        }
        catch { _pageError = "Could not update role."; }
        finally { _saving = false; }
    }

    private async Task SetStatusAsync(string status)
    {
        _saving = true; _pageError = null; _successMsg = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.PutAsJsonAsync($"/api/v1/organisations/me/members/{UserId}/status", new { status });
            if (resp.IsSuccessStatusCode) { _successMsg = $"Status set to {status}."; await LoadAsync(); }
            else _pageError = "Could not update status.";
        }
        catch { _pageError = "Could not update status."; }
        finally { _saving = false; }
    }

    private async Task VerifyIdentityAsync()
    {
        _saving = true; _pageError = null; _successMsg = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.PostAsync($"/api/v1/organisations/me/members/{UserId}/verify-identity", null);
            if (resp.IsSuccessStatusCode) { _successMsg = "Identity verified successfully."; await LoadAsync(); }
            else _pageError = "Could not verify identity.";
        }
        catch { _pageError = "Could not verify identity."; }
        finally { _saving = false; }
    }

    private async Task RemoveMemberAsync()
    {
        _saving = true; _pageError = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.DeleteAsync($"/api/v1/organisations/me/members/{UserId}");
            if (resp.IsSuccessStatusCode) Nav.NavigateTo("/app/organisation/team");
            else _pageError = "Could not remove member.";
        }
        catch { _pageError = "Could not remove member."; }
        finally { _saving = false; _confirmRemove = false; }
    }

    private static string StatusBadge(string? s) => s switch
    {
        "Active" => "bg-success",
        "Suspended" => "bg-warning text-dark",
        "Revoked" => "bg-danger",
        _ => "bg-secondary"
    };
}
