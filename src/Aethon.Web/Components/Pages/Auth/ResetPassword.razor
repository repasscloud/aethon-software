@page "/reset-password"
@layout EmptyLayout
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Reset Password | Aethon</PageTitle>

<div class="container-fluid login-shell py-4 py-lg-5">
    <div class="row justify-content-center align-items-center w-100 m-0">
        <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-dark text-white mb-3"
                             style="width: 64px; height: 64px; font-size: 1.4rem; font-weight: 700;">
                            A
                        </div>
                        <h2 class="h4 fw-bold mb-1">Set new password</h2>
                        @if (_requiresMfa)
                        {
                            <p class="text-secondary small mb-0">Your account has two-factor authentication. Enter your authenticator code to continue.</p>
                        }
                        else
                        {
                            <p class="text-secondary small mb-0">Choose a new password for your account.</p>
                        }
                    </div>

                    @if (_invalidLink)
                    {
                        <div class="alert alert-danger rounded-3">
                            This reset link is invalid or has expired. <a href="/forgot-password">Request a new one</a>.
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger rounded-3 mb-3">@_error</div>
                    }
                    else if (!string.IsNullOrEmpty(_success))
                    {
                        <div class="alert alert-success rounded-3 mb-3">@_success</div>
                    }

                    @if (!_invalidLink && !_done)
                    {
                        @if (_requiresMfa)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Authenticator Code</label>
                                <input type="text"
                                       inputmode="numeric"
                                       maxlength="6"
                                       autocomplete="one-time-code"
                                       class="form-control form-control-lg rounded-4 text-center"
                                       style="letter-spacing: 0.3em; font-size: 1.4rem; min-height: 58px;"
                                       placeholder="000000"
                                       @bind="_totpCode" />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-semibold">New Password</label>
                            <input type="password"
                                   class="form-control form-control-lg rounded-4"
                                   style="min-height: 58px;"
                                   placeholder="Enter new password"
                                   @bind="_newPassword" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Confirm New Password</label>
                            <input type="password"
                                   class="form-control form-control-lg rounded-4"
                                   style="min-height: 58px;"
                                   placeholder="Confirm new password"
                                   @bind="_confirmPassword" />
                        </div>
                        <div class="d-grid mb-3">
                            <button class="btn btn-dark btn-lg rounded-4" style="min-height: 58px;"
                                    @onclick="Submit" disabled="@_loading">
                                @(_loading ? "Resetting..." : "Reset Password")
                            </button>
                        </div>
                    }

                    @if (_done)
                    {
                        <div class="d-grid">
                            <a href="/login" class="btn btn-dark btn-lg rounded-4" style="min-height: 58px;">Sign in</a>
                        </div>
                    }
                    else if (!_invalidLink)
                    {
                        <div class="text-center">
                            <a href="/login" class="small text-secondary text-decoration-none">Back to sign in</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _email = "";
    private string _token = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    private string _totpCode = "";
    private bool _requiresMfa;
    private bool _loading;
    private bool _done;
    private bool _invalidLink;
    private string? _error;
    private string? _success;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("email", out var email)) _email = email.ToString();
        if (query.TryGetValue("token", out var token)) _token = token.ToString();

        if (string.IsNullOrEmpty(_email) || string.IsNullOrEmpty(_token))
        {
            _invalidLink = true;
            return;
        }

        // Check whether the account requires MFA during reset
        try
        {
            var client = HttpClientFactory.CreateClient("AethonApiDirect");
            var result = await client.GetFromJsonAsync<MfaCheckResponse>(
                $"/api/v1/auth/reset-password/check?email={Uri.EscapeDataString(_email)}");
            _requiresMfa = result?.RequiresMfa == true;
        }
        catch
        {
            // If the check fails, proceed without MFA — the API will enforce it
        }
    }

    private async Task Submit()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            _error = "Please enter a new password.";
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }
        if (_requiresMfa && string.IsNullOrWhiteSpace(_totpCode))
        {
            _error = "Please enter your authenticator code.";
            return;
        }

        _loading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("AethonApiDirect");
            var response = await client.PostAsJsonAsync("/api/v1/auth/reset-password", new
            {
                email = _email,
                token = _token,
                newPassword = _newPassword,
                totpCode = string.IsNullOrWhiteSpace(_totpCode) ? null : _totpCode
            });

            if (response.IsSuccessStatusCode)
            {
                _success = "Your password has been reset. You can now sign in with your new password.";
                _done = true;
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                if (content.Contains("invalid_token") || content.Contains("InvalidToken"))
                    _error = "This reset link is invalid or has expired. Please request a new one.";
                else if (content.Contains("mfa_required"))
                    _error = "Please enter your authenticator code.";
                else if (content.Contains("invalid_mfa_code"))
                    _error = "Invalid authenticator code. Please try again.";
                else
                    _error = "Failed to reset password. The link may have expired.";
            }
        }
        catch
        {
            _error = "Unable to reach the service. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private record MfaCheckResponse(bool RequiresMfa);
}
