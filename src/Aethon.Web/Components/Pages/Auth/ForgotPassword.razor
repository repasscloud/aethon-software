@page "/forgot-password"
@layout EmptyLayout
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Forgot Password | Aethon</PageTitle>

<div class="container-fluid login-shell py-4 py-lg-5">
    <div class="row justify-content-center align-items-center w-100 m-0">
        <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-dark text-white mb-3"
                             style="width: 64px; height: 64px; font-size: 1.4rem; font-weight: 700;">
                            A
                        </div>
                        <h2 class="h4 fw-bold mb-1">Forgot your password?</h2>
                        <p class="text-secondary small mb-0">Enter your email and we'll send you a reset link.</p>
                    </div>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger rounded-3 mb-3">@_error</div>
                    }
                    @if (!string.IsNullOrEmpty(_success))
                    {
                        <div class="alert alert-success rounded-3 mb-3">@_success</div>
                    }

                    @if (!_sent)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email address</label>
                            <input type="email"
                                   class="form-control form-control-lg rounded-4"
                                   style="min-height: 58px;"
                                   placeholder="name@company.com"
                                   @bind="_email" />
                        </div>
                        <div class="d-grid mb-3">
                            <button class="btn btn-dark btn-lg rounded-4" style="min-height: 58px;"
                                    @onclick="Submit" disabled="@_loading">
                                @(_loading ? "Sending..." : "Send reset link")
                            </button>
                        </div>
                    }

                    <div class="text-center">
                        <a href="/login" class="small text-secondary text-decoration-none">Back to sign in</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _email = "";
    private bool _loading;
    private bool _sent;
    private string? _error;
    private string? _success;

    private async Task Submit()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_email))
        {
            _error = "Please enter your email address.";
            return;
        }

        _loading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("AethonApiDirect");
            var response = await client.PostAsJsonAsync("/api/v1/auth/forgot-password", new { email = _email });

            // Always show success message — never reveal whether the email exists
            _sent = true;
            _success = "If that email is registered, a reset link has been sent. Please check your inbox.";
        }
        catch
        {
            _error = "Unable to reach the service. Please try again later.";
        }
        finally
        {
            _loading = false;
        }
    }
}
