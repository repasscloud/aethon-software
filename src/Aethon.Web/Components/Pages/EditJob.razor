@page "/app/jobs/{Id}/edit"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net
@using System.Net.Http.Json
@using Aethon.Shared.Enums
@using Aethon.Shared.Jobs
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject NavigationManager NavigationManager

<PageTitle>Edit job | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h4 fw-bold mb-2">Loading job</h1>
            <p class="text-secondary mb-0">Fetching job details for editing.</p>
        </div>
    </div>
}
else if (_notFound)
{
    <div class="alert alert-danger rounded-4 mb-0">Job not found.</div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h1 class="h3 fw-bold mb-2">Edit job</h1>
                <p class="text-secondary mb-0">Update the job details.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_pageError))
        {
            <div class="alert alert-danger rounded-4 mb-0">@_pageError</div>
        }

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <EditForm Model="_model" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />

                    <!-- ── Core details ──────────────────────────────────── -->
                    <h2 class="h5 fw-bold mb-3">Job details</h2>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-lg-8">
                            <label class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                            <InputText @bind-Value="_model.Title" class="form-control rounded-4" />
                            <ValidationMessage For="@(() => _model.Title)" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Category</label>
                            <InputSelect @bind-Value="_model.Category" class="form-select rounded-4">
                                <option value="">Select category</option>
                                <option value="@JobCategory.Accounting">Accounting</option>
                                <option value="@JobCategory.AdminSecretarial">Admin &amp; Secretarial</option>
                                <option value="@JobCategory.AdvertisingPR">Advertising &amp; PR</option>
                                <option value="@JobCategory.Aerospace">Aerospace</option>
                                <option value="@JobCategory.AgricultureFishingForestry">Agriculture, Fishing &amp; Forestry</option>
                                <option value="@JobCategory.Arts">Arts</option>
                                <option value="@JobCategory.Automobile">Automobile</option>
                                <option value="@JobCategory.Banking">Banking</option>
                                <option value="@JobCategory.BuildingConstruction">Building &amp; Construction</option>
                                <option value="@JobCategory.Catering">Catering</option>
                                <option value="@JobCategory.Charity">Charity</option>
                                <option value="@JobCategory.CustomerService">Customer Service</option>
                                <option value="@JobCategory.Design">Design</option>
                                <option value="@JobCategory.Education">Education</option>
                                <option value="@JobCategory.Engineering">Engineering</option>
                                <option value="@JobCategory.ExecutiveManagement">Executive &amp; Management</option>
                                <option value="@JobCategory.FinanceInsurance">Finance &amp; Insurance</option>
                                <option value="@JobCategory.FoodBeverage">Food &amp; Beverage</option>
                                <option value="@JobCategory.Government">Government</option>
                                <option value="@JobCategory.GraduateRoles">Graduate Roles</option>
                                <option value="@JobCategory.Healthcare">Healthcare</option>
                                <option value="@JobCategory.Hospitality">Hospitality</option>
                                <option value="@JobCategory.HumanResources">Human Resources</option>
                                <option value="@JobCategory.ITSoftware">IT &amp; Software</option>
                                <option value="@JobCategory.LegalServices">Legal Services</option>
                                <option value="@JobCategory.Logistics">Logistics</option>
                                <option value="@JobCategory.Manufacturing">Manufacturing</option>
                                <option value="@JobCategory.Marketing">Marketing</option>
                                <option value="@JobCategory.MediaJournalism">Media &amp; Journalism</option>
                                <option value="@JobCategory.MiningResources">Mining &amp; Resources</option>
                                <option value="@JobCategory.PartTimeTemp">Part-time &amp; Temp</option>
                                <option value="@JobCategory.Pharmaceuticals">Pharmaceuticals</option>
                                <option value="@JobCategory.PropertyRealEstate">Property &amp; Real Estate</option>
                                <option value="@JobCategory.PublicRelations">Public Relations</option>
                                <option value="@JobCategory.Recruitment">Recruitment</option>
                                <option value="@JobCategory.Research">Research</option>
                                <option value="@JobCategory.Retail">Retail</option>
                                <option value="@JobCategory.Sales">Sales</option>
                                <option value="@JobCategory.Science">Science</option>
                                <option value="@JobCategory.SecurityIntelligence">Security &amp; Intelligence</option>
                                <option value="@JobCategory.SocialWork">Social Work</option>
                                <option value="@JobCategory.SportRecreation">Sport &amp; Recreation</option>
                                <option value="@JobCategory.TelecommunicationsISP">Telecommunications &amp; ISP</option>
                                <option value="@JobCategory.Tourism">Tourism</option>
                                <option value="@JobCategory.TransportDistribution">Transport &amp; Distribution</option>
                                <option value="@JobCategory.UtilitiesEnergy">Utilities &amp; Energy</option>
                                <option value="@JobCategory.Veterinary">Veterinary</option>
                                <option value="@JobCategory.Other">Other</option>
                            </InputSelect>
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Department</label>
                            <InputText @bind-Value="_model.Department" class="form-control rounded-4" placeholder="e.g. Engineering, Finance, Marketing" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Location</label>
                            <InputText @bind-Value="_model.LocationText" class="form-control rounded-4" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Workplace type <span class="text-danger">*</span></label>
                            <InputSelect @bind-Value="_model.WorkplaceType" class="form-select rounded-4">
                                <option value="">Select workplace type</option>
                                <option value="@WorkplaceType.OnSite">On-site</option>
                                <option value="@WorkplaceType.Hybrid">Hybrid</option>
                                <option value="@WorkplaceType.Remote">Remote</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => _model.WorkplaceType)" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Employment type <span class="text-danger">*</span></label>
                            <InputSelect @bind-Value="_model.EmploymentType" class="form-select rounded-4">
                                <option value="">Select employment type</option>
                                <option value="@EmploymentType.FullTime">Full-time</option>
                                <option value="@EmploymentType.PartTime">Part-time</option>
                                <option value="@EmploymentType.Contract">Contract</option>
                                <option value="@EmploymentType.Temporary">Temporary</option>
                                <option value="@EmploymentType.Casual">Casual</option>
                                <option value="@EmploymentType.Internship">Internship</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => _model.EmploymentType)" />
                        </div>
                    </div>

                    <!-- ── Regions & countries ────────────────────────────── -->
                    <h2 class="h5 fw-bold mb-3">Regions &amp; countries</h2>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Regions</label>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var region in Enum.GetValues<JobRegion>())
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="region-@region"
                                               checked="@_model.Regions.Contains(region)"
                                               @onchange="e => ToggleRegion(region, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label" for="region-@region">@FormatRegion(region)</label>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (AvailableCountries().Any())
                        {
                            <div class="col-12 col-lg-6">
                                <label class="form-label fw-semibold">Countries <span class="text-secondary small">(select specific countries)</span></label>
                                <div style="max-height:200px; overflow-y:auto; border:1px solid #dee2e6; border-radius:8px; padding:8px;">
                                    @foreach (var country in AvailableCountries())
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   id="country-@country.Replace(" ","-").Replace("'","")"
                                                   checked="@_model.Countries.Contains(country)"
                                                   @onchange="e => ToggleCountry(country, (bool)(e.Value ?? false))" />
                                            <label class="form-check-label small" for="country-@country.Replace(" ","-").Replace("'","")">@country</label>
                                        </div>
                                    }
                                </div>
                                <div class="form-text">Select all countries or leave blank to match all in the selected region(s).</div>
                            </div>
                        }
                    </div>

                    <!-- ── Content ───────────────────────────────────────── -->
                    <h2 class="h5 fw-bold mb-3">Content</h2>
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                            <RichTextEditor Value="@_model.Description" ValueChanged="v => _model.Description = v" />
                            <ValidationMessage For="@(() => _model.Description)" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Requirements</label>
                            <RichTextEditor Value="@(_model.Requirements ?? "")" ValueChanged="v => _model.Requirements = string.IsNullOrWhiteSpace(v) ? null : v" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Benefits (description)</label>
                            <RichTextEditor Value="@(_model.Benefits ?? "")" ValueChanged="v => _model.Benefits = string.IsNullOrWhiteSpace(v) ? null : v" />
                        </div>
                    </div>

                    <!-- ── Compensation ──────────────────────────────────── -->
                    <h2 class="h5 fw-bold mb-3">Compensation</h2>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-lg-3">
                            <label class="form-label fw-semibold">Salary from <span class="text-danger">*</span></label>
                            <InputNumber @bind-Value="_model.SalaryFrom" class="form-control rounded-4" />
                            <ValidationMessage For="@(() => _model.SalaryFrom)" />
                        </div>

                        <div class="col-12 col-lg-3">
                            <label class="form-label fw-semibold">Salary to <span class="text-danger">*</span></label>
                            <InputNumber @bind-Value="_model.SalaryTo" class="form-control rounded-4" />
                            <ValidationMessage For="@(() => _model.SalaryTo)" />
                        </div>

                        <div class="col-12 col-lg-3">
                            <label class="form-label fw-semibold">Currency</label>
                            <InputSelect @bind-Value="_model.SalaryCurrency" class="form-select rounded-4">
                                <option value="">Select currency</option>
                                <option value="@CurrencyCode.AUD">AUD</option>
                                <option value="@CurrencyCode.USD">USD</option>
                                <option value="@CurrencyCode.EUR">EUR</option>
                                <option value="@CurrencyCode.GBP">GBP</option>
                                <option value="@CurrencyCode.NZD">NZD</option>
                            </InputSelect>
                        </div>

                        <div class="col-12 col-lg-3">
                            <label class="form-label fw-semibold">Visibility</label>
                            <InputSelect @bind-Value="_model.Visibility" class="form-select rounded-4">
                                <option value="@JobVisibility.Public">Public</option>
                                <option value="@JobVisibility.Private">Private</option>
                            </InputSelect>
                        </div>
                    </div>

                    <!-- ── Benefits tags ─────────────────────────────────── -->
                    <h2 class="h5 fw-bold mb-3">Benefit tags</h2>
                    <div class="row g-2 mb-4">
                        @foreach (var benefit in _allBenefits)
                        {
                            <div class="col-6 col-md-4 col-lg-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           id="edit-benefit-@benefit.Replace(" ", "-").ToLower()"
                                           checked="@_model.BenefitsTags.Contains(benefit)"
                                           @onchange="e => ToggleBenefit(benefit, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label small" for="edit-benefit-@benefit.Replace(" ", "-").ToLower()">@benefit</label>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- ── Application options ───────────────────────────── -->
                    <h2 class="h5 fw-bold mb-3">Application options</h2>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">External application URL</label>
                            <InputText @bind-Value="_model.ExternalApplicationUrl" class="form-control rounded-4" placeholder="https://yoursite.com/apply" />
                            <div class="form-text">Leave blank to use the internal ATS.</div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Application email</label>
                            <InputText @bind-Value="_model.ApplicationEmail" class="form-control rounded-4" placeholder="jobs@yourcompany.com" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Special requirements for applicants</label>
                            <RichTextEditor Value="@(_model.ApplicationSpecialRequirements ?? "")" ValueChanged="v => _model.ApplicationSpecialRequirements = string.IsNullOrWhiteSpace(v) ? null : v" />
                        </div>
                    </div>

                    <!-- ── ATS / internal ────────────────────────────────── -->
                    <h2 class="h5 fw-bold mb-3">ATS &amp; internal</h2>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Keywords</label>
                            <InputText @bind-Value="_model.Keywords" class="form-control rounded-4" />
                            <div class="form-text">Used for candidate auto-matching and search.</div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">PO / Reference number</label>
                            <InputText @bind-Value="_model.PoNumber" class="form-control rounded-4" />
                        </div>

                        <div class="col-12 col-lg-3">
                            <label class="form-label fw-semibold">Listing expiry date <span class="text-danger">*</span></label>
                            <InputDate @bind-Value="_expiryDate" class="form-control rounded-4" />
                            <div class="form-text">Job will be hidden from public after this date.</div>
                        </div>
                    </div>

                    <!-- ── Promotion ─────────────────────────────────────── -->
                    <h2 class="h5 fw-bold mb-3">Promotion</h2>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-lg-4">
                            <div class="form-check form-switch">
                                <InputCheckbox @bind-Value="_model.IncludeCompanyLogo" class="form-check-input" id="editIncludeLogoCheck" />
                                <label class="form-check-label" for="editIncludeLogoCheck">Show company logo on listing</label>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="form-check form-switch">
                                <InputCheckbox @bind-Value="_model.IsHighlighted" class="form-check-input" id="editHighlightCheck" />
                                <label class="form-check-label" for="editHighlightCheck">Highlight in search results</label>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="form-check form-switch">
                                <InputCheckbox @bind-Value="_model.AllowAutoMatch" class="form-check-input" id="editAutoMatchCheck" />
                                <label class="form-check-label" for="editAutoMatchCheck">Auto-match to candidate profiles</label>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Sticky to top until</label>
                            <InputDate @bind-Value="_stickyUntilDate" class="form-control rounded-4" />
                            <div class="form-text">Leave blank for no sticky promotion.</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-2">
                        <button type="submit" class="btn btn-dark rounded-4 px-4" disabled="@_saving">
                            @(_saving ? "Saving..." : "Save changes")
                        </button>
                        <a class="btn btn-outline-secondary rounded-4 px-4" href="/app/jobs/@Id">Back</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = "";

    private readonly UpdateJobRequestDto _model = new();
    private bool _loaded;
    private bool _notFound;
    private bool _saving;
    private string? _pageError;
    private DateTime? _stickyUntilDate;
    private DateOnly? _expiryDate;

    private static readonly string[] _allBenefits =
    [
        "401(K)", "Distributed team", "Async", "Vision insurance", "Dental insurance",
        "Medical insurance", "Unlimited vacation", "Paid time off", "4-day workweek",
        "401(K) matching", "Company retreats", "Coworking budget", "Learning budget",
        "Free gym membership", "Mental wellness budget", "Home office budget",
        "Pay in crypto", "Pseudonymous", "Profit sharing", "Equity compensation",
        "No whiteboard interview", "No monitoring system", "No politics at work",
        "We hire old (and young)"
    ];

    private static readonly Dictionary<JobRegion, string[]> _regionCountries = new()
    {
        [JobRegion.Africa] = ["Algeria","Angola","Benin","Botswana","Burkina Faso","Burundi","Cameroon","Cape Verde","Central African Republic","Chad","Comoros","Congo","DR Congo","Djibouti","Egypt","Equatorial Guinea","Eritrea","Eswatini","Ethiopia","Gabon","Gambia","Ghana","Guinea","Guinea-Bissau","Ivory Coast","Kenya","Lesotho","Liberia","Libya","Madagascar","Malawi","Mali","Mauritania","Mauritius","Morocco","Mozambique","Namibia","Niger","Nigeria","Rwanda","São Tomé and Príncipe","Senegal","Seychelles","Sierra Leone","Somalia","South Africa","South Sudan","Sudan","Tanzania","Togo","Tunisia","Uganda","Zambia","Zimbabwe"],
        [JobRegion.Asia] = ["Afghanistan","Armenia","Azerbaijan","Bahrain","Bangladesh","Bhutan","Brunei","Cambodia","China","Cyprus","Georgia","India","Indonesia","Iran","Iraq","Israel","Japan","Jordan","Kazakhstan","Kuwait","Kyrgyzstan","Laos","Lebanon","Malaysia","Maldives","Mongolia","Myanmar","Nepal","North Korea","Oman","Pakistan","Palestine","Philippines","Qatar","Saudi Arabia","Singapore","South Korea","Sri Lanka","Syria","Taiwan","Tajikistan","Thailand","Timor-Leste","Turkey","Turkmenistan","United Arab Emirates","Uzbekistan","Vietnam","Yemen"],
        [JobRegion.Europe] = ["Albania","Andorra","Austria","Belarus","Belgium","Bosnia and Herzegovina","Bulgaria","Croatia","Cyprus","Czech Republic","Denmark","Estonia","Finland","France","Germany","Greece","Hungary","Iceland","Ireland","Italy","Kosovo","Latvia","Liechtenstein","Lithuania","Luxembourg","Malta","Moldova","Monaco","Montenegro","Netherlands","North Macedonia","Norway","Poland","Portugal","Romania","Russia","San Marino","Serbia","Slovakia","Slovenia","Spain","Sweden","Switzerland","Ukraine","United Kingdom","Vatican City"],
        [JobRegion.LatinAmerica] = ["Argentina","Belize","Bolivia","Brazil","Chile","Colombia","Costa Rica","Cuba","Dominican Republic","Ecuador","El Salvador","Guatemala","Guyana","Haiti","Honduras","Jamaica","Mexico","Nicaragua","Panama","Paraguay","Peru","Puerto Rico","Suriname","Trinidad and Tobago","Uruguay","Venezuela"],
        [JobRegion.MiddleEast] = ["Bahrain","Egypt","Iran","Iraq","Israel","Jordan","Kuwait","Lebanon","Oman","Palestine","Qatar","Saudi Arabia","Syria","Turkey","United Arab Emirates","Yemen"],
        [JobRegion.NorthAmerica] = ["Canada","Mexico","United States"],
        [JobRegion.Oceania] = ["Australia","Fiji","Kiribati","Marshall Islands","Micronesia","Nauru","New Zealand","Palau","Papua New Guinea","Samoa","Solomon Islands","Tonga","Tuvalu","Vanuatu"],
        [JobRegion.Worldwide] = []
    };

    private IEnumerable<string> AvailableCountries()
    {
        if (_model.Regions.Count == 0) return [];
        if (_model.Regions.Contains(JobRegion.Worldwide))
            return _regionCountries.Where(kv => kv.Key != JobRegion.Worldwide).SelectMany(kv => kv.Value).Distinct().OrderBy(c => c);
        return _model.Regions.SelectMany(r => _regionCountries.TryGetValue(r, out var c) ? c : []).Distinct().OrderBy(c => c);
    }

    private void ToggleRegion(JobRegion region, bool selected)
    {
        if (selected && !_model.Regions.Contains(region))
            _model.Regions.Add(region);
        else if (!selected)
            _model.Regions.Remove(region);

        // Remove countries no longer in available set
        var available = AvailableCountries().ToHashSet();
        _model.Countries.RemoveAll(c => !available.Contains(c));
    }

    private void ToggleCountry(string country, bool selected)
    {
        if (selected && !_model.Countries.Contains(country))
            _model.Countries.Add(country);
        else if (!selected)
            _model.Countries.Remove(country);
    }

    private static string FormatRegion(JobRegion r) => r switch
    {
        JobRegion.LatinAmerica => "Latin America",
        JobRegion.MiddleEast => "Middle East",
        JobRegion.NorthAmerica => "North America",
        _ => r.ToString()
    };

    private void ToggleBenefit(string benefit, bool selected)
    {
        if (selected && !_model.BenefitsTags.Contains(benefit))
            _model.BenefitsTags.Add(benefit);
        else if (!selected)
            _model.BenefitsTags.Remove(benefit);
    }

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;
        _notFound = false;
        _pageError = null;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.GetAsync($"/api/v1/jobs/{Id}");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                _notFound = true;
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _pageError = "Could not load job.";
                return;
            }

            var job = await response.Content.ReadFromJsonAsync<JobDetailDto>(AethonApiClient.JsonOptions);
            if (job is null)
            {
                _notFound = true;
                return;
            }

            _model.Title = job.Title;
            _model.Department = job.Department;
            _model.LocationText = job.LocationText;
            _model.WorkplaceType = job.WorkplaceType;
            _model.EmploymentType = job.EmploymentType;
            _model.Description = job.Description;
            _model.Requirements = job.Requirements;
            _model.Benefits = job.Benefits;
            _model.SalaryFrom = job.SalaryFrom;
            _model.SalaryTo = job.SalaryTo;
            _model.SalaryCurrency = job.SalaryCurrency;
            _model.Visibility = job.Visibility != 0 ? job.Visibility : JobVisibility.Public;
            _model.Category = job.Category;
            _model.Regions = job.Regions is { Count: > 0 } ? [.. job.Regions] : [];
            _model.Countries = job.Countries is { Count: > 0 } ? [.. job.Countries] : [];
            _model.IncludeCompanyLogo = job.IncludeCompanyLogo;
            _model.IsHighlighted = job.IsHighlighted;
            _model.StickyUntilUtc = job.StickyUntilUtc;
            _model.AllowAutoMatch = job.AllowAutoMatch;
            _model.BenefitsTags = [.. job.BenefitsTags];
            _model.ApplicationSpecialRequirements = job.ApplicationSpecialRequirements;
            _model.Keywords = job.Keywords;
            _model.PoNumber = job.PoNumber;

            _model.ExternalApplicationUrl = job.ExternalApplicationUrl;
            _model.ApplicationEmail = job.ApplicationEmail;
            _stickyUntilDate = job.StickyUntilUtc?.ToLocalTime();
            _expiryDate = job.PostingExpiresUtc.HasValue ? DateOnly.FromDateTime(job.PostingExpiresUtc.Value.ToLocalTime()) : null;
        }
        catch
        {
            _pageError = "Could not load job.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _pageError = null;

        _model.StickyUntilUtc = _stickyUntilDate.HasValue
            ? DateTime.SpecifyKind(_stickyUntilDate.Value, DateTimeKind.Utc)
            : null;

        _model.PostingExpiresUtc = _expiryDate.HasValue
            ? DateTime.SpecifyKind(_expiryDate.Value.ToDateTime(TimeOnly.MinValue), DateTimeKind.Utc)
            : null;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PutAsJsonAsync($"/api/v1/jobs/{Id}", _model);

            if (response.IsSuccessStatusCode)
            {
                NavigationManager.NavigateTo($"/app/jobs/{Id}", forceLoad: false);
                return;
            }

            _pageError = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(_pageError))
                _pageError = "Job could not be updated.";
        }
        catch
        {
            _pageError = "Job could not be updated.";
        }
        finally
        {
            _saving = false;
        }
    }
}
