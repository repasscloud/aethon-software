@page "/organisations"
@attribute [AllowAnonymous]
@layout PublicLayout
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Aethon.Shared.Enums
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject IJSRuntime JS

<PageTitle>Organisations | Aethon</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-1">Organisations</h1>
            <p class="text-secondary mb-0">
                @if (_totalCount > 0)
                {
                    var from = (_currentPage - 1) * _pageSize + 1;
                    var to   = Math.Min(_currentPage * _pageSize, _totalCount);
                    <span>Showing @from–@to of @_totalCount organisations.</span>
                }
                else if (!_loading)
                {
                    <span>Browse companies and agencies on Aethon.</span>
                }
            </p>
        </div>
    </div>

    <!-- Filters -->
    <div style="position:sticky;top:0;z-index:100;">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-3">
                <div class="row g-2 align-items-center">
                    <div class="col-12 col-md-6">
                        <input class="form-control rounded-pill"
                               placeholder="Search organisations…"
                               @bind="_search"
                               @bind:event="oninput"
                               @bind:after="FilterChangedAsync" />
                    </div>
                    <div class="col-auto">
                        <div class="form-check form-check-inline mb-0">
                            <input class="form-check-input" type="checkbox" id="verifiedOnlyCheck"
                                   checked="@_verifiedOnly"
                                   @onchange="e => { _verifiedOnly = (bool)(e.Value ?? false); _ = FilterChangedAsync(); }" />
                            <label class="form-check-label small" for="verifiedOnlyCheck">
                                <i class="bi bi-patch-check-fill text-primary me-1"></i>Verified only
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 text-secondary">Loading…</div>
        </div>
    }
    else if (_orgs.Count == 0)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 text-center">
                <p class="text-secondary mb-2">No organisations found.</p>
                @if (!string.IsNullOrWhiteSpace(_search) || _verifiedOnly)
                {
                    <button class="btn btn-outline-secondary btn-sm rounded-pill" @onclick="ClearFilters">Clear filters</button>
                }
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var org in _orgs)
            {
                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="/organisations/@org.Slug" class="text-decoration-none h-100">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-3 d-flex gap-3 align-items-start">
                                @if (!string.IsNullOrWhiteSpace(org.LogoUrl))
                                {
                                    <img src="@org.LogoUrl" alt="@org.Name"
                                         style="width:56px;height:56px;object-fit:contain;border-radius:10px;background:#f8f9fa;flex-shrink:0;border:1px solid #e9ecef;" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center bg-secondary bg-opacity-10 rounded-3 flex-shrink-0"
                                         style="width:56px;height:56px;">
                                        <i class="bi bi-building text-secondary fs-4"></i>
                                    </div>
                                }
                                <div class="flex-grow-1 min-w-0">
                                    <div class="d-flex align-items-center gap-1 flex-wrap mb-1">
                                        <span class="fw-semibold text-dark text-truncate">@org.Name</span>
                                        @if (org.IsVerified)
                                        {
                                            @if (org.VerificationTier == VerificationTier.EnhancedTrusted)
                                            {
                                                <span class="badge bg-warning text-dark rounded-pill" style="font-size:.65rem;" title="Enhanced Trusted Employer">
                                                    <i class="bi bi-patch-check-fill me-1"></i>Enhanced
                                                </span>
                                            }
                                            else if (org.VerificationTier == VerificationTier.GovtVerified)
                                            {
                                                <span class="badge bg-secondary rounded-pill" style="font-size:.65rem;" title="Government Verified">
                                                    <i class="bi bi-bank me-1"></i>Govt.
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-primary rounded-pill" style="font-size:.65rem;" title="Verified Employer">
                                                    <i class="bi bi-patch-check-fill me-1"></i>Verified
                                                </span>
                                            }
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(org.PublicLocationText))
                                    {
                                        <div class="text-secondary small text-truncate">
                                            <i class="bi bi-geo-alt-fill text-danger me-1"></i>@org.PublicLocationText
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(org.Summary))
                                    {
                                        <div class="text-secondary small mt-1" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                            @org.Summary
                                        </div>
                                    }
                                    @if (org.ActiveJobCount > 0)
                                    {
                                        <div class="mt-2">
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill" style="font-size:.7rem;">
                                                <i class="bi bi-briefcase-fill me-1"></i>@org.ActiveJobCount open @(org.ActiveJobCount == 1 ? "role" : "roles")
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (_totalPages > 1)
        {
            <div class="d-flex justify-content-center align-items-center gap-2 flex-wrap">
                <button class="btn btn-outline-secondary btn-sm rounded-pill"
                        disabled="@(_currentPage <= 1)"
                        @onclick="@(() => GoToPageAsync(_currentPage - 1))">
                    <i class="bi bi-chevron-left"></i> Prev
                </button>

                @for (var i = Math.Max(1, _currentPage - 2); i <= Math.Min(_totalPages, _currentPage + 2); i++)
                {
                    var p = i;
                    <button class="btn btn-sm rounded-pill @(p == _currentPage ? "btn-dark" : "btn-outline-secondary")"
                            @onclick="@(() => GoToPageAsync(p))">@p</button>
                }

                <button class="btn btn-outline-secondary btn-sm rounded-pill"
                        disabled="@(_currentPage >= _totalPages)"
                        @onclick="@(() => GoToPageAsync(_currentPage + 1))">
                    Next <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        }
    }
</div>

@code {
    private List<PublicOrganisationListItemDto> _orgs = [];
    private bool _loading = true;
    private string _search = "";
    private bool _verifiedOnly;
    private int _currentPage = 1;
    private int _totalCount;
    private int _totalPages = 1;
    private const int _pageSize = 24;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadAsync();
            StateHasChanged();
        }
    }

    private async Task FilterChangedAsync()
    {
        _currentPage = 1;
        await LoadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        _currentPage = page;
        await LoadAsync();
        await JS.InvokeVoidAsync("scrollTo", 0, 0);
    }

    private async Task ClearFilters()
    {
        _search = "";
        _verifiedOnly = false;
        _currentPage = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var qs = new List<string>
            {
                $"page={_currentPage}",
                $"pageSize={_pageSize}"
            };
            if (!string.IsNullOrWhiteSpace(_search))
                qs.Add($"search={Uri.EscapeDataString(_search.Trim())}");
            if (_verifiedOnly)
                qs.Add("verifiedOnly=true");

            var url = $"/api/v1/public/organisations?{string.Join("&", qs)}";
            var client = await Api.CreateAsync();
            var result = await client.GetFromJsonAsync<PublicOrganisationsPageDto>(url, AethonApiClient.JsonOptions);
            if (result is not null)
            {
                _orgs = result.Items;
                _totalCount = result.TotalCount;
                _totalPages = result.TotalPages;
                _currentPage = result.Page;
            }
        }
        catch
        {
            _orgs = [];
        }
        _loading = false;
    }
}
