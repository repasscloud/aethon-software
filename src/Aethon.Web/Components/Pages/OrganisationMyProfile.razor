@page "/app/organisation/my-profile"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using Aethon.Shared.Organisations
@using Aethon.Shared.Verification
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject NavigationManager Nav

<PageTitle>My profile | Organisation | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading…</div>
    </div>
}
else if (_data is null)
{
    <div class="alert alert-danger rounded-4">Could not load your profile. You may not be a member of an organisation.</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <!-- Header -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h1 class="h3 fw-bold mb-1">My profile</h1>
                <p class="text-secondary mb-0">@_data.OrgName</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_pageError))
        {
            <div class="alert alert-danger rounded-4">@_pageError</div>
        }
        @if (!string.IsNullOrEmpty(_successMsg))
        {
            <div class="alert alert-success rounded-4">@_successMsg</div>
        }

        <!-- Account info -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Account</h2>
                <dl class="row mb-0 small">
                    <dt class="col-5 col-md-3 text-secondary">Email</dt>
                    <dd class="col-7 col-md-9">@_data.Email</dd>
                    <dt class="col-5 col-md-3 text-secondary">Email confirmed</dt>
                    <dd class="col-7 col-md-9">@(_data.EmailConfirmed ? "Yes" : "No")</dd>
                    <dt class="col-5 col-md-3 text-secondary">Identity verified</dt>
                    <dd class="col-7 col-md-9">
                        @if (_data.IsIdentityVerified)
                        {
                            <span class="badge bg-success rounded-pill"><i class="bi bi-patch-check-fill me-1"></i>Verified</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary rounded-pill">Not verified</span>
                        }
                    </dd>
                </dl>

                <hr class="my-3" />

                <h3 class="h6 fw-semibold mb-3">Display name</h3>
                <div class="d-flex gap-2 align-items-end flex-wrap">
                    <div style="min-width:220px;">
                        <label class="form-label small fw-semibold mb-1">Display name</label>
                        <input type="text" class="form-control form-control-sm rounded-3"
                               @bind="_displayName" maxlength="150" placeholder="Your display name" />
                    </div>
                    <button class="btn btn-sm btn-primary rounded-pill" @onclick="SaveDisplayNameAsync" disabled="@_saving">
                        @(_saving ? "Saving…" : "Save name")
                    </button>
                </div>
            </div>
        </div>

        <!-- Identity verification -->
        @if (!_data.IsIdentityVerified)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-1">Identity verification</h2>
                    <p class="text-secondary small mb-3">
                        Submit a request to have your identity verified by the Aethon team.
                        You must confirm your email before you can request verification.
                    </p>

                    @if (_data.VerificationRequestStatus == "Pending")
                    {
                        <div class="alert alert-info rounded-4 mb-0">
                            <i class="bi bi-hourglass-split me-2"></i>
                            Your verification request is <strong>pending review</strong>. We'll notify you when it's processed.
                        </div>
                    }
                    else
                    {
                        @if (_data.VerificationRequestStatus == "Denied")
                        {
                            <div class="alert alert-warning rounded-4 mb-3">
                                <i class="bi bi-x-circle me-2"></i>
                                Your previous request was <strong>denied</strong>.
                                @if (!string.IsNullOrEmpty(_verificationRequest?.ReviewNotes))
                                {
                                    <span> Reason: @_verificationRequest.ReviewNotes</span>
                                }
                                You may submit a new request.
                            </div>
                        }

                        @if (_data.EmailConfirmed)
                        {
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <label class="form-label small fw-semibold mb-1">Full legal name</label>
                                    <input type="text" class="form-control form-control-sm rounded-3"
                                           @bind="_verifyFullName" maxlength="200" placeholder="As on your ID" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label small fw-semibold mb-1">Contact email</label>
                                    <input type="email" class="form-control form-control-sm rounded-3"
                                           @bind="_verifyEmail" maxlength="256" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label small fw-semibold mb-1">Phone number</label>
                                    <input type="tel" class="form-control form-control-sm rounded-3"
                                           @bind="_verifyPhone" maxlength="50" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-semibold mb-1">
                                        Additional notes <span class="text-secondary fw-normal">(optional)</span>
                                    </label>
                                    <textarea class="form-control form-control-sm rounded-3" rows="2"
                                              @bind="_verifyNotes" maxlength="1000"></textarea>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-sm btn-success rounded-pill" @onclick="SubmitVerificationRequestAsync" disabled="@_saving">
                                        <i class="bi bi-patch-check me-1"></i>@(_saving ? "Submitting…" : "Submit verification request")
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-secondary small mb-0">Please confirm your email address before submitting a verification request.</p>
                        }
                    }
                </div>
            </div>
        }

        <!-- Team profile -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-1">Team profile</h2>
                <p class="text-secondary small mb-3">
                    This information can optionally appear on the public team directory for your organisation.
                    @if (!_data.OrgIsPublicProfileEnabled)
                    {
                        <span class="text-warning"><i class="bi bi-exclamation-triangle me-1"></i>Your organisation's public profile is not enabled, so your team profile will not be visible publicly.</span>
                    }
                </p>

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label small fw-semibold mb-1">URL slug</label>
                        <input type="text" class="form-control form-control-sm rounded-3"
                               @bind="_profileSlug" maxlength="60"
                               placeholder="e.g. jane-smith" />
                        <div class="form-text">Lowercase letters, numbers and hyphens only. 3–60 characters.</div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small fw-semibold mb-1">Job title</label>
                        <input type="text" class="form-control form-control-sm rounded-3"
                               @bind="_profileJobTitle" maxlength="200" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold mb-1">Bio</label>
                        <textarea class="form-control form-control-sm rounded-3" rows="3"
                                  @bind="_profileBio" maxlength="2000"></textarea>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small fw-semibold mb-1">Public email</label>
                        <input type="email" class="form-control form-control-sm rounded-3"
                               @bind="_profilePublicEmail" maxlength="256" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small fw-semibold mb-1">Public phone</label>
                        <input type="tel" class="form-control form-control-sm rounded-3"
                               @bind="_profilePublicPhone" maxlength="50" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small fw-semibold mb-1">LinkedIn URL</label>
                        <input type="url" class="form-control form-control-sm rounded-3"
                               @bind="_profileLinkedIn" maxlength="500" />
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="profilePublic"
                                   @bind="_profileIsPublic" />
                            <label class="form-check-label small" for="profilePublic">
                                Show my profile on the public team directory
                            </label>
                        </div>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-sm btn-primary rounded-pill" @onclick="SaveProfileAsync" disabled="@_saving">
                            @(_saving ? "Saving…" : "Save profile")
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
}

@code {
    private bool _loaded;
    private bool _saving;
    private string? _pageError;
    private string? _successMsg;

    private MyMemberProfileDto? _data;
    private MyVerificationRequestDto? _verificationRequest;

    // Display name
    private string _displayName = "";

    // Team profile fields
    private string? _profileSlug;
    private string? _profileJobTitle;
    private string? _profileBio;
    private string? _profilePublicEmail;
    private string? _profilePublicPhone;
    private string? _profileLinkedIn;
    private bool _profileIsPublic;

    // Verification form fields
    private string _verifyFullName = "";
    private string _verifyEmail = "";
    private string _verifyPhone = "";
    private string? _verifyNotes;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _pageError = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.GetAsync("/api/v1/organisations/me/my-profile");
            if (resp.IsSuccessStatusCode)
            {
                _data = await resp.Content.ReadFromJsonAsync<MyMemberProfileDto>(AethonApiClient.JsonOptions);
                if (_data is not null)
                {
                    _displayName = _data.DisplayName;
                    var p = _data.Profile;
                    if (p is not null)
                    {
                        _profileSlug = p.Slug;
                        _profileJobTitle = p.JobTitle;
                        _profileBio = p.Bio;
                        _profilePublicEmail = p.PublicEmail;
                        _profilePublicPhone = p.PublicPhone;
                        _profileLinkedIn = p.LinkedInUrl;
                        _profileIsPublic = p.IsPublicProfileEnabled;
                    }

                    // Load latest verification request details for denial notes
                    if (_data.VerificationRequestStatus == "Denied")
                    {
                        var vResp = await client.GetAsync("/api/v1/identity/verification-request/mine");
                        if (vResp.IsSuccessStatusCode)
                            _verificationRequest = await vResp.Content.ReadFromJsonAsync<MyVerificationRequestDto>(AethonApiClient.JsonOptions);
                    }
                }
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Forbidden ||
                     resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _data = null;
            }
            else
            {
                _pageError = "Could not load your profile.";
            }
        }
        catch { _pageError = "Could not load your profile."; }
        finally { _loaded = true; }
    }

    private async Task SaveDisplayNameAsync()
    {
        _saving = true; _pageError = null; _successMsg = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.PutAsJsonAsync("/api/v1/organisations/me/display-name",
                new { displayName = _displayName });
            if (resp.IsSuccessStatusCode) { _successMsg = "Display name updated."; await LoadAsync(); }
            else _pageError = "Could not update display name.";
        }
        catch { _pageError = "Could not update display name."; }
        finally { _saving = false; }
    }

    private async Task SaveProfileAsync()
    {
        _saving = true; _pageError = null; _successMsg = null;
        try
        {
            var client = await Api.CreateAsync();
            var body = new UpsertMyMemberProfileRequestDto
            {
                Slug = string.IsNullOrWhiteSpace(_profileSlug) ? null : _profileSlug.Trim(),
                JobTitle = string.IsNullOrWhiteSpace(_profileJobTitle) ? null : _profileJobTitle.Trim(),
                Bio = string.IsNullOrWhiteSpace(_profileBio) ? null : _profileBio.Trim(),
                PublicEmail = string.IsNullOrWhiteSpace(_profilePublicEmail) ? null : _profilePublicEmail.Trim(),
                PublicPhone = string.IsNullOrWhiteSpace(_profilePublicPhone) ? null : _profilePublicPhone.Trim(),
                LinkedInUrl = string.IsNullOrWhiteSpace(_profileLinkedIn) ? null : _profileLinkedIn.Trim(),
                IsPublicProfileEnabled = _profileIsPublic
            };
            var resp = await client.PutAsJsonAsync("/api/v1/organisations/me/my-profile", body);
            if (resp.IsSuccessStatusCode) { _successMsg = "Team profile saved."; await LoadAsync(); }
            else
            {
                var msg = await TryReadErrorAsync(resp);
                _pageError = msg ?? "Could not save team profile.";
            }
        }
        catch { _pageError = "Could not save team profile."; }
        finally { _saving = false; }
    }

    private async Task SubmitVerificationRequestAsync()
    {
        _saving = true; _pageError = null; _successMsg = null;
        try
        {
            var client = await Api.CreateAsync();
            var body = new SubmitVerificationRequestDto
            {
                FullName = _verifyFullName,
                EmailAddress = _verifyEmail,
                PhoneNumber = _verifyPhone,
                AdditionalNotes = string.IsNullOrWhiteSpace(_verifyNotes) ? null : _verifyNotes
            };
            var resp = await client.PostAsJsonAsync("/api/v1/identity/verification-request", body);
            if (resp.IsSuccessStatusCode) { _successMsg = "Verification request submitted. We'll review it shortly."; await LoadAsync(); }
            else
            {
                var msg = await TryReadErrorAsync(resp);
                _pageError = msg ?? "Could not submit verification request.";
            }
        }
        catch { _pageError = "Could not submit verification request."; }
        finally { _saving = false; }
    }

    private static async Task<string?> TryReadErrorAsync(HttpResponseMessage resp)
    {
        try
        {
            if (resp.Content.Headers.ContentType?.MediaType?.Contains("json", StringComparison.OrdinalIgnoreCase) == true)
            {
                var problem = await resp.Content.ReadFromJsonAsync<ValidationProblemResponse>(AethonApiClient.JsonOptions);
                if (problem?.Errors is { Count: > 0 })
                    return string.Join(" ", problem.Errors.SelectMany(x => x.Value));
            }
            var raw = await resp.Content.ReadAsStringAsync();
            return string.IsNullOrWhiteSpace(raw) ? null : raw;
        }
        catch { return null; }
    }

    private sealed class ValidationProblemResponse
    {
        public Dictionary<string, string[]> Errors { get; set; } = [];
    }
}
