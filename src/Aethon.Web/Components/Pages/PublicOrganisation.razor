@page "/organisations/{Slug}"
@page "/companies/{Slug}"
@page "/recruiters/{Slug}"
@layout PublicLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.Net
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@using Aethon.Shared.Enums
@using Aethon.Shared.Jobs
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject NavigationManager NavigationManager

<PageTitle>@(_org?.Name ?? "Organisation") | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading organisation…</div>
    </div>
}
else if (_org is null)
{
    <div class="alert alert-danger rounded-4 mb-0">@(_error ?? "Organisation not found.")</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <!-- Header card with optional banner -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            @if (!string.IsNullOrWhiteSpace(_org.BannerImageUrl))
            {
                <div style="height:180px; background:url('@_org.BannerImageUrl') center/cover no-repeat; background-color:#e9ecef;"></div>
            }
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row gap-4 align-items-md-start">
                    @if (!string.IsNullOrWhiteSpace(_org.LogoUrl))
                    {
                        <div class="flex-shrink-0" style="@(string.IsNullOrWhiteSpace(_org.BannerImageUrl) ? "" : "margin-top:-48px;")">
                            <img src="@_org.LogoUrl" alt="@_org.Name"
                                 style="width:96px; height:96px; object-fit:contain; border:3px solid #fff; border-radius:16px; background:#fff; box-shadow:0 2px 8px rgba(0,0,0,.1);" />
                        </div>
                    }
                    <div class="flex-grow-1 min-w-0">
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                            <h1 class="h3 fw-bold mb-0">@_org.Name</h1>
                            @if (_org.IsVerified)
                            {
                                @if (_org.VerificationTier == VerificationTier.EnhancedTrusted)
                                {
                                    <a href="/info/enhanced-verification" class="badge bg-warning text-dark rounded-pill text-decoration-none" title="Enhanced Trusted Employer">
                                        <i class="bi bi-patch-check-fill me-1"></i>Enhanced Trusted
                                    </a>
                                }
                                else
                                {
                                    <a href="/info/standard-verification" class="badge bg-primary rounded-pill text-decoration-none" title="Verified Employer">
                                        <i class="bi bi-patch-check-fill me-1"></i>Verified
                                    </a>
                                }
                            }
                        </div>

                        <!-- Location prominent -->
                        @if (!string.IsNullOrWhiteSpace(_org.PublicLocationText))
                        {
                            <div class="text-secondary mb-2 fw-semibold">
                                <i class="bi bi-geo-alt-fill text-danger me-1"></i>@_org.PublicLocationText
                            </div>
                        }

                        <!-- Meta row: industry, size -->
                        <div class="d-flex flex-wrap gap-3 text-secondary small mb-3">
                            @if (_org.Industry.HasValue)
                            {
                                <span><i class="bi bi-tag-fill me-1"></i>@FormatCategory(_org.Industry.Value)</span>
                            }
                            @if (_org.CompanySize.HasValue)
                            {
                                <span><i class="bi bi-people-fill me-1"></i>@FormatCompanySize(_org.CompanySize.Value) employees</span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_org.Summary))
                        {
                            <div class="mb-3" style="white-space: pre-wrap;">@_org.Summary</div>
                        }

                        <!-- EOE / Accessible badges -->
                        @if (_org.IsEqualOpportunityEmployer || _org.IsAccessibleWorkplace)
                        {
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @if (_org.IsEqualOpportunityEmployer)
                                {
                                    <a href="/info/equal-opportunity-employer" class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 text-decoration-none" style="font-size:.8rem;">
                                        <i class="bi bi-people-fill me-1"></i>Equal Opportunity Employer
                                    </a>
                                }
                                @if (_org.IsAccessibleWorkplace)
                                {
                                    <a href="/info/accessible-workplace" class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 text-decoration-none" style="font-size:.8rem;">
                                        <i class="bi bi-universal-access me-1"></i>Accessible Workplace
                                    </a>
                                }
                            </div>
                        }

                        <!-- Contact & social links -->
                        <div class="d-flex flex-wrap gap-3">
                            @if (!string.IsNullOrWhiteSpace(_org.WebsiteUrl))
                            {
                                <a href="@_org.WebsiteUrl" target="_blank" class="text-decoration-none text-secondary small"><i class="bi bi-globe me-1"></i>Website</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(_org.PublicContactEmail))
                            {
                                <span class="text-secondary small"><i class="bi bi-envelope me-1"></i>@_org.PublicContactEmail</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_org.PublicContactPhone))
                            {
                                <span class="text-secondary small"><i class="bi bi-telephone me-1"></i>@_org.PublicContactPhone</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_org.LinkedInUrl))
                            {
                                <a href="@SocialUrl(_org.LinkedInUrl, "https://www.linkedin.com/company/")" target="_blank" class="text-decoration-none text-secondary small"><i class="bi bi-linkedin me-1 text-primary"></i>LinkedIn</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(_org.TwitterHandle))
                            {
                                <a href="https://x.com/@_org.TwitterHandle" target="_blank" class="text-decoration-none text-secondary small"><i class="bi bi-twitter-x me-1"></i>@@@_org.TwitterHandle</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(_org.FacebookUrl))
                            {
                                <a href="@SocialUrl(_org.FacebookUrl, "https://www.facebook.com/")" target="_blank" class="text-decoration-none text-secondary small"><i class="bi bi-facebook me-1 text-primary"></i>Facebook</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(_org.TikTokHandle))
                            {
                                <a href="https://www.tiktok.com/@@@_org.TikTokHandle" target="_blank" class="text-decoration-none text-secondary small"><i class="bi bi-tiktok me-1"></i>@@@_org.TikTokHandle</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(_org.InstagramHandle))
                            {
                                <a href="https://www.instagram.com/@_org.InstagramHandle" target="_blank" class="text-decoration-none text-secondary small"><i class="bi bi-instagram me-1 text-danger"></i>@@@_org.InstagramHandle</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(_org.YouTubeUrl))
                            {
                                <a href="@SocialUrl(_org.YouTubeUrl, "https://www.youtube.com/channel/")" target="_blank" class="text-decoration-none text-secondary small"><i class="bi bi-youtube me-1 text-danger"></i>YouTube</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Meet the team -->
        @if (_org.HasPublicTeam)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 fw-bold mb-0">Meet the team</h2>
                        <a href="/organisations/@_org.Slug/team" class="btn btn-sm btn-outline-secondary rounded-pill">
                            View all <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                    @if (_teamMembers is null)
                    {
                        <p class="text-secondary small mb-0">Loading team…</p>
                    }
                    else if (_teamMembers.Count == 0)
                    {
                        <p class="text-secondary small mb-0">No team members listed yet.</p>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var m in _teamMembers.Take(6))
                            {
                                <div class="col-6 col-md-4 col-lg-3">
                                    <a href="/organisations/@_org.Slug/team/@m.Slug" class="text-decoration-none">
                                        <div class="d-flex align-items-center gap-2 p-2 border rounded-3 h-100">
                                            @if (!string.IsNullOrEmpty(m.ProfilePictureUrl))
                                            {
                                                <img src="@m.ProfilePictureUrl" alt="@m.DisplayName"
                                                     style="width:40px;height:40px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center justify-content-center bg-secondary bg-opacity-10 rounded-circle flex-shrink-0"
                                                     style="width:40px;height:40px;">
                                                    <i class="bi bi-person text-secondary"></i>
                                                </div>
                                            }
                                            <div class="min-w-0">
                                                <div class="fw-semibold text-dark small text-truncate">
                                                    @m.DisplayName
                                                    @if (m.IsIdentityVerified)
                                                    {
                                                        <i class="bi bi-patch-check-fill text-success ms-1" title="ID Verified" style="font-size:.7rem;"></i>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrEmpty(m.JobTitle))
                                                {
                                                    <div class="text-secondary" style="font-size:.7rem;" title="@m.JobTitle">@m.JobTitle</div>
                                                }
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Open positions -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Open positions</h2>
                @if (_jobs is null)
                {
                    <p class="text-secondary mb-0">Loading jobs…</p>
                }
                else if (_jobs.Count == 0)
                {
                    <p class="text-secondary mb-0">No open positions at this time.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var job in _jobs)
                        {
                            <a href="@JobUrl(job)" class="text-decoration-none">
                                <div class="border rounded-4 p-3">
                                    <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                        <span class="fw-semibold text-dark">@job.Title</span>
                                        @if (job.IsImmediateStart)
                                        {
                                            <span class="badge bg-success rounded-pill" style="font-size:.7rem;">Immediate Start</span>
                                        }
                                        @if (job.IsHighlighted)
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill" style="font-size:.7rem;">Featured</span>
                                        }
                                    </div>
                                    <div class="text-secondary small">
                                        @if (!string.IsNullOrWhiteSpace(job.Department))
                                        {
                                            <span>@job.Department · </span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(job.LocationText))
                                        {
                                            <span>@job.LocationText · </span>
                                        }
                                        <span>@job.EmploymentType · @job.WorkplaceType</span>
                                    </div>
                                    @if (job.SalaryFrom.HasValue || job.SalaryTo.HasValue || job.HasCommission)
                                    {
                                        <div class="text-secondary small mt-1">
                                            @if (job.SalaryFrom.HasValue && job.SalaryTo.HasValue)
                                            {
                                                <span>@job.SalaryCurrency @job.SalaryFrom?.ToString("N0") – @job.SalaryTo?.ToString("N0")</span>
                                            }
                                            @if (job.HasCommission && job.OteFrom.HasValue && job.OteTo.HasValue)
                                            {
                                                <span class="ms-2 text-success">OTE: @job.SalaryCurrency @job.OteFrom?.ToString("N0") – @job.OteTo?.ToString("N0")</span>
                                            }
                                            else if (job.HasCommission)
                                            {
                                                <span class="ms-2 text-success">+ Commission</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    private bool _loaded;
    private string? _error;
    private PublicOrganisationProfileDto? _org;
    private List<PublicJobListItemDto>? _jobs;
    private List<PublicTeamMemberDto>? _teamMembers;

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;
        _org = null;
        _jobs = null;
        _teamMembers = null;

        try
        {
            var client = await Api.CreateAsync();
            var orgResponse = await client.GetAsync($"/api/v1/public/organisations/{Slug}");

            if (orgResponse.StatusCode == HttpStatusCode.NotFound)
            {
                _error = "Organisation not found.";
                return;
            }

            _org = await orgResponse.Content.ReadFromJsonAsync<PublicOrganisationProfileDto>(AethonApiClient.JsonOptions);

            var jobsResponse = await client.GetAsync($"/api/v1/public/jobs?organisationSlug={Uri.EscapeDataString(Slug)}");
            if (jobsResponse.IsSuccessStatusCode)
                _jobs = await jobsResponse.Content.ReadFromJsonAsync<List<PublicJobListItemDto>>(AethonApiClient.JsonOptions);
            else
                _jobs = [];

            if (_org?.HasPublicTeam == true)
            {
                var teamResponse = await client.GetAsync($"/api/v1/public/organisations/{Uri.EscapeDataString(Slug)}/team");
                if (teamResponse.IsSuccessStatusCode)
                    _teamMembers = await teamResponse.Content.ReadFromJsonAsync<List<PublicTeamMemberDto>>(AethonApiClient.JsonOptions);
                else
                    _teamMembers = [];
            }
        }
        catch
        {
            _error = "Could not load organisation.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private static string SocialUrl(string? handle, string baseUrl)
    {
        if (string.IsNullOrWhiteSpace(handle)) return "#";
        if (handle.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            handle.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return handle;
        return baseUrl + handle.TrimStart('/');
    }

    private static string JobUrl(PublicJobListItemDto job)
    {
        if (!string.IsNullOrEmpty(job.OrganisationSlug))
        {
            var clean = Regex.Replace(job.Title.ToLowerInvariant(), @"[^a-z0-9\s_]", "");
            var slug = Regex.Replace(clean.Trim(), @"\s+", "-");
            return $"/jobs/{job.OrganisationSlug}/{slug}-{job.Id}";
        }
        return $"/jobs/{job.Id}";
    }

    private static string FormatCompanySize(CompanySize size) => size switch
    {
        CompanySize.UpTo10 => "1–10",
        CompanySize.UpTo50 => "11–50",
        CompanySize.UpTo200 => "51–200",
        CompanySize.UpTo500 => "201–500",
        CompanySize.UpTo1000 => "501–1,000",
        CompanySize.UpTo5000 => "1,001–5,000",
        CompanySize.UpTo10000 => "5,001–10,000",
        CompanySize.MoreThan10000 => "More than 10,000",
        _ => size.ToString()
    };

    private static string FormatCategory(JobCategory c) => c switch
    {
        JobCategory.AdminSecretarial => "Admin & Secretarial",
        JobCategory.AdvertisingPR => "Advertising & PR",
        JobCategory.AgricultureFishingForestry => "Agriculture, Fishing & Forestry",
        JobCategory.BuildingConstruction => "Building & Construction",
        JobCategory.CustomerService => "Customer Service",
        JobCategory.ExecutiveManagement => "Executive & Management",
        JobCategory.FinanceInsurance => "Finance & Insurance",
        JobCategory.FoodBeverage => "Food & Beverage",
        JobCategory.GraduateRoles => "Graduate Roles",
        JobCategory.HumanResources => "Human Resources",
        JobCategory.ITSoftware => "IT & Software",
        JobCategory.LegalServices => "Legal Services",
        JobCategory.MediaJournalism => "Media & Journalism",
        JobCategory.MiningResources => "Mining & Resources",
        JobCategory.PartTimeTemp => "Part-time & Temp",
        JobCategory.PropertyRealEstate => "Property & Real Estate",
        JobCategory.PublicRelations => "Public Relations",
        JobCategory.SecurityIntelligence => "Security & Intelligence",
        JobCategory.SocialWork => "Social Work",
        JobCategory.SportRecreation => "Sport & Recreation",
        JobCategory.TelecommunicationsISP => "Telecommunications & ISP",
        JobCategory.TransportDistribution => "Transport & Distribution",
        JobCategory.UtilitiesEnergy => "Utilities & Energy",
        _ => c.ToString()
    };
}
