@page "/organisations/{Slug}"
@page "/companies/{Slug}"
@page "/recruiters/{Slug}"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.Net
@using System.Net.Http.Json
@using Aethon.Shared.Jobs
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api

<PageTitle>Organisation | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading organisation…</div>
    </div>
}
else if (_org is null)
{
    <div class="alert alert-danger rounded-4 mb-0">@(_error ?? "Organisation not found.")</div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                @if (!string.IsNullOrWhiteSpace(_org.LogoUrl))
                {
                    <img src="@_org.LogoUrl" alt="@_org.Name" style="max-height:64px; max-width:220px;" class="mb-3" />
                }

                <h1 class="h3 fw-bold mb-2">@_org.Name</h1>
                <div class="text-secondary mb-3">@_org.PublicLocationText</div>

                @if (!string.IsNullOrWhiteSpace(_org.Summary))
                {
                    <div class="mb-3" style="white-space: pre-wrap;">@_org.Summary</div>
                }

                <div class="d-flex flex-column gap-2">
                    @if (!string.IsNullOrWhiteSpace(_org.WebsiteUrl))
                    {
                        <div><a href="@_org.WebsiteUrl" target="_blank">@_org.WebsiteUrl</a></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_org.PublicContactEmail))
                    {
                        <div>@_org.PublicContactEmail</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_org.PublicContactPhone))
                    {
                        <div>@_org.PublicContactPhone</div>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Open positions</h2>
                @if (_jobs is null)
                {
                    <p class="text-secondary mb-0">Loading jobs…</p>
                }
                else if (_jobs.Count == 0)
                {
                    <p class="text-secondary mb-0">No open positions at this time.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var job in _jobs)
                        {
                            <a href="/jobs/@job.Id" class="text-decoration-none">
                                <div class="border rounded-4 p-3 hover-bg-light">
                                    <div class="fw-semibold text-dark">@job.Title</div>
                                    <div class="text-secondary small mt-1">
                                        @if (!string.IsNullOrWhiteSpace(job.Department))
                                        {
                                            <span>@job.Department · </span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(job.LocationText))
                                        {
                                            <span>@job.LocationText · </span>
                                        }
                                        <span>@job.EmploymentType · @job.WorkplaceType</span>
                                    </div>
                                    @if (job.SalaryFrom.HasValue && job.SalaryTo.HasValue)
                                    {
                                        <div class="text-secondary small mt-1">
                                            @job.SalaryCurrency @job.SalaryFrom?.ToString("0.##") – @job.SalaryTo?.ToString("0.##")
                                        </div>
                                    }
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    private bool _loaded;
    private string? _error;
    private PublicOrganisationProfileDto? _org;
    private List<PublicJobListItemDto>? _jobs;

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;
        _org = null;
        _jobs = null;

        try
        {
            var client = await Api.CreateAsync();
            var orgResponse = await client.GetAsync($"/api/v1/public/organisations/{Slug}");

            if (orgResponse.StatusCode == HttpStatusCode.NotFound)
            {
                _error = "Organisation not found.";
                return;
            }

            _org = await orgResponse.Content.ReadFromJsonAsync<PublicOrganisationProfileDto>(AethonApiClient.JsonOptions);

            var jobsResponse = await client.GetAsync($"/api/v1/public/jobs?organisationSlug={Uri.EscapeDataString(Slug)}");
            if (jobsResponse.IsSuccessStatusCode)
                _jobs = await jobsResponse.Content.ReadFromJsonAsync<List<PublicJobListItemDto>>(AethonApiClient.JsonOptions);
            else
                _jobs = [];
        }
        catch
        {
            _error = "Could not load organisation.";
        }
        finally
        {
            _loaded = true;
        }
    }
}
