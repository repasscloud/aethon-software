@page "/dev/password-reset"
@attribute [Authorize]
@rendermode InteractiveServer
@using Aethon.Data.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity

<PageTitle>Password reset helper | Aethon</PageTitle>

<div class="container py-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-2">Password reset helper</h1>
            <p class="text-secondary mb-4">
                Generates a valid ASP.NET Identity password hash and ready-to-run SQL for a user.
            </p>

            <EditForm Model="_model" OnValidSubmit="GenerateAsync">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        <label class="form-label fw-semibold">Email</label>
                        <InputText @bind-Value="_model.Email" class="form-control rounded-4" />
                        <ValidationMessage For="@(() => _model.Email)" />
                    </div>

                    <div class="col-12 col-lg-6">
                        <label class="form-label fw-semibold">New password</label>
                        <InputText @bind-Value="_model.Password" type="password" class="form-control rounded-4" />
                        <ValidationMessage For="@(() => _model.Password)" />
                    </div>

                    <div class="col-12">
                        <button type="submit" class="btn btn-dark rounded-4 px-4">
                            Generate hash + SQL
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_hash))
    {
        <div class="card border-0 shadow-sm rounded-4 mt-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Generated values</h2>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Password hash</label>
                    <textarea class="form-control rounded-4" rows="4" readonly>@_hash</textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Security stamp</label>
                    <input class="form-control rounded-4" value="@_securityStamp" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Concurrency stamp</label>
                    <input class="form-control rounded-4" value="@_concurrencyStamp" readonly />
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mt-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">SQL</h2>
                <textarea class="form-control rounded-4 font-monospace" rows="12" readonly>@_sql</textarea>
            </div>
        </div>
    }
</div>

@code {
    private readonly PasswordResetModel _model = new();

    private string _hash = "";
    private string _securityStamp = "";
    private string _concurrencyStamp = "";
    private string _sql = "";

    private Task GenerateAsync()
    {
        var hasher = new PasswordHasher<ApplicationUser>();
        var user = new ApplicationUser();

        _hash = hasher.HashPassword(user, _model.Password);
        _securityStamp = Guid.NewGuid().ToString();
        _concurrencyStamp = Guid.NewGuid().ToString();

        var escapedEmail = EscapeSql(_model.Email);
        var escapedHash = EscapeSql(_hash);
        var escapedSecurityStamp = EscapeSql(_securityStamp);
        var escapedConcurrencyStamp = EscapeSql(_concurrencyStamp);

        _sql = string.Join(Environment.NewLine,
            "UPDATE \"AspNetUsers\"",
            "SET",
            $"    \"PasswordHash\" = '{escapedHash}',",
            $"    \"SecurityStamp\" = '{escapedSecurityStamp}',",
            $"    \"ConcurrencyStamp\" = '{escapedConcurrencyStamp}',",
            "    \"AccessFailedCount\" = 0,",
            "    \"LockoutEnd\" = NULL",
            $"WHERE \"Email\" = '{escapedEmail}';");

        return Task.CompletedTask;
    }

    private static string EscapeSql(string value)
    {
        return value.Replace("'", "''");
    }

    private sealed class PasswordResetModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string Password { get; set; } = "";
    }
}