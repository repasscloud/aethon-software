@page "/app/organisations/my-claims"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using Aethon.Shared.Enums
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject IHttpClientFactory HttpClientFactory

<PageTitle>My claim requests | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading…</div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 fw-bold mb-1">My claim requests</h1>
                        <p class="text-secondary mb-0">Track the status of your organisation claim submissions.</p>
                    </div>
                    <a href="/app/organisations/claim" class="btn btn-dark rounded-4 px-4">New claim</a>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger rounded-4 mb-0">@_error</div>
        }

        @if (_claims.Count == 0)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 text-secondary">No claim requests yet.</div>
            </div>
        }
        else
        {
            @foreach (var claim in _claims)
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <div class="fw-semibold fs-5">@claim.OrganisationName</div>
                                @if (!string.IsNullOrWhiteSpace(claim.OrganisationSlug))
                                {
                                    <div class="small text-secondary">/@claim.OrganisationSlug</div>
                                }
                            </div>
                            <div>
                                @if (claim.Status == ClaimRequestStatus.Pending)
                                {
                                    <span class="badge bg-warning text-dark rounded-pill">Pending</span>
                                }
                                else if (claim.Status == ClaimRequestStatus.Approved)
                                {
                                    <span class="badge bg-success rounded-pill">Approved</span>
                                }
                                else if (claim.Status == ClaimRequestStatus.Rejected)
                                {
                                    <span class="badge bg-danger rounded-pill">Rejected</span>
                                }
                                else if (claim.Status == ClaimRequestStatus.Cancelled)
                                {
                                    <span class="badge bg-secondary rounded-pill">Cancelled</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary rounded-pill">@claim.Status</span>
                                }
                            </div>
                        </div>

                        <div class="row g-2 small text-secondary mb-3">
                            <div class="col-12 col-md-4">
                                Submitted: @claim.SubmittedUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </div>
                            <div class="col-12 col-md-4">
                                Method: @claim.VerificationMethod
                            </div>
                            @if (claim.VerifiedUtc.HasValue)
                            {
                                <div class="col-12 col-md-4">
                                    Verified: @claim.VerifiedUtc.Value.ToLocalTime().ToString("dd MMM yyyy")
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(claim.VerificationToken) && claim.Status == ClaimRequestStatus.Pending)
                        {
                            <div class="alert alert-info rounded-4 py-2 mb-3">
                                <div class="small fw-semibold mb-1">Verification token (send this to Aethon support to complete your claim):</div>
                                <code>@claim.VerificationToken</code>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(claim.RejectionReason))
                        {
                            <div class="alert alert-danger rounded-4 py-2 mb-3">
                                <div class="small fw-semibold">Rejection reason:</div>
                                <div>@claim.RejectionReason</div>
                            </div>
                        }

                        @if (claim.Status == ClaimRequestStatus.Pending)
                        {
                            <button class="btn btn-sm btn-outline-danger rounded-3"
                                    @onclick="() => CancelAsync(claim)"
                                    disabled="@_cancelling">
                                @(_cancelling ? "Cancelling…" : "Cancel claim")
                            </button>
                        }
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private bool _loaded;
    private bool _cancelling;
    private string? _error;
    private List<OrganisationClaimRequestDto> _claims = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("AethonApi");
            var response = await client.GetAsync("/api/v1/organisations/me/claim-requests");

            if (response.IsSuccessStatusCode)
            {
                _claims = await response.Content.ReadFromJsonAsync<List<OrganisationClaimRequestDto>>() ?? [];
            }
            else
            {
                _error = "Could not load claim requests.";
            }
        }
        catch
        {
            _error = "Could not load claim requests.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private async Task CancelAsync(OrganisationClaimRequestDto claim)
    {
        _cancelling = true;
        _error = null;

        try
        {
            var client = HttpClientFactory.CreateClient("AethonApi");
            var response = await client.DeleteAsync($"/api/v1/organisations/me/claim-requests/{claim.Id}");

            if (response.IsSuccessStatusCode)
            {
                await LoadAsync();
                return;
            }

            _error = "Could not cancel claim request.";
        }
        catch
        {
            _error = "Could not cancel claim request.";
        }
        finally
        {
            _cancelling = false;
        }
    }
}
