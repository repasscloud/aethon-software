@page "/company/jobs/pending-approvals"
@rendermode InteractiveServer
@attribute [Authorize]
@using Aethon.Shared.CompanyJobsApproval
@using Aethon.Shared.Jobs
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@inject AethonApiClient Api

<PageTitle>Pending Job Approvals | Aethon</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-1">Pending job approvals</h1>
            <p class="text-secondary mb-0">Review and act on recruiter-submitted jobs awaiting your approval.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger rounded-4 mb-0">@_error</div>
    }

    @if (_items is null)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">Loading…</div>
        </div>
    }
    else if (_items.Count == 0)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <p class="text-secondary mb-0">No jobs are currently awaiting approval.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Submitted</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _items)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Title</td>
                                    <td>@(item.SubmittedForApprovalUtc?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                                    <td>
                                        <button class="btn btn-success btn-sm rounded-3 me-2"
                                                @onclick="() => ApproveAsync(item.Id)"
                                                disabled="@_busy">
                                            Approve
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm rounded-3"
                                                @onclick="() => RejectAsync(item.Id)"
                                                disabled="@_busy">
                                            Reject
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<JobSummaryDto>? _items;
    private string? _error;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _error = null;
        try
        {
            var client = await Api.CreateAsync();
            _items = await client.GetFromJsonAsync<List<JobSummaryDto>>("/api/v1/company/jobs/approvals", AethonApiClient.JsonOptions) ?? [];
        }
        catch
        {
            _error = "Could not load pending approvals.";
            _items = [];
        }
    }

    private async Task ApproveAsync(Guid id)
    {
        _busy = true;
        _error = null;
        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsync($"/api/v1/company/jobs/approvals/{id}/approve", null);
            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not approve job. Please try again.";
                return;
            }
            await ReloadAsync();
        }
        catch
        {
            _error = "Could not approve job.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RejectAsync(Guid id)
    {
        _busy = true;
        _error = null;
        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsJsonAsync($"/api/v1/company/jobs/approvals/{id}/reject", new RejectJobApprovalDto
            {
                Reason = "Rejected by company"
            });
            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not reject job. Please try again.";
                return;
            }
            await ReloadAsync();
        }
        catch
        {
            _error = "Could not reject job.";
        }
        finally
        {
            _busy = false;
        }
    }
}
