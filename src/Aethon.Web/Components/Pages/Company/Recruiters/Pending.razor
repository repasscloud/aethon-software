@page "/company/recruiters/pending"
@using Aethon.Shared.RecruiterCompanies
@inject HttpClient Http

<PageTitle>Pending Recruiter Requests</PageTitle>

@if (items is null)
{
    <p>Loading...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Recruiter</th>
                <th>Message</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in items)
        {
            <tr>
                <td>@item.RecruiterOrganisationName</td>
                <td>@item.Message</td>
                <td>
                    <button class="btn btn-success" @onclick="() => Approve(item.Id)">Approve</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<RecruiterCompanyRelationshipDto>? items;

    protected override async Task OnInitializedAsync()
    {
        items = await Http.GetFromJsonAsync<List<RecruiterCompanyRelationshipDto>>("api/company/recruiters/pending");
    }

    private async Task Approve(Guid id)
    {
        await Http.PostAsync($"api/company/recruiters/{id}/approve", null);
        items = await Http.GetFromJsonAsync<List<RecruiterCompanyRelationshipDto>>("api/company/recruiters/pending");
    }
}
