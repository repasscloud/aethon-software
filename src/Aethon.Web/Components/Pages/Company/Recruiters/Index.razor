@page "/company/recruiters"
@rendermode InteractiveServer
@attribute [Authorize]
@using Aethon.Shared.CompanyRecruiters
@using Aethon.Shared.Enums
@using Aethon.Shared.RecruiterCompanies
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@inject AethonApiClient Api

<PageTitle>Recruiters | Aethon</PageTitle>

<div class="d-flex flex-column gap-4">

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-1">Recruiter relationships</h1>
            <p class="text-secondary mb-0">Manage recruiter agencies that work with your organisation.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_pageError))
    {
        <div class="alert alert-danger rounded-4 mb-0">@_pageError</div>
    }

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Invite a recruiter agency</h2>

            <EditForm Model="_inviteModel" OnValidSubmit="InviteAsync">
                <div class="row g-3 mb-3">
                    <div class="col-12 col-lg-8">
                        <label class="form-label fw-semibold">Recruiter organisation ID</label>
                        <input class="form-control rounded-4"
                               @bind="_recruiterOrgIdText"
                               placeholder="Paste the recruiter's organisation GUID" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Message (optional)</label>
                        <InputTextArea class="form-control rounded-4" @bind-Value="_inviteModel.Message" rows="2" />
                    </div>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-12 col-lg-6">
                        <h6 class="fw-semibold">Recruiter permissions</h6>
                        @foreach (var (label, getter, setter) in RecruiterPermissions())
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       checked="@getter()"
                                       @onchange="e => setter((bool)(e.Value ?? false))" />
                                <label class="form-check-label">@label</label>
                            </div>
                        }
                    </div>
                    <div class="col-12 col-lg-6">
                        <h6 class="fw-semibold">Agency-level grants</h6>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   checked="@_inviteModel.RecruiterCanCreateUnclaimedCompanyJobs"
                                   @onchange="e => _inviteModel.RecruiterCanCreateUnclaimedCompanyJobs = (bool)(e.Value ?? false)" />
                            <label class="form-check-label">Can create unclaimed company jobs</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   checked="@_inviteModel.RecruiterCanPublishJobs"
                                   @onchange="e => _inviteModel.RecruiterCanPublishJobs = (bool)(e.Value ?? false)" />
                            <label class="form-check-label">Can publish jobs</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   checked="@_inviteModel.RecruiterCanManageCandidates"
                                   @onchange="e => _inviteModel.RecruiterCanManageCandidates = (bool)(e.Value ?? false)" />
                            <label class="form-check-label">Can manage candidates</label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-dark rounded-4 px-4" disabled="@_inviting">
                    @(_inviting ? "Sending…" : "Send invite")
                </button>
            </EditForm>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Active relationships</h2>

            @if (_items is null)
            {
                <p class="text-secondary">Loading…</p>
            }
            else if (_items.Count == 0)
            {
                <p class="text-secondary mb-0">No recruiter relationships yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Recruiter</th>
                                <th>Status</th>
                                <th>Scope</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _items)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.RecruiterOrganisationName</td>
                                    <td>
                                        @if (item.Status == OrganisationRecruitmentPartnershipStatus.Active)
                                        {
                                            <span class="badge bg-success rounded-pill">Active</span>
                                        }
                                        else if (item.Status == OrganisationRecruitmentPartnershipStatus.Pending)
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill">@item.Status</span>
                                        }
                                    </td>
                                    <td>@item.Scope</td>
                                    <td>
                                        @if (item.Status == OrganisationRecruitmentPartnershipStatus.Active ||
                                             item.Status == OrganisationRecruitmentPartnershipStatus.Pending)
                                        {
                                            <button class="btn btn-outline-warning btn-sm rounded-3"
                                                    @onclick="() => SuspendAsync(item.Id)"
                                                    disabled="@_busy">
                                                Suspend
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<RecruiterCompanyRelationshipDto>? _items;
    private readonly CreateCompanyRecruiterInviteDto _inviteModel = new();
    private string _recruiterOrgIdText = string.Empty;
    private string? _pageError;
    private bool _inviting;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _pageError = null;
        try
        {
            var client = await Api.CreateAsync();
            _items = await client.GetFromJsonAsync<List<RecruiterCompanyRelationshipDto>>("/api/v1/company/recruiters", AethonApiClient.JsonOptions) ?? [];
        }
        catch
        {
            _pageError = "Could not load recruiter relationships.";
            _items = [];
        }
    }

    private async Task InviteAsync()
    {
        if (!Guid.TryParse(_recruiterOrgIdText, out var orgId))
        {
            _pageError = "Please enter a valid recruiter organisation ID (GUID).";
            return;
        }

        _inviting = true;
        _pageError = null;

        try
        {
            _inviteModel.RecruiterOrganisationId = orgId;
            var client = await Api.CreateAsync();
            var response = await client.PostAsJsonAsync("/api/v1/company/recruiters/invites", _inviteModel);

            if (!response.IsSuccessStatusCode)
            {
                _pageError = await ReadErrorAsync(response) ?? "Could not send invite.";
                return;
            }

            _recruiterOrgIdText = string.Empty;
            ResetInviteForm();
            await LoadAsync();
        }
        catch
        {
            _pageError = "Could not send invite.";
        }
        finally
        {
            _inviting = false;
        }
    }

    private async Task SuspendAsync(Guid relationshipId)
    {
        _busy = true;
        _pageError = null;
        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsync($"/api/v1/company/recruiters/{relationshipId}/suspend", null);
            if (!response.IsSuccessStatusCode)
            {
                _pageError = "Could not suspend relationship.";
                return;
            }
            await LoadAsync();
        }
        catch
        {
            _pageError = "Could not suspend relationship.";
        }
        finally
        {
            _busy = false;
        }
    }

    private void ResetInviteForm()
    {
        _inviteModel.RecruiterOrganisationId = Guid.Empty;
        _inviteModel.AllowCreateDraftJobs = false;
        _inviteModel.AllowSubmitJobsForApproval = false;
        _inviteModel.AllowManageApprovedJobs = false;
        _inviteModel.AllowViewCandidates = false;
        _inviteModel.AllowSubmitCandidates = false;
        _inviteModel.AllowCommunicateWithCandidates = false;
        _inviteModel.AllowScheduleInterviews = false;
        _inviteModel.AllowPublishJobs = false;
        _inviteModel.RecruiterCanCreateUnclaimedCompanyJobs = false;
        _inviteModel.RecruiterCanPublishJobs = false;
        _inviteModel.RecruiterCanManageCandidates = false;
        _inviteModel.Message = null;
    }

    private IEnumerable<(string Label, Func<bool> Getter, Action<bool> Setter)> RecruiterPermissions()
    {
        yield return ("Allow create draft jobs",
            () => _inviteModel.AllowCreateDraftJobs,
            v => _inviteModel.AllowCreateDraftJobs = v);
        yield return ("Allow submit jobs for approval",
            () => _inviteModel.AllowSubmitJobsForApproval,
            v => _inviteModel.AllowSubmitJobsForApproval = v);
        yield return ("Allow manage approved jobs",
            () => _inviteModel.AllowManageApprovedJobs,
            v => _inviteModel.AllowManageApprovedJobs = v);
        yield return ("Allow view candidates",
            () => _inviteModel.AllowViewCandidates,
            v => _inviteModel.AllowViewCandidates = v);
        yield return ("Allow submit candidates",
            () => _inviteModel.AllowSubmitCandidates,
            v => _inviteModel.AllowSubmitCandidates = v);
        yield return ("Allow communicate with candidates",
            () => _inviteModel.AllowCommunicateWithCandidates,
            v => _inviteModel.AllowCommunicateWithCandidates = v);
        yield return ("Allow schedule interviews",
            () => _inviteModel.AllowScheduleInterviews,
            v => _inviteModel.AllowScheduleInterviews = v);
        yield return ("Allow publish jobs",
            () => _inviteModel.AllowPublishJobs,
            v => _inviteModel.AllowPublishJobs = v);
    }

    private static async Task<string?> ReadErrorAsync(HttpResponseMessage response)
    {
        try
        {
            var problem = await response.Content.ReadFromJsonAsync<ProblemResponse>(AethonApiClient.JsonOptions);
            if (!string.IsNullOrWhiteSpace(problem?.Detail)) return problem.Detail;
        }
        catch { }

        var raw = await response.Content.ReadAsStringAsync();
        return string.IsNullOrWhiteSpace(raw) ? null : raw;
    }

    private sealed class ProblemResponse
    {
        public string? Detail { get; set; }
    }
}
