@page "/app/organisations/claim"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Claim an organisation | Aethon</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-1">Claim an organisation</h1>
            <p class="text-secondary mb-0">
                Search for an unclaimed organisation and submit a claim request.
                You will need to verify ownership via your email domain.
            </p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Search</h2>

            <div class="row g-2 mb-4">
                <div class="col-12 col-lg-9">
                    <input class="form-control rounded-4"
                           @bind="_searchTerm"
                           @bind:event="oninput"
                           @onkeydown="HandleSearchKeyDown"
                           placeholder="Search by name or slug…" />
                </div>
                <div class="col-12 col-lg-3">
                    <button class="btn btn-dark rounded-4 w-100"
                            @onclick="SearchAsync"
                            disabled="@_searching">
                        @(_searching ? "Searching…" : "Search")
                    </button>
                </div>
            </div>

            @if (_results is not null)
            {
                @if (_results.Count == 0)
                {
                    <p class="text-secondary mb-0">No claimable organisations found.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var org in _results)
                        {
                            <div class="border rounded-4 p-3 @(_selectedOrg?.Id == org.Id ? "border-dark" : "")">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-semibold">@org.Name</div>
                                        @if (!string.IsNullOrWhiteSpace(org.Slug))
                                        {
                                            <div class="small text-secondary">/@org.Slug</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(org.Domain))
                                        {
                                            <div class="small text-secondary">@org.Domain</div>
                                        }
                                    </div>
                                    <div class="d-flex gap-2 align-items-center">
                                        @if (org.HasActiveClaim)
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill small">Claim pending</span>
                                        }
                                        <button class="btn btn-sm btn-outline-dark rounded-3"
                                                @onclick="() => SelectOrg(org)"
                                                disabled="@org.HasActiveClaim">
                                            Claim
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @if (_selectedOrg is not null)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-1">Submit claim for @_selectedOrg.Name</h2>
                <p class="text-secondary small mb-3">
                    A claim request will be submitted using your registered email address.
                    You will need to verify your email domain matches the organisation's domain.
                </p>

                @if (!string.IsNullOrWhiteSpace(_claimError))
                {
                    <div class="alert alert-danger rounded-4 mb-3">@_claimError</div>
                }
                @if (!string.IsNullOrWhiteSpace(_claimSuccess))
                {
                    <div class="alert alert-success rounded-4 mb-3">@_claimSuccess</div>
                }

                <EditForm Model="_claimModel" OnValidSubmit="SubmitClaimAsync">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Notes (optional)</label>
                        <InputTextArea @bind-Value="_claimModel.Notes"
                                       class="form-control rounded-4"
                                       rows="3"
                                       placeholder="Add any context to support your claim…" />
                        <ValidationMessage For="@(() => _claimModel.Notes)" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dark rounded-4 px-4" disabled="@_submitting">
                            @(_submitting ? "Submitting…" : "Submit claim")
                        </button>
                        <button type="button" class="btn btn-outline-secondary rounded-4" @onclick="() => _selectedOrg = null">
                            Cancel
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="h5 fw-bold mb-0">My claim requests</h2>
                <a href="/app/organisations/my-claims" class="small text-dark">View all →</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string _searchTerm = "";
    private bool _searching;
    private bool _submitting;
    private string? _claimError;
    private string? _claimSuccess;

    private List<ClaimableOrganisationDto>? _results;
    private ClaimableOrganisationDto? _selectedOrg;
    private SubmitClaimRequestDto _claimModel = new();

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task SearchAsync()
    {
        _searching = true;
        _results = null;

        try
        {
            var client = HttpClientFactory.CreateClient("AethonApi");
            var url = string.IsNullOrWhiteSpace(_searchTerm)
                ? "/api/v1/organisations/claimable"
                : $"/api/v1/organisations/claimable?search={Uri.EscapeDataString(_searchTerm)}";

            _results = await client.GetFromJsonAsync<List<ClaimableOrganisationDto>>(url) ?? [];
        }
        catch
        {
            _results = [];
        }
        finally
        {
            _searching = false;
        }
    }

    private void SelectOrg(ClaimableOrganisationDto org)
    {
        _selectedOrg = org;
        _claimModel = new SubmitClaimRequestDto { OrganisationSlug = org.Slug };
        _claimError = null;
        _claimSuccess = null;
    }

    private async Task SubmitClaimAsync()
    {
        _submitting = true;
        _claimError = null;
        _claimSuccess = null;

        try
        {
            var client = HttpClientFactory.CreateClient("AethonApi");
            var response = await client.PostAsJsonAsync("/api/v1/organisations/claim", _claimModel);

            if (response.IsSuccessStatusCode)
            {
                _claimSuccess = "Claim submitted successfully. Check 'My claim requests' for the verification token.";
                _selectedOrg = null;
                if (_results is not null)
                {
                    await SearchAsync();
                }
                return;
            }

            try
            {
                var problem = await response.Content.ReadFromJsonAsync<ProblemResponse>();
                _claimError = problem?.Detail ?? "Could not submit claim.";
            }
            catch
            {
                _claimError = "Could not submit claim.";
            }
        }
        catch
        {
            _claimError = "Could not submit claim.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class ProblemResponse
    {
        public string? Detail { get; set; }
    }
}
