    private IEnumerable<string> AvailableCountries()
    {
        if (_model.Regions.Count == 0) return [];
        if (_model.Regions.Contains(JobRegion.Worldwide))
            return _regionCountries.Where(kv => kv.Key != JobRegion.Worldwide).SelectMany(kv => kv.Value).Distinct().OrderBy(c => c);
        return _model.Regions.SelectMany(r => _regionCountries.TryGetValue(r, out var c) ? c : []).Distinct().OrderBy(c => c);
    }

    private void ToggleRegion(JobRegion region, bool selected)
    {
        if (selected && !_model.Regions.Contains(region))
            _model.Regions.Add(region);
        else if (!selected)
            _model.Regions.Remove(region);

        // Remove countries no longer in available set
        var available = AvailableCountries().ToHashSet();
        _model.Countries.RemoveAll(c => !available.Contains(c));
    }

