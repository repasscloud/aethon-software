@page "/app/jobs/new"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using Aethon.Shared.Enums
@using Aethon.Shared.Jobs
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject NavigationManager NavigationManager

<PageTitle>Create job | Aethon</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-2">Create job</h1>
            <p class="text-secondary mb-0">Create a new job posting for your organisation.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_pageError))
    {
        <div class="alert alert-danger rounded-4 mb-0">@_pageError</div>
    }

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <EditForm Model="_model" OnValidSubmit="CreateJobAsync">
                <DataAnnotationsValidator />

                <!-- ── Core details ─────────────────────────────────────── -->
                <h2 class="h5 fw-bold mb-3">Job details</h2>
                <div class="row g-3 mb-4">
                    <div class="col-12 col-lg-8">
                        <label class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                        <InputText @bind-Value="_model.Title" class="form-control rounded-4" placeholder="e.g. Senior Software Engineer" />
                        <ValidationMessage For="@(() => _model.Title)" />
                    </div>

                    <div class="col-12 col-lg-4">
                        <label class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="_model.Category" class="form-select rounded-4">
                            <option value="">Select category</option>
                            <option value="@JobCategory.Accounting">Accounting</option>
                            <option value="@JobCategory.AdminSecretarial">Admin &amp; Secretarial</option>
                            <option value="@JobCategory.AdvertisingPR">Advertising &amp; PR</option>
                            <option value="@JobCategory.Aerospace">Aerospace</option>
                            <option value="@JobCategory.AgricultureFishingForestry">Agriculture, Fishing &amp; Forestry</option>
                            <option value="@JobCategory.Arts">Arts</option>
                            <option value="@JobCategory.Automobile">Automobile</option>
                            <option value="@JobCategory.Banking">Banking</option>
                            <option value="@JobCategory.BuildingConstruction">Building &amp; Construction</option>
                            <option value="@JobCategory.Catering">Catering</option>
                            <option value="@JobCategory.Charity">Charity</option>
                            <option value="@JobCategory.CustomerService">Customer Service</option>
                            <option value="@JobCategory.Design">Design</option>
                            <option value="@JobCategory.Education">Education</option>
                            <option value="@JobCategory.Engineering">Engineering</option>
                            <option value="@JobCategory.ExecutiveManagement">Executive &amp; Management</option>
                            <option value="@JobCategory.FinanceInsurance">Finance &amp; Insurance</option>
                            <option value="@JobCategory.FoodBeverage">Food &amp; Beverage</option>
                            <option value="@JobCategory.Government">Government</option>
                            <option value="@JobCategory.GraduateRoles">Graduate Roles</option>
                            <option value="@JobCategory.Healthcare">Healthcare</option>
                            <option value="@JobCategory.Hospitality">Hospitality</option>
                            <option value="@JobCategory.HumanResources">Human Resources</option>
                            <option value="@JobCategory.ITSoftware">IT &amp; Software</option>
                            <option value="@JobCategory.LegalServices">Legal Services</option>
                            <option value="@JobCategory.Logistics">Logistics</option>
                            <option value="@JobCategory.Manufacturing">Manufacturing</option>
                            <option value="@JobCategory.Marketing">Marketing</option>
                            <option value="@JobCategory.MediaJournalism">Media &amp; Journalism</option>
                            <option value="@JobCategory.MiningResources">Mining &amp; Resources</option>
                            <option value="@JobCategory.PartTimeTemp">Part-time &amp; Temp</option>
                            <option value="@JobCategory.Pharmaceuticals">Pharmaceuticals</option>
                            <option value="@JobCategory.PropertyRealEstate">Property &amp; Real Estate</option>
                            <option value="@JobCategory.PublicRelations">Public Relations</option>
                            <option value="@JobCategory.Recruitment">Recruitment</option>
                            <option value="@JobCategory.Research">Research</option>
                            <option value="@JobCategory.Retail">Retail</option>
                            <option value="@JobCategory.Sales">Sales</option>
                            <option value="@JobCategory.Science">Science</option>
                            <option value="@JobCategory.SecurityIntelligence">Security &amp; Intelligence</option>
                            <option value="@JobCategory.SocialWork">Social Work</option>
                            <option value="@JobCategory.SportRecreation">Sport &amp; Recreation</option>
                            <option value="@JobCategory.TelecommunicationsISP">Telecommunications &amp; ISP</option>
                            <option value="@JobCategory.Tourism">Tourism</option>
                            <option value="@JobCategory.TransportDistribution">Transport &amp; Distribution</option>
                            <option value="@JobCategory.UtilitiesEnergy">Utilities &amp; Energy</option>
                            <option value="@JobCategory.Veterinary">Veterinary</option>
                            <option value="@JobCategory.Other">Other</option>
                        </InputSelect>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Summary <span class="text-danger">*</span></label>
                        <InputTextArea @bind-Value="_model.Summary" class="form-control rounded-4" rows="3"
                                       placeholder="A brief overview of the role that will appear in search results (50–300 characters)" maxlength="300" />
                        <div class="d-flex justify-content-between">
                            <ValidationMessage For="@(() => _model.Summary)" />
                            <div class="form-text text-end">@(_model.Summary?.Length ?? 0)/300</div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-4">
                        <label class="form-label fw-semibold">Department</label>
                        <InputText @bind-Value="_model.Department" class="form-control rounded-4" placeholder="e.g. Engineering, Finance, Marketing" />
                    </div>

                    <div class="col-12 col-lg-4">
                        <label class="form-label fw-semibold">Location <span class="text-danger">*</span></label>
                        <InputText @bind-Value="_model.LocationText" class="form-control rounded-4" placeholder="e.g. Sydney NSW" />
                        <ValidationMessage For="@(() => _model.LocationText)" />
                    </div>

                    <div class="col-12 col-lg-4">
                        <label class="form-label fw-semibold">Workplace type <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="_model.WorkplaceType" class="form-select rounded-4">
                            <option value="">Select workplace type</option>
                            <option value="@WorkplaceType.OnSite">On-site</option>
                            <option value="@WorkplaceType.Hybrid">Hybrid</option>
                            <option value="@WorkplaceType.Remote">Remote</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => _model.WorkplaceType)" />
                    </div>

                    <div class="col-12 col-lg-4">
                        <label class="form-label fw-semibold">Employment type <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="_model.EmploymentType" class="form-select rounded-4">
                            <option value="">Select employment type</option>
                            <option value="@EmploymentType.FullTime">Full-time</option>
                            <option value="@EmploymentType.PartTime">Part-time</option>
                            <option value="@EmploymentType.Contract">Contract</option>
                            <option value="@EmploymentType.Temporary">Temporary</option>
                            <option value="@EmploymentType.Casual">Casual</option>
                            <option value="@EmploymentType.Internship">Internship</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => _model.EmploymentType)" />
                    </div>

                    <div class="col-12">
                        <div class="form-check form-switch">
                            <InputCheckbox @bind-Value="_model.IsImmediateStart" class="form-check-input" id="immediateStartCheck" />
                            <label class="form-check-label" for="immediateStartCheck">
                                <span class="fw-semibold">Immediate Start</span>
                                <span class="text-secondary ms-1 small">— this role is available to start right away (shown as a green badge on listings)</span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- ── Regions & countries ──────────────────────────────── -->
                <h2 class="h5 fw-bold mb-3">Regions &amp; countries</h2>
                <div class="row g-3 mb-4">
                    <div class="col-12 col-lg-6">
                        <label class="form-label fw-semibold">Regions</label>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var region in Enum.GetValues<JobRegion>())
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           id="region-@region"
                                           checked="@_model.Regions.Contains(region)"
                                           @onchange="e => ToggleRegion(region, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label" for="region-@region">@FormatRegion(region)</label>
                                </div>
                            }
                        </div>
                    </div>

                    @if (AvailableCountries().Any())
                    {
                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Countries <span class="text-secondary small">(select specific countries)</span></label>
                            <div style="max-height:200px; overflow-y:auto; border:1px solid #dee2e6; border-radius:8px; padding:8px;">
                                @foreach (var country in AvailableCountries())
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="country-@country.Replace(" ","-").Replace("'","")"
                                               checked="@_model.Countries.Contains(country)"
                                               @onchange="e => ToggleCountry(country, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label small" for="country-@country.Replace(" ","-").Replace("'","")">@country</label>
                                    </div>
                                }
                            </div>
                            <div class="form-text">Select all countries or leave blank to match all in the selected region(s).</div>
                        </div>
                    }
                </div>

                <!-- ── Description ──────────────────────────────────────── -->
                <h2 class="h5 fw-bold mb-3">Content</h2>
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                        <RichTextEditor Value="@_model.Description" ValueChanged="v => _model.Description = v" />
                        <ValidationMessage For="@(() => _model.Description)" />
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Requirements</label>
                        <RichTextEditor Value="@(_model.Requirements ?? "")" ValueChanged="v => _model.Requirements = string.IsNullOrWhiteSpace(v) ? null : v" />
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Benefits (description)</label>
                        <RichTextEditor Value="@(_model.Benefits ?? "")" ValueChanged="v => _model.Benefits = string.IsNullOrWhiteSpace(v) ? null : v" />
                    </div>
                </div>

                <!-- ── Salary ────────────────────────────────────────────── -->
                <h2 class="h5 fw-bold mb-3">Compensation</h2>
                <div class="row g-3 mb-4">
                    <div class="col-12 col-lg-3">
                        <label class="form-label fw-semibold">Salary from</label>
                        <InputNumber @bind-Value="_model.SalaryFrom" class="form-control rounded-4" placeholder="e.g. 80000" />
                    </div>

                    <div class="col-12 col-lg-3">
                        <label class="form-label fw-semibold">Salary to</label>
                        <InputNumber @bind-Value="_model.SalaryTo" class="form-control rounded-4" placeholder="e.g. 100000" />
                    </div>

                    <div class="col-12 col-lg-3">
                        <label class="form-label fw-semibold">Currency</label>
                        <InputSelect @bind-Value="_model.SalaryCurrency" class="form-select rounded-4">
                            <option value="">Select currency</option>
                            <option value="@CurrencyCode.AUD">AUD</option>
                            <option value="@CurrencyCode.USD">USD</option>
                            <option value="@CurrencyCode.EUR">EUR</option>
                            <option value="@CurrencyCode.GBP">GBP</option>
                            <option value="@CurrencyCode.NZD">NZD</option>
                        </InputSelect>
                    </div>

                    <div class="col-12 col-lg-3">
                        <label class="form-label fw-semibold">Status</label>
                        <InputSelect @bind-Value="_model.Status" class="form-select rounded-4">
                            <option value="@JobStatus.Draft">Draft</option>
                            <option value="@JobStatus.Published">Published</option>
                        </InputSelect>
                    </div>

                    <div class="col-12">
                        <div class="form-check form-switch">
                            <InputCheckbox @bind-Value="_model.HasCommission" class="form-check-input" id="commissionCheck" />
                            <label class="form-check-label" for="commissionCheck">
                                <span class="fw-semibold">This role includes commission / variable pay</span>
                            </label>
                        </div>
                    </div>

                    @if (_model.HasCommission)
                    {
                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">OTE from <span class="text-secondary small">(On-Target Earnings)</span></label>
                            <InputNumber @bind-Value="_model.OteFrom" class="form-control rounded-4" placeholder="e.g. 120000" />
                        </div>
                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">OTE to</label>
                            <InputNumber @bind-Value="_model.OteTo" class="form-control rounded-4" placeholder="e.g. 160000" />
                        </div>
                        <div class="col-12 col-lg-4 d-flex align-items-end">
                            <div class="form-text mb-2">OTE = base salary + full commission at target. Leave blank to just show "+ Commission".</div>
                        </div>
                    }
                </div>

                <!-- ── Benefits tags ─────────────────────────────────────── -->
                <h2 class="h5 fw-bold mb-3">Benefit tags</h2>
                @foreach (var group in _benefitGroups)
                {
                    <div class="mb-3">
                        <div class="small fw-semibold text-secondary text-uppercase mb-2" style="letter-spacing:.05em;">@group.Key</div>
                        <div class="row g-1">
                            @foreach (var benefit in group.Value)
                            {
                                var benefitId = $"benefit-{benefit.Replace(" ", "-").Replace("(", "").Replace(")", "").Replace("/", "").Replace("+", "").ToLower()}";
                                <div class="col-6 col-md-4 col-lg-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="@benefitId"
                                               checked="@_model.BenefitsTags.Contains(benefit)"
                                               @onchange="e => ToggleBenefit(benefit, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label small" for="@benefitId">@benefit</label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                <div class="mb-4"></div>

                <!-- ── Application options ──────────────────────────────── -->
                <h2 class="h5 fw-bold mb-3">Application options</h2>
                <div class="row g-3 mb-4">
                    <div class="col-12 col-lg-6">
                        <label class="form-label fw-semibold">External application URL</label>
                        <InputText @bind-Value="_model.ExternalApplicationUrl" class="form-control rounded-4" placeholder="https://yoursite.com/apply" />
                        <div class="form-text">Leave blank to use the internal ATS.</div>
                    </div>

                    <div class="col-12 col-lg-6">
                        <label class="form-label fw-semibold">Application email</label>
                        <InputText @bind-Value="_model.ApplicationEmail" class="form-control rounded-4" placeholder="jobs@yourcompany.com" />
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Special requirements for applicants</label>
                        <RichTextEditor Value="@(_model.ApplicationSpecialRequirements ?? "")" ValueChanged="v => _model.ApplicationSpecialRequirements = string.IsNullOrWhiteSpace(v) ? null : v" />
                    </div>
                </div>

                <!-- ── ATS / internal ────────────────────────────────────── -->
                <h2 class="h5 fw-bold mb-3">ATS &amp; internal</h2>
                <div class="row g-3 mb-4">
                    <div class="col-12 col-lg-6">
                        <label class="form-label fw-semibold">Keywords</label>
                        <InputText @bind-Value="_model.Keywords" class="form-control rounded-4" placeholder="e.g. React, TypeScript, AWS" />
                        <div class="form-text">Used for candidate auto-matching and search.</div>
                    </div>

                    <div class="col-12 col-lg-3">
                        <label class="form-label fw-semibold">PO / Reference number</label>
                        <InputText @bind-Value="_model.PoNumber" class="form-control rounded-4" placeholder="PO-2024-001" />
                    </div>

                    <div class="col-12 col-lg-3">
                        <label class="form-label fw-semibold">Visibility</label>
                        <InputSelect @bind-Value="_model.Visibility" class="form-select rounded-4">
                            <option value="@JobVisibility.Public">Public</option>
                            <option value="@JobVisibility.Private">Private</option>
                        </InputSelect>
                    </div>

                    <div class="col-12 col-lg-3">
                        <label class="form-label fw-semibold">Listing expiry date <span class="text-danger">*</span></label>
                        <InputDate @bind-Value="_expiryDate" class="form-control rounded-4" />
                        <div class="form-text">Job will be hidden from public after this date.</div>
                    </div>
                </div>

                <!-- ── Video ────────────────────────────────────────────── -->
                <h2 class="h5 fw-bold mb-1">Video</h2>
                <p class="text-secondary small mb-3">Embed a short video to showcase the role or your workplace. Only one video source can be used.</p>
                <div class="row g-3 mb-4">
                    <div class="col-12 col-lg-6">
                        <label class="form-label fw-semibold"><i class="bi bi-youtube me-1 text-danger"></i>YouTube video ID</label>
                        <InputText @bind-Value="_model.VideoYouTubeId" class="form-control rounded-4" placeholder="e.g. dQw4w9WgXcQ"
                                   disabled="@(!string.IsNullOrWhiteSpace(_model.VideoVimeoId))" />
                        <div class="form-text">The ID from the YouTube URL: youtube.com/watch?v=<strong>ID</strong></div>
                        <ValidationMessage For="@(() => _model.VideoYouTubeId)" />
                    </div>
                    <div class="col-12 col-lg-6">
                        <label class="form-label fw-semibold"><i class="bi bi-camera-video me-1 text-info"></i>Vimeo video ID</label>
                        <InputText @bind-Value="_model.VideoVimeoId" class="form-control rounded-4" placeholder="e.g. 123456789"
                                   disabled="@(!string.IsNullOrWhiteSpace(_model.VideoYouTubeId))" />
                        <div class="form-text">The numeric ID from the Vimeo URL: vimeo.com/<strong>ID</strong></div>
                        <ValidationMessage For="@(() => _model.VideoVimeoId)" />
                    </div>
                </div>

                <!-- ── Screening questions ───────────────────────────────── -->
                <h2 class="h5 fw-bold mb-1">Screening questions</h2>
                <p class="text-secondary small mb-3">Configure questions applicants must answer when applying via the internal ATS. These questions do not appear for email or external URL applications.</p>

                <div class="form-check form-switch mb-3">
                    <input type="checkbox" class="form-check-input" id="sqAutoTag"
                           checked="@_screening.AutoTagNotSuitable"
                           @onchange="e => _screening.AutoTagNotSuitable = (bool)e.Value!" />
                    <label class="form-check-label" for="sqAutoTag">Automatically tag applications that don't meet must-have requirements as "Not Suitable"</label>
                </div>

                @{
                    var _sqCountry = _model.Countries?.Count == 1 ? _model.Countries[0] : "";
                    var _sqIndustry = _model.Category.HasValue ? FormatCategory(_model.Category.Value) : "";
                    var _sqWrLabel = string.IsNullOrEmpty(_sqCountry) ? "Right to work" : $"Right to work in {_sqCountry}";
                    var _sqYeLabel = string.IsNullOrEmpty(_sqIndustry) ? "Years of experience" : $"Years of experience in {_sqIndustry}";
                    var _sqQualLabel = string.IsNullOrEmpty(_sqIndustry) ? "Relevant qualification" : $"Qualification in {_sqIndustry}";
                }

                @SqSimpleBlock("sqWr", _sqWrLabel, _screening.WorkRights, _workRightsAnswers)
                @SqSimpleBlock("sqYe", _sqYeLabel, _screening.YearsExperience, _yearsExpAnswers)

                @* ── Salary (special: AcceptableMaxSalary) ── *@
                <div class="border rounded-4 p-3 mb-2">
                    <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                        <span class="fw-semibold small">Expected annual base salary</span>
                        <div class="d-flex gap-3 flex-shrink-0">
                            <div class="form-check form-switch mb-0">
                                <input type="checkbox" class="form-check-input" id="sqSalEn"
                                       checked="@_screening.Salary.Enabled"
                                       @onchange="e => _screening.Salary.Enabled = (bool)e.Value!" />
                                <label class="form-check-label small" for="sqSalEn">Include</label>
                            </div>
                            <div class="form-check form-switch mb-0">
                                <input type="checkbox" class="form-check-input" id="sqSalMh"
                                       disabled="@(!_screening.Salary.Enabled)"
                                       checked="@(_screening.Salary.Enabled && _screening.Salary.IsMustHave)"
                                       @onchange="e => _screening.Salary.IsMustHave = (bool)e.Value!" />
                                <label class="form-check-label small" for="sqSalMh">Must-have</label>
                            </div>
                        </div>
                    </div>
                    @if (_screening.Salary.Enabled && _screening.Salary.IsMustHave)
                    {
                        <div class="col-12 col-lg-4 mt-2">
                            <label class="form-label small text-secondary">Maximum acceptable salary</label>
                            <select class="form-select form-select-sm rounded-4"
                                    value="@_screening.Salary.AcceptableMaxSalary"
                                    @onchange="e => _screening.Salary.AcceptableMaxSalary = e.Value?.ToString()">
                                <option value="">Select max salary</option>
                                @foreach (var opt in _salaryOptions)
                                {
                                    <option value="@opt">@opt</option>
                                }
                            </select>
                        </div>
                    }
                </div>

                @SqSimpleBlock("sqNp", "Notice period", _screening.NoticePeriod, _noticePeriodAnswers)
                @SqSimpleBlock("sqPc", "Police check", _screening.PoliceCheck, _policeCheckAnswers)
                @SqSimpleBlock("sqWwc", "Working with Children Check", _screening.WorkingWithChildren, _wwcAnswers)
                @SqSimpleBlock("sqMed", "Pre-employment medical check", _screening.MedicalCheck, _yesNoAnswers)
                @SqSimpleBlock("sqDl", "Driver's licence", _screening.DriversLicence, _yesNoAnswers)
                @SqSimpleBlock("sqCar", "Access to a car", _screening.CarAccess, _yesNoAnswers)
                @SqSimpleBlock("sqPh", "Available to work on public holidays", _screening.PublicHolidays, _yesNoAnswers)

                @* ── Qualification (multi-select acceptable answers) ── *@
                @SqSimpleBlock("sqQual", _sqQualLabel, _screening.Qualification, _qualificationAnswers(_sqIndustry))

                <!-- ── Promotion options ─────────────────────────────────── -->
                <h2 class="h5 fw-bold mb-3">Promotion</h2>
                <div class="row g-3 mb-4">
                    <div class="col-12 col-lg-4">
                        <div class="form-check form-switch">
                            <InputCheckbox @bind-Value="_model.IncludeCompanyLogo" class="form-check-input" id="includeLogoCheck" />
                            <label class="form-check-label" for="includeLogoCheck">Show company logo on listing</label>
                        </div>
                    </div>

                    <div class="col-12 col-lg-4">
                        <div class="form-check form-switch">
                            <InputCheckbox @bind-Value="_model.IsHighlighted" class="form-check-input" id="highlightCheck" />
                            <label class="form-check-label" for="highlightCheck">Highlight in search results</label>
                        </div>
                    </div>

                    <div class="col-12 col-lg-4">
                        <div class="form-check form-switch">
                            <InputCheckbox @bind-Value="_model.AllowAutoMatch" class="form-check-input" id="autoMatchCheck" />
                            <label class="form-check-label" for="autoMatchCheck">Auto-match to candidate profiles</label>
                        </div>
                    </div>

                    <div class="col-12 col-lg-4">
                        <label class="form-label fw-semibold">Sticky to top until</label>
                        <InputDate @bind-Value="_stickyUntilDate" class="form-control rounded-4" />
                        <div class="form-text">Leave blank for no sticky promotion.</div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn btn-dark rounded-4 px-4" disabled="@_saving">
                        @(_saving ? "Saving..." : "Create job")
                    </button>
                    <a class="btn btn-outline-secondary rounded-4 px-4" href="/app/jobs">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private readonly CreateJobRequestDto _model = new()
    {
        Status = JobStatus.Draft,
        SalaryCurrency = CurrencyCode.AUD,
        Visibility = JobVisibility.Public
    };

    private bool _saving;
    private string? _pageError;
    private DateTime? _stickyUntilDate;
    private DateOnly? _expiryDate;

    // ── Screening questions ─────────────────────────────────────────────
    private readonly ScreeningConfig _screening = new();

    private static readonly string[] _workRightsAnswers =
    [
        "I have permanent work rights with no restrictions",
        "I have temporary work rights with no restrictions",
        "I have temporary work rights limited to designated locations",
