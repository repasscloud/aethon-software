    private async Task CreateJobAsync()
    {
        _saving = true;
        _pageError = null;

        // map extra fields not directly bound
        _model.StickyUntilUtc = _stickyUntilDate.HasValue
            ? DateTime.SpecifyKind(_stickyUntilDate.Value, DateTimeKind.Utc)
            : null;

        _model.PostingExpiresUtc = _expiryDate.HasValue
            ? DateTime.SpecifyKind(_expiryDate.Value.ToDateTime(TimeOnly.MinValue), DateTimeKind.Utc)
            : null;

        _model.ScreeningQuestionsJson = System.Text.Json.JsonSerializer.Serialize(_screening);

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsJsonAsync("/api/v1/jobs", _model);

            if (!response.IsSuccessStatusCode)
            {
                _pageError = await response.Content.ReadAsStringAsync();
                if (string.IsNullOrWhiteSpace(_pageError))
                    _pageError = "Job could not be created.";
                return;
            }

            var jobId = await response.Content.ReadFromJsonAsync<Guid>(AethonApiClient.JsonOptions);

            if (_model.Status == JobStatus.Published)
            {
                var publishResponse = await client.PostAsync($"/api/v1/jobs/{jobId}/publish", null);
                if (!publishResponse.IsSuccessStatusCode)
                {
                    NavigationManager.NavigateTo($"/app/jobs/{jobId}", forceLoad: false);
                    return;
                }
            }

            NavigationManager.NavigateTo($"/app/jobs/{jobId}", forceLoad: false);
        }
        catch
        {
            _pageError = "Job could not be created.";
        }
        finally
        {
            _saving = false;
        }
    }
