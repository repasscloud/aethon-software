    private RenderFragment SqSimpleBlock(string idPrefix, string label, ScreeningQuestion q, string[] answers) => __builder =>
    {
        <div class="border rounded-4 p-3 mb-2">
            <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                <span class="fw-semibold small">@label</span>
                <div class="d-flex gap-3 flex-shrink-0">
                    <div class="form-check form-switch mb-0">
                        <input type="checkbox" class="form-check-input" id="@($"{idPrefix}En")"
                               checked="@q.Enabled"
                               @onchange="e => { q.Enabled = (bool)e.Value!; StateHasChanged(); }" />
                        <label class="form-check-label small" for="@($"{idPrefix}En")">Include</label>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input type="checkbox" class="form-check-input" id="@($"{idPrefix}Mh")"
                               disabled="@(!q.Enabled)"
                               checked="@(q.Enabled && q.IsMustHave)"
                               @onchange="e => { q.IsMustHave = (bool)e.Value!; StateHasChanged(); }" />
                        <label class="form-check-label small" for="@($"{idPrefix}Mh")">Must-have</label>
                    </div>
                </div>
            </div>
            @if (q.Enabled && q.IsMustHave)
            {
                <div class="text-secondary small mb-1">Acceptable answers:</div>
                @foreach (var ans in answers)
                {
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="@($"{idPrefix}{ans.GetHashCode()}")"
                               checked="@q.AcceptableAnswers.Contains(ans)"
                               @onchange="e => { ToggleAcceptable(q, ans, (bool)e.Value!); StateHasChanged(); }" />
                        <label class="form-check-label small" for="@($"{idPrefix}{ans.GetHashCode()}")">@ans</label>
                    </div>
                }
            }
        </div>;
    };

