@page "/app/organisation/team"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net
@using System.Net.Http.Json
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject NavigationManager NavigationManager

<PageTitle>Organisation team | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h4 fw-bold mb-2">Loading team</h1>
            <p class="text-secondary mb-0">Fetching organisation members and invites.</p>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-lg-between gap-3">
                    <div>
                        <h1 class="h3 fw-bold mb-2">Organisation team</h1>
                        <p class="text-secondary mb-0">@_response.OrganisationName</p>
                    </div>
                    <div class="text-secondary">
                        Type: <span class="fw-semibold text-dark text-capitalize">@_response.OrganisationType</span>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_pageError))
        {
            <div class="alert alert-danger rounded-4 mb-0">
                @_pageError
            </div>
        }

        @if (_response.CanInvite)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Invite user</h2>

                    @if (!string.IsNullOrWhiteSpace(_inviteSuccess))
                    {
                        <div class="alert alert-success rounded-4">@_inviteSuccess</div>
                    }

                    <EditForm Model="_inviteModel" OnValidSubmit="CreateInviteAsync">
                        <DataAnnotationsValidator />

                        <div class="row g-3">
                            <div class="col-12 col-lg-6">
                                <label class="form-label fw-semibold">Email</label>
                                <InputText @bind-Value="_inviteModel.Email"
                                           class="form-control rounded-4"
                                           placeholder="name@company.com" />
                                <ValidationMessage For="@(() => _inviteModel.Email)" />
                            </div>

                            @if (_response.OrganisationType == "company")
                            {
                                <div class="col-12 col-lg-4">
                                    <label class="form-label fw-semibold">Role</label>
                                    <InputSelect @bind-Value="_inviteModel.CompanyRole" class="form-select rounded-4">
                                        <option value="">Select role</option>
                                        <option value="Admin">Admin</option>
                                        <option value="Recruiter">Recruiter</option>
                                        <option value="HiringManager">HiringManager</option>
                                        <option value="Interviewer">Interviewer</option>
                                        <option value="Viewer">Viewer</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _inviteModel.CompanyRole)" />
                                </div>
                            }
                            else
                            {
                                <div class="col-12 col-lg-4">
                                    <label class="form-label fw-semibold">Role</label>
                                    <InputSelect @bind-Value="_inviteModel.RecruiterRole" class="form-select rounded-4">
                                        <option value="">Select role</option>
                                        <option value="Admin">Admin</option>
                                        <option value="Recruiter">Recruiter</option>
                                        <option value="TeamLead">TeamLead</option>
                                        <option value="Viewer">Viewer</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _inviteModel.RecruiterRole)" />
                                </div>
                            }

                            <div class="col-12 col-lg-2 d-grid">
                                <label class="form-label fw-semibold d-none d-lg-block">&nbsp;</label>
                                <button type="submit" class="btn btn-dark rounded-4" disabled="@_creatingInvite">
                                    @(_creatingInvite ? "Sending..." : "Invite")
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Members</h2>

                @if (_response.Members.Count == 0)
                {
                    <p class="text-secondary mb-0">No members found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Joined</th>
                                    @if (_response.CanInvite)
                                    {
                                        <th></th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var member in _response.Members)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@member.DisplayName</div>
                                            @if (member.IsOwner)
                                            {
                                                <div class="small text-secondary">Owner</div>
                                            }
                                        </td>
                                        <td>@member.Email</td>
                                        <td>@(member.CompanyRole ?? member.RecruiterRole ?? "-")</td>
                                        <td>@member.MembershipStatus</td>
                                        <td>@member.JoinedUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                                        @if (_response.CanInvite)
                                        {
                                            <td>
                                                <a href="/app/organisation/team/@member.UserId"
                                                   class="btn btn-sm btn-outline-secondary rounded-pill"
                                                   style="font-size:.75rem;padding:.2rem .7rem;">
                                                    Manage →
                                                </a>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Pending invites</h2>

                @if (_response.PendingInvites.Count == 0)
                {
                    <p class="text-secondary mb-0">No pending invites.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Expires</th>
                                    <th>Token</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var invite in _response.PendingInvites)
                                {
                                    <tr>
                                        <td>@invite.Email</td>
                                        <td>@(invite.CompanyRole ?? invite.RecruiterRole ?? "-")</td>
                                        <td>@invite.ExpiresUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                        <td>
                                            <code>@invite.Token</code>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Accept invite</h2>
                <p class="text-secondary">Use this when you are signed in as the invited user.</p>

                @if (!string.IsNullOrWhiteSpace(_acceptSuccess))
                {
                    <div class="alert alert-success rounded-4">@_acceptSuccess</div>
                }

                <EditForm Model="_acceptModel" OnValidSubmit="AcceptInviteAsync">
                    <DataAnnotationsValidator />

                    <div class="row g-3">
                        <div class="col-12 col-lg-10">
                            <label class="form-label fw-semibold">Invite token</label>
                            <InputText @bind-Value="_acceptModel.Token"
                                       class="form-control rounded-4"
                                       placeholder="Paste invite token" />
                            <ValidationMessage For="@(() => _acceptModel.Token)" />
                        </div>
                        <div class="col-12 col-lg-2 d-grid">
                            <label class="form-label fw-semibold d-none d-lg-block">&nbsp;</label>
                            <button type="submit" class="btn btn-outline-dark rounded-4" disabled="@_acceptingInvite">
                                @(_acceptingInvite ? "Joining..." : "Join")
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private bool _loaded;
    private bool _creatingInvite;
    private bool _acceptingInvite;
    private string? _pageError;
    private string? _inviteSuccess;
    private string? _acceptSuccess;

    private OrganisationMembersResponseDto _response = new();
    private CreateOrganisationInviteRequestDto _inviteModel = new();
    private AcceptOrganisationInviteRequestDto _acceptModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _pageError = null;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.GetAsync("/api/v1/organisations/me/members");

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                _pageError = "You are not authenticated for the API request.";
                _loaded = true;
                return;
            }

            if (response.StatusCode == HttpStatusCode.Forbidden)
            {
                _pageError = "You do not have access to this organisation.";
                _loaded = true;
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _pageError = await ReadErrorAsync(response) ?? "Could not load organisation team data.";
                _loaded = true;
                return;
            }

            _response = await response.Content.ReadFromJsonAsync<OrganisationMembersResponseDto>(AethonApiClient.JsonOptions) ?? new OrganisationMembersResponseDto();

            if (_response.OrganisationType == "company")
            {
                _inviteModel = new CreateOrganisationInviteRequestDto
                {
                    CompanyRole = "Viewer"
                };
            }
            else
            {
                _inviteModel = new CreateOrganisationInviteRequestDto
                {
                    RecruiterRole = "Viewer"
                };
            }
        }
        catch (Exception)
        {
            _pageError = "Could not load organisation team data.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private async Task CreateInviteAsync()
    {
        _pageError = null;
        _inviteSuccess = null;
        _creatingInvite = true;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsJsonAsync("/api/v1/organisations/me/invites", _inviteModel);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<OrganisationInviteDto>(AethonApiClient.JsonOptions);
                _inviteSuccess = $"Invite created for {result?.Email}. Token: {result?.Token}";
                _acceptSuccess = null;
                _acceptModel = new AcceptOrganisationInviteRequestDto();
                await LoadAsync();
                return;
            }

            _pageError = await ReadErrorAsync(response) ?? "Invite could not be created.";
        }
        catch (Exception)
        {
            _pageError = "Invite could not be created.";
        }
        finally
        {
            _creatingInvite = false;
        }
    }

    private async Task AcceptInviteAsync()
    {
        _pageError = null;
        _acceptSuccess = null;
        _acceptingInvite = true;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsJsonAsync("/api/v1/organisations/invites/accept", _acceptModel);

            if (response.IsSuccessStatusCode)
            {
                // Force re-login so the new org claims are reflected in the cookie immediately
                NavigationManager.NavigateTo(
                    "/account/signout?reason=" + Uri.EscapeDataString("Invite accepted. Please sign in again to update your session."),
                    forceLoad: true);
                return;
            }

            _pageError = await ReadErrorAsync(response) ?? "Invite could not be accepted.";
        }
        catch (Exception)
        {
            _pageError = "Invite could not be accepted.";
        }
        finally
        {
            _acceptingInvite = false;
        }
    }

    private static async Task<string?> ReadErrorAsync(HttpResponseMessage response)
    {
        if (response.Content.Headers.ContentType?.MediaType?.Contains("json", StringComparison.OrdinalIgnoreCase) == true)
        {
            var problem = await response.Content.ReadFromJsonAsync<ValidationProblemResponse>(AethonApiClient.JsonOptions);

            if (problem?.Errors is { Count: > 0 })
            {
                return string.Join(" ", problem.Errors.SelectMany(x => x.Value));
            }
        }

        var raw = await response.Content.ReadAsStringAsync();
        return string.IsNullOrWhiteSpace(raw) ? null : raw;
    }

    private sealed class ValidationProblemResponse
    {
        public Dictionary<string, string[]> Errors { get; set; } = [];
    }
}
