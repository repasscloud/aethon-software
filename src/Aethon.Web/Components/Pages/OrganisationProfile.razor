@page "/app/organisation/profile"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@using Aethon.Shared.Enums
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject NavigationManager NavigationManager
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Organisation profile | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h4 fw-bold mb-2">Loading organisation profile</h1>
            <p class="text-secondary mb-0">Fetching profile details.</p>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h1 class="h3 fw-bold mb-2">Organisation profile</h1>
                <p class="text-secondary mb-0">Manage your organisation's branding, contact details, and legal information.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert alert-success rounded-4 mb-0">@_message</div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger rounded-4 mb-0">@_error</div>
        }

        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <!-- ── 1. Organisation details ───────────────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Organisation details</h2>
                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Display name <span class="text-danger">*</span></label>
                            <InputText @bind-Value="_model.Name" class="form-control rounded-4" placeholder="Acme Corp" />
                            <ValidationMessage For="@(() => _model.Name)" />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Legal name</label>
                            <InputText @bind-Value="_model.LegalName" class="form-control rounded-4" placeholder="Acme Corporation Pty Ltd" />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Website</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">https://</span>
                                <InputText @bind-Value="_model.WebsiteUrl" class="form-control rounded-end-4" placeholder="www.yourcompany.com" />
                            </div>
                            @if (_urlErrors.TryGetValue("WebsiteUrl", out var websiteErr))
                            {
                                <div class="form-text text-danger">@websiteErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Slug</label>
                            <div class="input-group">
                                <InputText @bind-Value="_model.Slug" class="form-control rounded-start-4" placeholder="acme-corp" />
                                <button type="button" class="btn btn-outline-secondary rounded-end-4"
                                        @onclick="CheckSlugAsync" disabled="@_checkingSlug">
                                    @(_checkingSlug ? "Checking…" : "Check availability")
                                </button>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_slugMessage))
                            {
                                <div class="form-text @(_slugAvailable == true ? "text-success" : "text-danger")">
                                    @_slugMessage
                                </div>
                            }
                            else
                            {
                                <div class="form-text">Used for the public organisation page URL.</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Logo URL</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">https://</span>
                                <InputText @bind-Value="_model.LogoUrl" class="form-control rounded-end-4" placeholder="cdn.yourcompany.com/logo.png" />
                            </div>
                            <div class="form-text">Square image, min 200×200px recommended.</div>
                            @if (_urlErrors.TryGetValue("LogoUrl", out var logoErr))
                            {
                                <div class="form-text text-danger">@logoErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Banner image URL</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">https://</span>
                                <InputText @bind-Value="_model.BannerImageUrl" class="form-control rounded-end-4" placeholder="cdn.yourcompany.com/banner.jpg" />
                            </div>
                            <div class="form-text">Wide header image (e.g. 1200×300px).</div>
                            @if (_urlErrors.TryGetValue("BannerImageUrl", out var bannerErr))
                            {
                                <div class="form-text text-danger">@bannerErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Industry</label>
                            <InputSelect @bind-Value="_model.Industry" class="form-select rounded-4">
                                <option value="">— Select industry —</option>
                                <option value="@JobCategory.AdminSecretarial">Admin &amp; Secretarial</option>
                                <option value="@JobCategory.AdvertisingPR">Advertising &amp; PR</option>
                                <option value="@JobCategory.AgricultureFishingForestry">Agriculture, Fishing &amp; Forestry</option>
                                <option value="@JobCategory.BuildingConstruction">Building &amp; Construction</option>
                                <option value="@JobCategory.CustomerService">Customer Service</option>
                                <option value="@JobCategory.ExecutiveManagement">Executive &amp; Management</option>
                                <option value="@JobCategory.FinanceInsurance">Finance &amp; Insurance</option>
                                <option value="@JobCategory.FoodBeverage">Food &amp; Beverage</option>
                                <option value="@JobCategory.GraduateRoles">Graduate Roles</option>
                                <option value="@JobCategory.HumanResources">Human Resources</option>
                                <option value="@JobCategory.ITSoftware">IT &amp; Software</option>
                                <option value="@JobCategory.LegalServices">Legal Services</option>
                                <option value="@JobCategory.MediaJournalism">Media &amp; Journalism</option>
                                <option value="@JobCategory.MiningResources">Mining &amp; Resources</option>
                                <option value="@JobCategory.PartTimeTemp">Part-time &amp; Temp</option>
                                <option value="@JobCategory.PropertyRealEstate">Property &amp; Real Estate</option>
                                <option value="@JobCategory.PublicRelations">Public Relations</option>
                                <option value="@JobCategory.SecurityIntelligence">Security &amp; Intelligence</option>
                                <option value="@JobCategory.SocialWork">Social Work</option>
                                <option value="@JobCategory.SportRecreation">Sport &amp; Recreation</option>
                                <option value="@JobCategory.TelecommunicationsISP">Telecommunications &amp; ISP</option>
                                <option value="@JobCategory.TransportDistribution">Transport &amp; Distribution</option>
                                <option value="@JobCategory.UtilitiesEnergy">Utilities &amp; Energy</option>
                            </InputSelect>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Company size</label>
                            <InputSelect @bind-Value="_model.CompanySize" class="form-select rounded-4">
                                <option value="">— Select size —</option>
                                <option value="@CompanySize.UpTo10">1–10 employees</option>
                                <option value="@CompanySize.UpTo50">11–50 employees</option>
                                <option value="@CompanySize.UpTo200">51–200 employees</option>
                                <option value="@CompanySize.UpTo500">201–500 employees</option>
                                <option value="@CompanySize.UpTo1000">501–1,000 employees</option>
                                <option value="@CompanySize.UpTo5000">1,001–5,000 employees</option>
                                <option value="@CompanySize.UpTo10000">5,001–10,000 employees</option>
                                <option value="@CompanySize.MoreThan10000">More than 10,000 employees</option>
                            </InputSelect>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Summary</label>
                            <InputTextArea @bind-Value="_model.Summary" class="form-control rounded-4" rows="5" placeholder="Describe your organisation, culture, and what makes you a great employer..." />
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── 2. Public profile ─────────────────────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-1">Public profile</h2>
                    <p class="text-secondary small mb-3">This information is shown on your public organisation page and job listings.</p>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Public location</label>
                            <LocationPicker
                                LocationText="@_model.PublicLocationText"
                                LocationTextChanged="v => _model.PublicLocationText = v"
                                LocationCity="@_model.LocationCity"
                                LocationCityChanged="v => _model.LocationCity = v"
                                LocationState="@_model.LocationState"
                                LocationStateChanged="v => _model.LocationState = v"
                                LocationCountry="@_model.LocationCountry"
                                LocationCountryChanged="v => _model.LocationCountry = v"
                                LocationCountryCode="@_model.LocationCountryCode"
                                LocationCountryCodeChanged="v => _model.LocationCountryCode = v"
                                LocationLatitude="@_model.LocationLatitude"
                                LocationLatitudeChanged="v => _model.LocationLatitude = v"
                                LocationLongitude="@_model.LocationLongitude"
                                LocationLongitudeChanged="v => _model.LocationLongitude = v"
                                LocationPlaceId="@_model.LocationPlaceId"
                                LocationPlaceIdChanged="v => _model.LocationPlaceId = v"
                                Placeholder="Start typing a city or address..." />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Public contact email</label>
                            <InputText @bind-Value="_model.PublicContactEmail" class="form-control rounded-4" placeholder="contact@example.com" />
                            <ValidationMessage For="@(() => _model.PublicContactEmail)" />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Public contact phone</label>
                            <div class="input-group">
                                <select class="form-select flex-shrink-0 rounded-start-4" style="max-width:220px;"
                                        value="@_model.PublicContactPhoneDialCode"
                                        @onchange="e => _model.PublicContactPhoneDialCode = e.Value?.ToString()">
                                    <option value="">— Country —</option>
                                    @foreach (var c in Countries)
                                    {
                                        <option value="@c.DialCode">@c.Flag @c.Name (@c.DialCode)</option>
                                    }
                                </select>
                                <InputText @bind-Value="_model.PublicContactPhone" class="form-control rounded-end-4" placeholder="400 000 000" />
                            </div>
                        </div>

                        <div class="col-12">
                            <hr class="my-1" />
                        </div>

                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="_model.IsPublicProfileEnabled" class="form-check-input" id="publicProfileCheck" />
                                <label class="form-check-label" for="publicProfileCheck">
                                    🌐 Enable public organisation page and public job branding
                                </label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="_model.IsEqualOpportunityEmployer" class="form-check-input" id="eoeCheck" />
                                <label class="form-check-label" for="eoeCheck">
                                    <i class="bi bi-people-fill text-success me-1"></i>
                                    We certify as an <strong>Equal Opportunity Employer</strong>
                                </label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="_model.IsAccessibleWorkplace" class="form-check-input" id="accessibleCheck" />
                                <label class="form-check-label" for="accessibleCheck">
                                    <i class="bi bi-universal-access text-primary me-1"></i>
                                    We certify as an <strong>Accessible Workplace</strong>
                                </label>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_model.Slug))
                        {
                            <div class="col-12">
                                <a class="btn btn-sm btn-outline-secondary rounded-4" href="/organisations/@_model.Slug" target="_blank">
                                    <i class="bi bi-box-arrow-up-right me-1"></i>Open public page
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- ── 3. Social media ───────────────────────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Social media</h2>
                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-linkedin me-1 text-primary"></i> LinkedIn company slug</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4 small">linkedin.com/company/</span>
                                <InputText @bind-Value="_model.LinkedInUrl" class="form-control rounded-end-4" placeholder="your-company-slug" />
                            </div>
                            <div class="form-text">Enter only the slug, e.g. <code>repass-cloud</code></div>
                            @if (_urlErrors.TryGetValue("LinkedInUrl", out var liErr))
                            {
                                <div class="form-text text-danger">@liErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-twitter-x me-1"></i> X / Twitter handle</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">@@</span>
                                <InputText @bind-Value="_model.TwitterHandle" class="form-control rounded-end-4" placeholder="yourhandle" />
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-facebook me-1 text-primary"></i> Facebook page name</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4 small">facebook.com/</span>
                                <InputText @bind-Value="_model.FacebookUrl" class="form-control rounded-end-4" placeholder="YourPageName" />
                            </div>
                            <div class="form-text">Enter only your page name, e.g. <code>AethonSoftware</code></div>
                            @if (_urlErrors.TryGetValue("FacebookUrl", out var fbErr))
                            {
                                <div class="form-text text-danger">@fbErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-tiktok me-1"></i> TikTok handle</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">@@</span>
                                <InputText @bind-Value="_model.TikTokHandle" class="form-control rounded-end-4" placeholder="yourhandle" />
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-instagram me-1 text-danger"></i> Instagram handle</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">@@</span>
                                <InputText @bind-Value="_model.InstagramHandle" class="form-control rounded-end-4" placeholder="yourhandle" />
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-youtube me-1 text-danger"></i> YouTube channel</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4 small">youtube.com/channel/</span>
                                <InputText @bind-Value="_model.YouTubeUrl" class="form-control rounded-end-4" placeholder="UCxxxxxxxxxxxxxxxxxxxxxx" />
                            </div>
                            <div class="form-text">Enter only the channel ID or handle</div>
                            @if (_urlErrors.TryGetValue("YouTubeUrl", out var ytErr))
                            {
                                <div class="form-text text-danger">@ytErr</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── 4. Primary contact ────────────────────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-1">Primary contact</h2>
                    <p class="text-secondary small mb-3">Used internally for communications and verification. Not shown publicly.</p>
                    <div class="row g-3">
                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Full name</label>
                            <InputText @bind-Value="_model.PrimaryContactName" class="form-control rounded-4" placeholder="Jane Smith" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Email address</label>
                            <InputText @bind-Value="_model.PrimaryContactEmail" class="form-control rounded-4" placeholder="jane.smith@example.com" />
                            <ValidationMessage For="@(() => _model.PrimaryContactEmail)" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Phone number</label>
                            <div class="input-group">
                                <select class="form-select flex-shrink-0 rounded-start-4" style="max-width:220px;"
                                        value="@_model.PrimaryContactPhoneDialCode"
                                        @onchange="e => _model.PrimaryContactPhoneDialCode = e.Value?.ToString()">
                                    <option value="">— Country —</option>
                                    @foreach (var c in Countries)
                                    {
                                        <option value="@c.DialCode">@c.Flag @c.Name (@c.DialCode)</option>
                                    }
                                </select>
                                <InputText @bind-Value="_model.PrimaryContactPhone" class="form-control rounded-end-4" placeholder="400 000 000" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── 5. Legal & verification ───────────────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-1">Legal &amp; verification</h2>
                    <p class="text-secondary small mb-3">Registered business address and identifiers used for account verification. Not shown publicly.</p>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Registered address line 1</label>
                            <InputText @bind-Value="_model.RegisteredAddressLine1" class="form-control rounded-4" placeholder="Level 5, 123 Collins Street" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Address line 2 <span class="text-secondary fw-normal">(optional)</span></label>
                            <InputText @bind-Value="_model.RegisteredAddressLine2" class="form-control rounded-4" placeholder="Building B, Suite 200" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">City / Suburb</label>
                            <InputText @bind-Value="_model.RegisteredCity" class="form-control rounded-4" placeholder="Melbourne" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">State / Province</label>
                            <InputText @bind-Value="_model.RegisteredState" class="form-control rounded-4" placeholder="Victoria" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Postcode / ZIP</label>
                            <InputText @bind-Value="_model.RegisteredPostcode" class="form-control rounded-4" placeholder="3000" />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Country</label>
                            <select class="form-select rounded-4"
                                    value="@_model.RegisteredCountryCode"
                                    @onchange="OnRegisteredCountryChange">
                                <option value="">— Select country —</option>
                                @foreach (var c in Countries)
                                {
                                    <option value="@c.IsoCode">@c.Flag @c.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-lg-3">
                            <label class="form-label fw-semibold">Tax registration number</label>
                            <InputText @bind-Value="_model.TaxRegistrationNumber" class="form-control rounded-4" placeholder="e.g. ABN 12 345 678 901" />
                            <div class="form-text">ABN, EIN, VAT, GST, etc.</div>
                        </div>

                        <div class="col-12 col-lg-3">
                            <label class="form-label fw-semibold">Business registration number</label>
                            <InputText @bind-Value="_model.BusinessRegistrationNumber" class="form-control rounded-4" placeholder="e.g. ACN 123 456 789" />
                            <div class="form-text">ACN, company number, etc.</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Save ──────────────────────────────────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <button type="submit" class="btn btn-dark rounded-4 px-4" disabled="@_saving">
                        @(_saving ? "Saving..." : "Save profile")
                    </button>
                </div>
            </div>

        </EditForm>
    </div>
}

@code {
    private const string LinkedInBase = "https://www.linkedin.com/company/";
    private const string FacebookBase = "https://www.facebook.com/";
    private const string YouTubeBase  = "https://www.youtube.com/channel/";

    private bool _loaded;
    private bool _saving;
    private string? _message;
    private string? _error;
    private UpdateOrganisationProfileRequestDto _model = new();
    private bool _checkingSlug;
    private bool? _slugAvailable;
    private string? _slugMessage;
    private Dictionary<string, string> _urlErrors = new();

    // ── Country / dial-code data ────────────────────────────────────────────

    private record CountryEntry(string Flag, string Name, string IsoCode, string DialCode);

    private static readonly CountryEntry[] Countries =
    [
        new("🇦🇺", "Australia",           "AU", "+61"),
