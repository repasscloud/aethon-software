        new("🇵🇭", "Philippines",          "PH", "+63"),
        new("🇮🇩", "Indonesia",            "ID", "+62"),
        new("🇻🇳", "Vietnam",              "VN", "+84"),
        new("🇧🇩", "Bangladesh",           "BD", "+880"),
        new("🇵🇰", "Pakistan",             "PK", "+92"),
        new("🇩🇪", "Germany",              "DE", "+49"),
        new("🇫🇷", "France",               "FR", "+33"),
        new("🇮🇹", "Italy",                "IT", "+39"),
        new("🇪🇸", "Spain",                "ES", "+34"),
        new("🇳🇱", "Netherlands",          "NL", "+31"),
        new("🇧🇪", "Belgium",              "BE", "+32"),
        new("🇨🇭", "Switzerland",          "CH", "+41"),
        new("🇦🇹", "Austria",              "AT", "+43"),
        new("🇸🇪", "Sweden",               "SE", "+46"),
        new("🇳🇴", "Norway",               "NO", "+47"),
        new("🇩🇰", "Denmark",              "DK", "+45"),
        new("🇫🇮", "Finland",              "FI", "+358"),
        new("🇵🇱", "Poland",               "PL", "+48"),
        new("🇵🇹", "Portugal",             "PT", "+351"),
        new("🇬🇷", "Greece",               "GR", "+30"),
        new("🇨🇿", "Czech Republic",       "CZ", "+420"),
        new("🇷🇴", "Romania",              "RO", "+40"),
        new("🇭🇺", "Hungary",              "HU", "+36"),
        new("🇷🇺", "Russia",               "RU", "+7"),
