@page "/app/organisation/profile"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@using Aethon.Shared.Enums
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api
@inject NavigationManager NavigationManager
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Organisation profile | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h4 fw-bold mb-2">Loading organisation profile</h1>
            <p class="text-secondary mb-0">Fetching profile details.</p>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h1 class="h3 fw-bold mb-2">Organisation profile</h1>
                <p class="text-secondary mb-0">Manage branding and public company page details.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert alert-success rounded-4 mb-0">@_message</div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger rounded-4 mb-0">@_error</div>
        }

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <EditForm Model="_model" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />

                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Display name</label>
                            <InputText @bind-Value="_model.Name" class="form-control rounded-4" />
                            <ValidationMessage For="@(() => _model.Name)" />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Legal name</label>
                            <InputText @bind-Value="_model.LegalName" class="form-control rounded-4" />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Website</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">https://</span>
                                <InputText @bind-Value="_model.WebsiteUrl" class="form-control rounded-end-4" placeholder="www.yourcompany.com" />
                            </div>
                            @if (_urlErrors.TryGetValue("WebsiteUrl", out var websiteErr))
                            {
                                <div class="form-text text-danger">@websiteErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Slug</label>
                            <div class="input-group">
                                <InputText @bind-Value="_model.Slug" class="form-control rounded-start-4" />
                                <button type="button" class="btn btn-outline-secondary rounded-end-4"
                                        @onclick="CheckSlugAsync" disabled="@_checkingSlug">
                                    @(_checkingSlug ? "Checking…" : "Check availability")
                                </button>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_slugMessage))
                            {
                                <div class="form-text @(_slugAvailable == true ? "text-success" : "text-danger")">
                                    @_slugMessage
                                </div>
                            }
                            else
                            {
                                <div class="form-text">Used for the public organisation page URL.</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Logo URL</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">https://</span>
                                <InputText @bind-Value="_model.LogoUrl" class="form-control rounded-end-4" placeholder="example.com/logo.png" />
                            </div>
                            <div class="form-text">Square image, min 200×200px recommended.</div>
                            @if (_urlErrors.TryGetValue("LogoUrl", out var logoErr))
                            {
                                <div class="form-text text-danger">@logoErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Banner image URL</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">https://</span>
                                <InputText @bind-Value="_model.BannerImageUrl" class="form-control rounded-end-4" placeholder="example.com/banner.jpg" />
                            </div>
                            <div class="form-text">Wide header image shown at the top of your public page (e.g. 1200×300px).</div>
                            @if (_urlErrors.TryGetValue("BannerImageUrl", out var bannerErr))
                            {
                                <div class="form-text text-danger">@bannerErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Industry</label>
                            <InputSelect @bind-Value="_model.Industry" class="form-select rounded-4">
                                <option value="">— Select industry —</option>
                                <option value="@JobCategory.AdminSecretarial">Admin &amp; Secretarial</option>
                                <option value="@JobCategory.AdvertisingPR">Advertising &amp; PR</option>
                                <option value="@JobCategory.AgricultureFishingForestry">Agriculture, Fishing &amp; Forestry</option>
                                <option value="@JobCategory.BuildingConstruction">Building &amp; Construction</option>
                                <option value="@JobCategory.CustomerService">Customer Service</option>
                                <option value="@JobCategory.ExecutiveManagement">Executive &amp; Management</option>
                                <option value="@JobCategory.FinanceInsurance">Finance &amp; Insurance</option>
                                <option value="@JobCategory.FoodBeverage">Food &amp; Beverage</option>
                                <option value="@JobCategory.GraduateRoles">Graduate Roles</option>
                                <option value="@JobCategory.HumanResources">Human Resources</option>
                                <option value="@JobCategory.ITSoftware">IT &amp; Software</option>
                                <option value="@JobCategory.LegalServices">Legal Services</option>
                                <option value="@JobCategory.MediaJournalism">Media &amp; Journalism</option>
                                <option value="@JobCategory.MiningResources">Mining &amp; Resources</option>
                                <option value="@JobCategory.PartTimeTemp">Part-time &amp; Temp</option>
                                <option value="@JobCategory.PropertyRealEstate">Property &amp; Real Estate</option>
                                <option value="@JobCategory.PublicRelations">Public Relations</option>
                                <option value="@JobCategory.SecurityIntelligence">Security &amp; Intelligence</option>
                                <option value="@JobCategory.SocialWork">Social Work</option>
                                <option value="@JobCategory.SportRecreation">Sport &amp; Recreation</option>
                                <option value="@JobCategory.TelecommunicationsISP">Telecommunications &amp; ISP</option>
                                <option value="@JobCategory.TransportDistribution">Transport &amp; Distribution</option>
                                <option value="@JobCategory.UtilitiesEnergy">Utilities &amp; Energy</option>
                            </InputSelect>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Company size</label>
                            <InputSelect @bind-Value="_model.CompanySize" class="form-select rounded-4">
                                <option value="">— Select size —</option>
                                <option value="@CompanySize.UpTo10">1–10 employees</option>
                                <option value="@CompanySize.UpTo50">11–50 employees</option>
                                <option value="@CompanySize.UpTo200">51–200 employees</option>
                                <option value="@CompanySize.UpTo500">201–500 employees</option>
                                <option value="@CompanySize.UpTo1000">501–1,000 employees</option>
                                <option value="@CompanySize.UpTo5000">1,001–5,000 employees</option>
                                <option value="@CompanySize.UpTo10000">5,001–10,000 employees</option>
                                <option value="@CompanySize.MoreThan10000">More than 10,000 employees</option>
                            </InputSelect>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Summary</label>
                            <InputTextArea @bind-Value="_model.Summary" class="form-control rounded-4" rows="5" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Public location</label>
                            <LocationPicker
                                LocationText="@_model.PublicLocationText"
                                LocationTextChanged="v => _model.PublicLocationText = v"
                                LocationCity="@_model.LocationCity"
                                LocationCityChanged="v => _model.LocationCity = v"
                                LocationState="@_model.LocationState"
                                LocationStateChanged="v => _model.LocationState = v"
                                LocationCountry="@_model.LocationCountry"
                                LocationCountryChanged="v => _model.LocationCountry = v"
                                LocationCountryCode="@_model.LocationCountryCode"
                                LocationCountryCodeChanged="v => _model.LocationCountryCode = v"
                                LocationLatitude="@_model.LocationLatitude"
                                LocationLatitudeChanged="v => _model.LocationLatitude = v"
                                LocationLongitude="@_model.LocationLongitude"
                                LocationLongitudeChanged="v => _model.LocationLongitude = v"
                                LocationPlaceId="@_model.LocationPlaceId"
                                LocationPlaceIdChanged="v => _model.LocationPlaceId = v"
                                Placeholder="Start typing a city or address..." />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Public contact email</label>
                            <InputText @bind-Value="_model.PublicContactEmail" class="form-control rounded-4" />
                        </div>

                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold">Public contact phone</label>
                            <InputText @bind-Value="_model.PublicContactPhone" class="form-control rounded-4" />
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="_model.IsPublicProfileEnabled" class="form-check-input" />
                                <label class="form-check-label">Enable public organisation page and public job branding</label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="_model.IsEqualOpportunityEmployer" class="form-check-input" id="eoeCheck" />
                                <label class="form-check-label" for="eoeCheck">
                                    <i class="bi bi-people-fill text-success me-1"></i>
                                    We certify as an <strong>Equal Opportunity Employer</strong>
                                </label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="_model.IsAccessibleWorkplace" class="form-check-input" id="accessibleCheck" />
                                <label class="form-check-label" for="accessibleCheck">
                                    <i class="bi bi-universal-access text-primary me-1"></i>
                                    We certify as an <strong>Accessible Workplace</strong>
                                </label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h2 class="h5 fw-bold mb-3">Social media</h2>
                    <div class="row g-3 mb-2">
                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-linkedin me-1 text-primary"></i> LinkedIn company slug</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4 small">linkedin.com/company/</span>
                                <InputText @bind-Value="_model.LinkedInUrl" class="form-control rounded-end-4" placeholder="your-company-slug" />
                            </div>
                            <div class="form-text">Enter only the slug, e.g. <code>repass-cloud</code></div>
                            @if (_urlErrors.TryGetValue("LinkedInUrl", out var liErr))
                            {
                                <div class="form-text text-danger">@liErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-twitter-x me-1"></i> X / Twitter handle</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">@@</span>
                                <InputText @bind-Value="_model.TwitterHandle" class="form-control rounded-end-4" placeholder="yourhandle" />
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-facebook me-1 text-primary"></i> Facebook page name</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4 small">facebook.com/</span>
                                <InputText @bind-Value="_model.FacebookUrl" class="form-control rounded-end-4" placeholder="YourPageName" />
                            </div>
                            <div class="form-text">Enter only your page name, e.g. <code>AethonSoftware</code></div>
                            @if (_urlErrors.TryGetValue("FacebookUrl", out var fbErr))
                            {
                                <div class="form-text text-danger">@fbErr</div>
                            }
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-tiktok me-1"></i> TikTok handle</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">@@</span>
                                <InputText @bind-Value="_model.TikTokHandle" class="form-control rounded-end-4" placeholder="yourhandle" />
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-instagram me-1 text-danger"></i> Instagram handle</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4">@@</span>
                                <InputText @bind-Value="_model.InstagramHandle" class="form-control rounded-end-4" placeholder="yourhandle" />
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold"><i class="bi bi-youtube me-1 text-danger"></i> YouTube channel</label>
                            <div class="input-group">
                                <span class="input-group-text rounded-start-4 small">youtube.com/channel/</span>
                                <InputText @bind-Value="_model.YouTubeUrl" class="form-control rounded-end-4" placeholder="UCxxxxxxxxxxxxxxxxxxxxxx" />
                            </div>
                            <div class="form-text">Enter only the channel ID or handle</div>
                            @if (_urlErrors.TryGetValue("YouTubeUrl", out var ytErr))
                            {
                                <div class="form-text text-danger">@ytErr</div>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-dark rounded-4 px-4" disabled="@_saving">
                            @(_saving ? "Saving..." : "Save profile")
                        </button>

                        @if (!string.IsNullOrWhiteSpace(_model.Slug))
                        {
                            <a class="btn btn-outline-dark rounded-4 px-4" href="/organisations/@_model.Slug" target="_blank">Open public page</a>
                        }
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private const string LinkedInBase = "https://www.linkedin.com/company/";
    private const string FacebookBase = "https://www.facebook.com/";
    private const string YouTubeBase  = "https://www.youtube.com/channel/";

    private bool _loaded;
    private bool _saving;
    private string? _message;
    private string? _error;
    private UpdateOrganisationProfileRequestDto _model = new();
    private bool _checkingSlug;
    private bool? _slugAvailable;
    private string? _slugMessage;
    private Dictionary<string, string> _urlErrors = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = await Api.CreateAsync();
            var profile = await client.GetFromJsonAsync<OrganisationProfileDto>("/api/v1/organisations/me/profile", AethonApiClient.JsonOptions);

            if (profile is not null)
            {
                _model = new UpdateOrganisationProfileRequestDto
                {
                    Name = profile.Name,
                    LegalName = profile.LegalName,
                    WebsiteUrl = StripHttps(profile.WebsiteUrl),
                    Slug = profile.Slug,
                    LogoUrl = StripHttps(profile.LogoUrl),
                    Summary = profile.Summary,
                    PublicLocationText = profile.PublicLocationText,
                    LocationCity = profile.LocationCity,
                    LocationState = profile.LocationState,
                    LocationCountry = profile.LocationCountry,
                    LocationCountryCode = profile.LocationCountryCode,
                    LocationLatitude = profile.LocationLatitude,
                    LocationLongitude = profile.LocationLongitude,
                    LocationPlaceId = profile.LocationPlaceId,
                    PublicContactEmail = profile.PublicContactEmail,
                    PublicContactPhone = profile.PublicContactPhone,
                    IsPublicProfileEnabled = profile.IsPublicProfileEnabled,
                    IsEqualOpportunityEmployer = profile.IsEqualOpportunityEmployer,
                    IsAccessibleWorkplace = profile.IsAccessibleWorkplace,
                    BannerImageUrl = StripHttps(profile.BannerImageUrl),
                    Industry = profile.Industry,
                    CompanySize = profile.CompanySize,
                    LinkedInUrl = StripSocialPrefix(profile.LinkedInUrl, LinkedInBase),
                    TwitterHandle = profile.TwitterHandle,
                    FacebookUrl = StripSocialPrefix(profile.FacebookUrl, FacebookBase),
                    TikTokHandle = profile.TikTokHandle,
                    InstagramHandle = profile.InstagramHandle,
                    YouTubeUrl = StripSocialPrefix(profile.YouTubeUrl, YouTubeBase)
                };
            }
        }
        catch
        {
            _error = "Could not load organisation profile.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private async Task CheckSlugAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.Slug))
        {
            _slugMessage = "Enter a slug to check.";
            _slugAvailable = false;
            return;
        }

        _checkingSlug = true;
        _slugMessage = null;
        _slugAvailable = null;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.GetAsync($"/api/v1/organisations/check-slug?slug={Uri.EscapeDataString(_model.Slug)}");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<SlugCheckResult>(AethonApiClient.JsonOptions);
                _slugAvailable = result?.Available;
                _slugMessage = _slugAvailable == true
                    ? $"'{result!.Slug}' is available."
                    : $"'{result?.Slug ?? _model.Slug}' is already taken.";
            }
            else
            {
                _slugMessage = "Could not check slug availability.";
            }
        }
        catch
        {
            _slugMessage = "Could not check slug availability.";
        }
        finally
        {
            _checkingSlug = false;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _message = null;
        _error = null;
        _urlErrors.Clear();

        // Format validation for social handles
        if (!string.IsNullOrWhiteSpace(_model.LinkedInUrl) &&
            !Regex.IsMatch(_model.LinkedInUrl.Trim(), @"^[a-zA-Z0-9\-_]+$"))
            _urlErrors["LinkedInUrl"] = "Enter only your company slug — letters, numbers, and hyphens only. No slashes or https://.";

        if (!string.IsNullOrWhiteSpace(_model.FacebookUrl) &&
            (_model.FacebookUrl.Contains('/') || _model.FacebookUrl.Contains(' ')))
            _urlErrors["FacebookUrl"] = "Enter only your page name — no slashes or spaces.";

        if (!string.IsNullOrWhiteSpace(_model.YouTubeUrl) &&
            (_model.YouTubeUrl.Contains('/') || _model.YouTubeUrl.Contains(' ')))
            _urlErrors["YouTubeUrl"] = "Enter only the channel ID or handle — no slashes or spaces.";

        if (_urlErrors.Count > 0)
        {
            _saving = false;
            return;
        }

        // Build submit model with full URLs restored
        var submit = new UpdateOrganisationProfileRequestDto
        {
            Name = _model.Name,
            LegalName = _model.LegalName,
            WebsiteUrl    = BuildHttpsUrl(_model.WebsiteUrl),
            Slug          = _model.Slug,
            LogoUrl       = BuildHttpsUrl(_model.LogoUrl),
            BannerImageUrl = BuildHttpsUrl(_model.BannerImageUrl),
            Summary       = _model.Summary,
            PublicLocationText    = _model.PublicLocationText,
            LocationCity          = _model.LocationCity,
            LocationState         = _model.LocationState,
            LocationCountry       = _model.LocationCountry,
            LocationCountryCode   = _model.LocationCountryCode,
            LocationLatitude      = _model.LocationLatitude,
            LocationLongitude     = _model.LocationLongitude,
            LocationPlaceId       = _model.LocationPlaceId,
            PublicContactEmail    = _model.PublicContactEmail,
            PublicContactPhone    = _model.PublicContactPhone,
            IsPublicProfileEnabled       = _model.IsPublicProfileEnabled,
            IsEqualOpportunityEmployer   = _model.IsEqualOpportunityEmployer,
            IsAccessibleWorkplace        = _model.IsAccessibleWorkplace,
            Industry      = _model.Industry,
            CompanySize   = _model.CompanySize,
            LinkedInUrl   = BuildSocialUrl(_model.LinkedInUrl, LinkedInBase),
            TwitterHandle = _model.TwitterHandle,
            FacebookUrl   = BuildSocialUrl(_model.FacebookUrl, FacebookBase),
            TikTokHandle  = _model.TikTokHandle,
            InstagramHandle = _model.InstagramHandle,
            YouTubeUrl    = BuildSocialUrl(_model.YouTubeUrl, YouTubeBase)
        };

        // URL reachability checks (website, logo, banner) — run in parallel
        var checks = new List<Task>();
        if (!string.IsNullOrWhiteSpace(submit.WebsiteUrl))
            checks.Add(CheckUrlAsync(submit.WebsiteUrl, "WebsiteUrl"));
        if (!string.IsNullOrWhiteSpace(submit.LogoUrl))
            checks.Add(CheckUrlAsync(submit.LogoUrl, "LogoUrl"));
        if (!string.IsNullOrWhiteSpace(submit.BannerImageUrl))
            checks.Add(CheckUrlAsync(submit.BannerImageUrl, "BannerImageUrl"));

        if (checks.Count > 0)
            await Task.WhenAll(checks);

        if (_urlErrors.Count > 0)
        {
            _saving = false;
            return;
        }

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PutAsJsonAsync("/api/v1/organisations/me/profile", submit);

            if (response.IsSuccessStatusCode)
            {
                _message = "Organisation profile saved.";
                return;
            }

            _error = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(_error))
                _error = "Could not save organisation profile.";
        }
        catch
        {
            _error = "Could not save organisation profile.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CheckUrlAsync(string url, string field)
    {
        try
        {
            using var http = HttpClientFactory.CreateClient();
            http.Timeout = TimeSpan.FromSeconds(8);
            http.DefaultRequestHeaders.UserAgent.ParseAdd("Mozilla/5.0 (compatible; AethonBot/1.0)");
            using var req = new HttpRequestMessage(HttpMethod.Head, url);
            using var res = await http.SendAsync(req);
            if (!res.IsSuccessStatusCode)
                _urlErrors[field] = $"URL returned HTTP {(int)res.StatusCode}. Please check it is publicly accessible.";
        }
        catch
        {
            _urlErrors[field] = "Could not reach this URL. Please check it is correct and publicly accessible.";
        }
    }

    // ── URL helpers ────────────────────────────────────────────────────────────

    private static string StripHttps(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        if (url.StartsWith("https://", StringComparison.OrdinalIgnoreCase)) return url["https://".Length..];
        if (url.StartsWith("http://",  StringComparison.OrdinalIgnoreCase)) return url["http://".Length..];
        return url;
    }

    private static string StripSocialPrefix(string? url, string baseUrl)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        url = url.Trim();
        // Try exact base and base without www
        foreach (var p in new[] { baseUrl, baseUrl.Replace("www.", "") })
            if (url.StartsWith(p, StringComparison.OrdinalIgnoreCase))
                return url[p.Length..].Trim('/');
        // Fall back: just strip https://
        return StripHttps(url);
    }

    private static string? BuildHttpsUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return null;
        value = value.Trim();
        if (value.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            value.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return value;
        return "https://" + value;
    }

    private static string? BuildSocialUrl(string? handle, string baseUrl)
    {
        if (string.IsNullOrWhiteSpace(handle)) return null;
        handle = handle.Trim().TrimStart('/');
        if (handle.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return handle;
        return baseUrl + handle;
    }

    private sealed class SlugCheckResult
    {
        public bool Available { get; set; }
        public string? Slug { get; set; }
    }
}
