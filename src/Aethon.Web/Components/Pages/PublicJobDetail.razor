@page "/jobs/{Id}"
@page "/jobs/{OrgSlug}/{Slug}"
@attribute [AllowAnonymous]
@layout PublicLayout
@rendermode InteractiveServer
@using System.Net
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
@using System.Text.RegularExpressions
@using Aethon.Shared.Auth
@using Aethon.Shared.Enums
@using Aethon.Shared.Jobs
@using Aethon.Shared.Utilities
@using Aethon.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@inject AethonApiClient Api
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(_job?.Title ?? "Job") | Aethon</PageTitle>

@if (_job is not null)
{
    <HeadContent>
        <script type="application/ld+json">@((MarkupString)BuildJsonLd())</script>
    </HeadContent>
}

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading job…</div>
    </div>
}
else if (_job is null)
{
    <div class="alert alert-danger rounded-4 mb-0">@(_error ?? "Job not found.")</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <!-- Header card -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-lg-row gap-4">

                    @if (!string.IsNullOrWhiteSpace(_job.Organisation.LogoUrl))
                    {
                        <div class="flex-shrink-0">
                            <img src="@_job.Organisation.LogoUrl" alt="@_job.Organisation.Name"
                                 style="width:80px; height:80px; object-fit:contain; border:1px solid #e9ecef; border-radius:12px; padding:8px;" />
                        </div>
                    }

                    <div class="flex-grow-1 min-w-0">
                        <h1 class="h3 fw-bold mb-1">@_job.Title</h1>
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
                            <a class="text-decoration-none text-secondary small" href="/organisations/@_job.Organisation.Slug">@_job.Organisation.Name</a>
                            @if (_job.Organisation.IsVerified)
                            {
                                @if (_job.Organisation.VerificationTier == VerificationTier.EnhancedTrusted)
                                {
                                    <a href="/info/enhanced-verification" class="badge bg-success rounded-pill text-decoration-none" style="font-size:.7rem;" title="Enhanced Trusted Employer">
                                        <i class="bi bi-shield-fill-check me-1"></i>Enhanced Trusted
                                    </a>
                                }
                                else
                                {
                                    <a href="/info/standard-verification" class="badge bg-primary rounded-pill text-decoration-none" style="font-size:.7rem;" title="Verified Employer">
                                        <i class="bi bi-patch-check-fill me-1"></i>Verified
                                    </a>
                                }
                            }
                            @if (_job.IsImported)
                            {
                                <span class="badge bg-secondary rounded-pill" style="font-size:.7rem;" title="This job was imported from an external source">
                                    <i class="bi bi-box-arrow-in-down me-1"></i>External Listing
                                </span>
                            }
                        </div>

                        <!-- Badges row -->
                        @if (_job.IsImmediateStart)
                        {
                            <div class="mb-2">
                                <span class="badge bg-success rounded-pill"><i class="bi bi-lightning-fill me-1"></i>Immediate Start</span>
                            </div>
                        }

                        @if (_job.PostingExpiresUtc.HasValue && _job.PostingExpiresUtc.Value > DateTime.UtcNow)
                        {
                            <div class="mb-2">
                                <span class="badge bg-warning text-dark rounded-pill">
                                    <i class="bi bi-clock me-1"></i>Apply by @_job.PostingExpiresUtc.Value.ToString("d MMM yyyy")
                                </span>
                            </div>
                        }

                        <!-- Key attributes row -->
                        <div class="d-flex flex-wrap gap-3 mb-3">
                            @if (!string.IsNullOrWhiteSpace(_job.LocationText))
                            {
                                <span class="d-flex align-items-center gap-1 text-secondary">
                                    <i class="bi bi-geo-alt-fill text-danger" style="font-size:.9rem;"></i>
                                    <span>@_job.LocationText</span>
                                </span>
                            }
                            <span class="d-flex align-items-center gap-1 text-secondary">
                                @switch (_job.WorkplaceType)
                                {
                                    case WorkplaceType.OnSite:
                                        <i class="bi bi-building-fill" style="font-size:.9rem; color:#e67e22;"></i>
                                        break;
                                    case WorkplaceType.Hybrid:
                                        <i class="bi bi-shuffle" style="font-size:.9rem; color:#8e44ad;"></i>
                                        break;
                                    case WorkplaceType.Remote:
                                        <i class="bi bi-house-fill" style="font-size:.9rem; color:#16a085;"></i>
                                        break;
                                }
                                <span>@FormatEnum(_job.WorkplaceType.ToString())</span>
                            </span>
                            <span class="d-flex align-items-center gap-1 text-secondary">
                                @switch (_job.EmploymentType)
                                {
                                    case EmploymentType.FullTime:
                                        <i class="bi bi-clock-fill" style="font-size:.9rem; color:#2980b9;"></i>
                                        break;
                                    case EmploymentType.PartTime:
                                        <i class="bi bi-clock-history" style="font-size:.9rem; color:#7f8c8d;"></i>
                                        break;
                                    case EmploymentType.Contract:
                                        <i class="bi bi-file-earmark-text-fill" style="font-size:.9rem; color:#d35400;"></i>
                                        break;
                                    case EmploymentType.Temporary:
                                        <i class="bi bi-hourglass-split" style="font-size:.9rem; color:#f39c12;"></i>
                                        break;
                                    case EmploymentType.Casual:
                                        <i class="bi bi-sun-fill" style="font-size:.9rem; color:#27ae60;"></i>
                                        break;
                                    case EmploymentType.Internship:
                                        <i class="bi bi-mortarboard-fill" style="font-size:.9rem; color:#8e44ad;"></i>
                                        break;
                                }
                                <span>@FormatEnum(_job.EmploymentType.ToString())</span>
                            </span>
                            @if (_job.Category.HasValue)
                            {
                                <span class="d-flex align-items-center gap-1 text-secondary">
                                    <i class="bi bi-tag-fill text-success" style="font-size:.9rem;"></i>
                                    <span>@FormatCategory(_job.Category.Value)</span>
                                </span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_job.Department))
                            {
                                <span class="d-flex align-items-center gap-1 text-secondary">
                                    <i class="bi bi-diagram-3-fill text-warning" style="font-size:.9rem;"></i>
                                    <span>@_job.Department</span>
                                </span>
                            }
                            @if (_job.SalaryFrom.HasValue || _job.SalaryTo.HasValue)
                            {
                                <span class="d-flex align-items-center gap-1">
                                    <i class="bi bi-cash-coin text-success" style="font-size:.9rem;"></i>
                                    @if (_job.SalaryFrom.HasValue && _job.SalaryTo.HasValue)
                                    {
                                        <span class="fw-semibold text-dark">@_job.SalaryCurrency @_job.SalaryFrom?.ToString("N0") – @_job.SalaryTo?.ToString("N0")</span>
                                    }
                                    else if (_job.SalaryFrom.HasValue)
                                    {
                                        <span class="fw-semibold text-dark">From @_job.SalaryCurrency @_job.SalaryFrom?.ToString("N0")</span>
                                    }
                                    @if (_job.HasCommission && _job.OteFrom.HasValue && _job.OteTo.HasValue)
                                    {
                                        <span class="ms-1 text-success fw-semibold">· OTE @_job.SalaryCurrency @_job.OteFrom?.ToString("N0") – @_job.OteTo?.ToString("N0")</span>
                                    }
                                    else if (_job.HasCommission)
                                    {
                                        <span class="ms-1 text-success">+ Commission</span>
                                    }
                                </span>
                            }
                            else if (_job.HasCommission)
                            {
                                <span class="d-flex align-items-center gap-1 text-success">
                                    <i class="bi bi-cash-coin" style="font-size:.9rem;"></i>
                                    @if (_job.OteFrom.HasValue && _job.OteTo.HasValue)
                                    {
                                        <span class="fw-semibold">OTE @_job.SalaryCurrency @_job.OteFrom?.ToString("N0") – @_job.OteTo?.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span>Commission available</span>
                                    }
                                </span>
                            }
                            @foreach (var region in _job.Regions)
                            {
                                <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-2 py-1" style="font-size:.8rem;">
                                    <i class="bi bi-globe2 me-1"></i>@FormatRegion(region)
                                </span>
                            }
                            @foreach (var country in _job.Countries)
                            {
                                <span class="badge bg-light text-secondary border rounded-pill px-2 py-1" style="font-size:.8rem;" title="@country">
                                    @CountryFlag(country) @country
                                </span>
                            }
                        </div>

                        <!-- EOE / Accessible badges -->
                        @if (_job.Organisation.IsEqualOpportunityEmployer || _job.Organisation.IsAccessibleWorkplace)
                        {
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @if (_job.Organisation.IsEqualOpportunityEmployer)
                                {
                                    <a href="/info/equal-opportunity-employer" class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 text-decoration-none" style="font-size:.8rem;">
                                        <i class="bi bi-people-fill me-1"></i>Equal Opportunity Employer
                                    </a>
                                }
                                @if (_job.Organisation.IsAccessibleWorkplace)
                                {
                                    <a href="/info/accessible-workplace" class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 text-decoration-none" style="font-size:.8rem;">
                                        <i class="bi bi-universal-access me-1"></i>Accessible Workplace
                                    </a>
                                }
                            </div>
                        }

                        @if (_canApply)
                        {
                            @if (!string.IsNullOrWhiteSpace(_job.ExternalApplicationUrl))
                            {
                                <a class="btn btn-dark rounded-4 px-4" href="@_job.ExternalApplicationUrl" target="_blank" rel="noopener noreferrer">
                                    <i class="bi bi-box-arrow-up-right me-2"></i>Apply on company site
                                </a>
                            }
                            else if (!string.IsNullOrWhiteSpace(_job.ApplicationEmail))
                            {
                                <a class="btn btn-dark rounded-4 px-4" href="@ApplyUrl()">
                                    <i class="bi bi-envelope me-2"></i>Apply by email
                                </a>
                            }
                            else
                            {
                                <a class="btn btn-dark rounded-4 px-4" href="@ApplyUrl()">
                                    <i class="bi bi-send me-2"></i>Apply now
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Description -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">About the role</h2>
                <div class="rich-content">@((MarkupString)(_job.Description ?? ""))</div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_job.Requirements))
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Requirements</h2>
                    <div class="rich-content">@((MarkupString)_job.Requirements)</div>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_job.Benefits))
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Benefits</h2>
                    <div class="rich-content">@((MarkupString)_job.Benefits)</div>
                </div>
            </div>
        }

        @if (_job.BenefitsTags.Count > 0)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-4">Perks &amp; benefits</h2>
                    @foreach (var section in BenefitSections)
                    {
                        var tags = _job.BenefitsTags.Where(t => section.Tags.Contains(t)).ToList();
                        @if (tags.Count > 0)
                        {
                            <div class="mb-4">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <i class="bi @(section.Icon) text-secondary"></i>
                                    <span class="fw-semibold text-secondary small text-uppercase" style="letter-spacing:.05em;">@(section.Label)</span>
                                </div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var tag in tags)
                                    {
                                        <span class="d-flex align-items-center gap-1 px-3 py-1 rounded-pill border bg-light text-dark" style="font-size:.85rem;">
                                            <i class="bi @BenefitIcon(tag)" style="font-size:.8rem;"></i>@tag
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    @{
                        var categorised = BenefitSections.SelectMany(s => s.Tags).ToHashSet();
                        var uncategorised = _job.BenefitsTags.Where(t => !categorised.Contains(t)).ToList();
                    }
                    @if (uncategorised.Count > 0)
                    {
                        <div class="mb-2">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-star text-secondary"></i>
                                <span class="fw-semibold text-secondary small text-uppercase" style="letter-spacing:.05em;">Other</span>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var tag in uncategorised)
                                {
                                    <span class="d-flex align-items-center gap-1 px-3 py-1 rounded-pill border bg-light text-dark" style="font-size:.85rem;">
                                        <i class="bi bi-check-lg" style="font-size:.8rem;"></i>@tag
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_job.VideoYouTubeId) || !string.IsNullOrWhiteSpace(_job.VideoVimeoId))
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Video</h2>
                    @if (!string.IsNullOrWhiteSpace(_job.VideoYouTubeId))
                    {
                        <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:12px;">
                            <iframe src="https://www.youtube.com/embed/@_job.VideoYouTubeId"
                                    style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen title="Job video"></iframe>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_job.VideoVimeoId))
                    {
                        <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:12px;">
                            <iframe src="https://player.vimeo.com/video/@_job.VideoVimeoId"
                                    style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;"
                                    allow="autoplay; fullscreen; picture-in-picture"
                                    allowfullscreen title="Job video"></iframe>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Apply CTA -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3">
                <div>
                    <div class="fw-semibold">Ready to apply?</div>
                    <div class="text-secondary small">Review the requirements above and submit your application.</div>
                </div>
                @if (_canApply)
                {
                    @if (!string.IsNullOrWhiteSpace(_job.ExternalApplicationUrl))
                    {
                        <a class="btn btn-dark rounded-4 px-4" href="@_job.ExternalApplicationUrl" target="_blank" rel="noopener noreferrer">
                            <i class="bi bi-box-arrow-up-right me-2"></i>Apply on company site
                        </a>
                    }
                    else if (!string.IsNullOrWhiteSpace(_job.ApplicationEmail))
                    {
                        <a class="btn btn-dark rounded-4 px-4" href="@ApplyUrl()">
                            <i class="bi bi-envelope me-2"></i>Apply by email
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-dark rounded-4 px-4" href="@ApplyUrl()">
                            <i class="bi bi-send me-2"></i>Apply now
                        </a>
                    }
                }
                else
                {
                    <span class="text-secondary small fst-italic">Applications are not available for your account type.</span>
                }
            </div>
        </div>

    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";
    [Parameter] public string OrgSlug { get; set; } = "";
    [Parameter] public string Slug { get; set; } = "";

    private bool _loaded;
    private bool _canApply = true;
    private string? _error;
    private PublicJobDetailDto? _job;
    private Guid _jobId;

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;
        _error = null;
        _job = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var appType = authState.User.FindFirst(AppClaimTypes.AppType)?.Value ?? "";
            _canApply = appType == "jobseeker";
        }
        else
        {
            _canApply = true; // unauthenticated — let the apply page handle sign-in
        }

        // Resolve job ID — either from the {Id} route or by extracting the GUID suffix from {Slug}
        if (!string.IsNullOrEmpty(Slug))
        {
            // Slug format: "job-title-words-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
            // GUID is always the last 36 characters
            var guidStr = Slug.Length >= 36 ? Slug[^36..] : "";
            if (!Guid.TryParse(guidStr, out _jobId))
            {
                _error = "Invalid job URL.";
                _loaded = true;
                return;
            }
        }
        else if (!Guid.TryParse(Id, out _jobId))
        {
            _error = "Invalid job URL.";
            _loaded = true;
            return;
        }

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.GetAsync($"/api/v1/public/jobs/{_jobId}");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                _error = "Job not found.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not load this job posting.";
                return;
            }

            _job = await response.Content.ReadFromJsonAsync<PublicJobDetailDto>(AethonApiClient.JsonOptions);

            // Imported jobs always show the apply button (external URL) regardless of account type
            if (_job is not null && _job.IsImported && !string.IsNullOrWhiteSpace(_job.ExternalApplicationUrl))
                _canApply = true;

            // Redirect old /jobs/{guid} URLs to the SEO-friendly URL
            if (_job is not null && string.IsNullOrEmpty(Slug) && !string.IsNullOrEmpty(_job.Organisation.Slug))
            {
                var seoUrl = $"/jobs/{_job.Organisation.Slug}/{JobSlug(_job.Title, _jobId)}";
                NavigationManager.NavigateTo(seoUrl, replace: true);
            }
        }
        catch
        {
            _error = "Could not load this job posting.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private string ApplyUrl()
    {
        if (_job is null) return "#";
        var orgSlug = _job.Organisation.Slug;
        if (!string.IsNullOrEmpty(orgSlug))
            return $"/jobs/{orgSlug}/{JobSlug(_job.Title, _jobId)}/apply";
        return $"/jobs/{_jobId}/apply";
    }

    private static string JobSlug(string title, Guid id)
    {
        var clean = Regex.Replace(title.ToLowerInvariant(), @"[^a-z0-9\s_]", "");
        var slug = Regex.Replace(clean.Trim(), @"\s+", "-");
        return $"{slug}-{id}";
    }

    private static string FormatEnum(string value)
    {
        // Insert spaces before uppercase letters: "FullTime" → "Full Time"
        return Regex.Replace(value, @"(?<!^)([A-Z])", " $1");
    }

    private static string FormatCategory(JobCategory c) => c switch
    {
        JobCategory.AdminSecretarial => "Admin & Secretarial",
        JobCategory.AdvertisingPR => "Advertising & PR",
        JobCategory.AgricultureFishingForestry => "Agriculture, Fishing & Forestry",
        JobCategory.BuildingConstruction => "Building & Construction",
        JobCategory.CustomerService => "Customer Service",
        JobCategory.ExecutiveManagement => "Executive & Management",
        JobCategory.FinanceInsurance => "Finance & Insurance",
        JobCategory.FoodBeverage => "Food & Beverage",
        JobCategory.GraduateRoles => "Graduate Roles",
        JobCategory.HumanResources => "Human Resources",
        JobCategory.ITSoftware => "IT & Software",
        JobCategory.LegalServices => "Legal Services",
        JobCategory.MediaJournalism => "Media & Journalism",
        JobCategory.MiningResources => "Mining & Resources",
        JobCategory.PartTimeTemp => "Part-time & Temp",
        JobCategory.PropertyRealEstate => "Property & Real Estate",
        JobCategory.PublicRelations => "Public Relations",
        JobCategory.SecurityIntelligence => "Security & Intelligence",
        JobCategory.SocialWork => "Social Work",
        JobCategory.SportRecreation => "Sport & Recreation",
        JobCategory.TelecommunicationsISP => "Telecommunications & ISP",
        JobCategory.TransportDistribution => "Transport & Distribution",
        JobCategory.UtilitiesEnergy => "Utilities & Energy",
        _ => c.ToString()
    };

    private static string FormatRegion(JobRegion r) => r switch
    {
        JobRegion.LatinAmerica => "Latin America",
        JobRegion.MiddleEast => "Middle East",
        JobRegion.NorthAmerica => "North America",
        _ => r.ToString()
    };

    private static string CountryFlag(string country)
    {
        var code = country switch
        {
            "Afghanistan"          => "AF", "Albania"            => "AL", "Algeria"          => "DZ",
            "Argentina"            => "AR", "Australia"          => "AU", "Austria"          => "AT",
            "Bangladesh"           => "BD", "Belgium"            => "BE", "Bolivia"          => "BO",
            "Brazil"               => "BR", "Cambodia"           => "KH", "Canada"           => "CA",
            "Chile"                => "CL", "China"              => "CN", "Colombia"         => "CO",
            "Croatia"              => "HR", "Czech Republic"     => "CZ", "Denmark"          => "DK",
            "Ecuador"              => "EC", "Egypt"              => "EG", "Estonia"          => "EE",
            "Ethiopia"             => "ET", "Finland"            => "FI", "France"           => "FR",
            "Germany"              => "DE", "Ghana"              => "GH", "Greece"           => "GR",
            "Guatemala"            => "GT", "Hungary"            => "HU", "India"            => "IN",
            "Indonesia"            => "ID", "Ireland"            => "IE", "Israel"           => "IL",
            "Italy"                => "IT", "Japan"              => "JP", "Jordan"           => "JO",
            "Kenya"                => "KE", "Latvia"             => "LV", "Lithuania"        => "LT",
            "Malaysia"             => "MY", "Mexico"             => "MX", "Morocco"          => "MA",
            "Netherlands"          => "NL", "New Zealand"        => "NZ", "Nigeria"          => "NG",
            "Norway"               => "NO", "Pakistan"           => "PK", "Panama"           => "PA",
            "Peru"                 => "PE", "Philippines"        => "PH", "Poland"           => "PL",
            "Portugal"             => "PT", "Romania"            => "RO", "Russia"           => "RU",
            "Saudi Arabia"         => "SA", "Serbia"             => "RS", "Singapore"        => "SG",
            "Slovakia"             => "SK", "Slovenia"           => "SI", "South Africa"     => "ZA",
            "South Korea"          => "KR", "Spain"              => "ES", "Sri Lanka"        => "LK",
            "Sweden"               => "SE", "Switzerland"        => "CH", "Taiwan"           => "TW",
            "Thailand"             => "TH", "Turkey"             => "TR", "Ukraine"          => "UA",
            "United Arab Emirates" => "AE", "United Kingdom"     => "GB", "United States"    => "US",
            "Uruguay"              => "UY", "Venezuela"          => "VE", "Vietnam"          => "VN",
            _ => null
        };
        if (code is null) return "🌐";
        return string.Concat(code.Select(c => char.ConvertFromUtf32(c - 'A' + 0x1F1E6)));
    }

    private sealed record BenefitSection(string Label, string Icon, HashSet<string> Tags);

    private static readonly BenefitSection[] BenefitSections =
    [
        new("Compensation", "bi-piggy-bank-fill", new HashSet<string>
