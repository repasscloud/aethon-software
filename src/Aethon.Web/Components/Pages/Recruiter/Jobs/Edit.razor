@page "/recruiter/jobs/edit/{JobId:guid}"
@using Aethon.Shared.Jobs
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Edit Recruiter Job</PageTitle>

@if (model is null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Title</label>
            <InputText class="form-control" @bind-Value="model.Title" />
        </div>

        <div class="mb-3">
            <label>Summary</label>
            <InputTextArea class="form-control" @bind-Value="model.Summary" />
        </div>

        <div class="mb-3">
            <label>Description</label>
            <InputTextArea class="form-control" @bind-Value="model.Description" />
        </div>

        <div class="mb-3">
            <label>Location</label>
            <InputText class="form-control" @bind-Value="model.Location" />
        </div>

        <div class="mb-3">
            <label>Salary Min</label>
            <InputNumber class="form-control" @bind-Value="model.SalaryMin" />
        </div>

        <div class="mb-3">
            <label>Salary Max</label>
            <InputNumber class="form-control" @bind-Value="model.SalaryMax" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" class="btn btn-success ms-2" @onclick="SubmitAsync">Submit For Approval</button>
    </EditForm>
}

@code {
    [Parameter] public Guid JobId { get; set; }

    private RecruiterUpdateJobDraftDto? model;

    protected override async Task OnInitializedAsync()
    {
        var detail = await Http.GetFromJsonAsync<JobDetailDto>($"api/jobs/{JobId}");
        if (detail is null)
        {
            return;
        }

        model = new RecruiterUpdateJobDraftDto
        {
            Title = detail.Title,
            Summary = detail.Summary ?? string.Empty,
            Description = detail.Description ?? string.Empty,
            Location = detail.LocationText ?? string.Empty,
            SalaryMin = detail.SalaryFrom ?? 0,
            SalaryMax = detail.SalaryTo ?? 0
        };
    }

    private async Task SaveAsync()
    {
        var response = await Http.PutAsJsonAsync($"api/recruiter/jobs/{JobId}", model);
        response.EnsureSuccessStatusCode();
        Nav.NavigateTo("/recruiter/jobs");
    }

    private async Task SubmitAsync()
    {
        var response = await Http.PostAsync($"api/recruiter/jobs/{JobId}/submit", null);
        response.EnsureSuccessStatusCode();
        Nav.NavigateTo("/recruiter/jobs");
    }
}