@page "/recruiter/jobs/edit/{JobId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@using Aethon.Shared.Jobs
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@inject AethonApiClient Api
@inject NavigationManager Nav

<PageTitle>Edit job | Aethon</PageTitle>

<div class="d-flex flex-column gap-4">

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-1">Edit job draft</h1>
            <p class="text-secondary mb-0">Update the job details or submit for company approval.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger rounded-4 mb-0">@_error</div>
    }

    @if (_model is null && !_loadFailed)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">Loading…</div>
        </div>
    }
    else if (_loadFailed)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <p class="text-danger mb-0">Could not load job. It may have been removed or you may not have access.</p>
            </div>
        </div>
    }
    else if (_model is not null)
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <EditForm Model="_model" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Job title</label>
                            <InputText class="form-control rounded-4" @bind-Value="_model.Title" />
                            <ValidationMessage For="@(() => _model.Title)" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Summary</label>
                            <InputTextArea class="form-control rounded-4" @bind-Value="_model.Summary" rows="2" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <InputTextArea class="form-control rounded-4" @bind-Value="_model.Description" rows="6" />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold">Location</label>
                            <InputText class="form-control rounded-4" @bind-Value="_model.Location" />
                        </div>

                        <div class="col-12 col-lg-3">
                            <label class="form-label fw-semibold">Salary min</label>
                            <InputNumber class="form-control rounded-4" @bind-Value="_model.SalaryMin" />
                        </div>

                        <div class="col-12 col-lg-3">
                            <label class="form-label fw-semibold">Salary max</label>
                            <InputNumber class="form-control rounded-4" @bind-Value="_model.SalaryMax" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-dark rounded-4 px-4" disabled="@_saving">
                            @(_saving ? "Saving…" : "Save")
                        </button>
                        <button type="button" class="btn btn-success rounded-4 px-4"
                                @onclick="SubmitAsync" disabled="@_saving">
                            Submit for approval
                        </button>
                        <button type="button" class="btn btn-outline-secondary rounded-4 px-4"
                                @onclick='() => Nav.NavigateTo("/recruiter/jobs")'>
                            Cancel
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid JobId { get; set; }

    private RecruiterUpdateJobDraftDto? _model;
    private string? _error;
    private bool _saving;
    private bool _loadFailed;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = await Api.CreateAsync();
            var detail = await client.GetFromJsonAsync<JobDetailDto>($"/api/v1/jobs/{JobId}", AethonApiClient.JsonOptions);
            if (detail is null)
            {
                _loadFailed = true;
                return;
            }

            _model = new RecruiterUpdateJobDraftDto
            {
                Title = detail.Title,
                Summary = detail.Summary ?? string.Empty,
                Description = detail.Description ?? string.Empty,
                Location = detail.LocationText ?? string.Empty,
                SalaryMin = detail.SalaryFrom ?? 0,
                SalaryMax = detail.SalaryTo ?? 0
            };
        }
        catch
        {
            _loadFailed = true;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PutAsJsonAsync($"/api/v1/recruiter/jobs/{JobId}", _model);
            if (!response.IsSuccessStatusCode)
            {
                _error = await ReadErrorAsync(response) ?? "Could not save job.";
                return;
            }
            Nav.NavigateTo("/recruiter/jobs");
        }
        catch
        {
            _error = "Could not save job.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SubmitAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsync($"/api/v1/recruiter/jobs/{JobId}/submit", null);
            if (!response.IsSuccessStatusCode)
            {
                _error = await ReadErrorAsync(response) ?? "Could not submit job for approval.";
                return;
            }
            Nav.NavigateTo("/recruiter/jobs");
        }
        catch
        {
            _error = "Could not submit job for approval.";
        }
        finally
        {
            _saving = false;
        }
    }

    private static async Task<string?> ReadErrorAsync(HttpResponseMessage response)
    {
        try
        {
            var problem = await response.Content.ReadFromJsonAsync<ProblemResponse>(AethonApiClient.JsonOptions);
            if (!string.IsNullOrWhiteSpace(problem?.Detail)) return problem.Detail;
        }
        catch { }

        var raw = await response.Content.ReadAsStringAsync();
        return string.IsNullOrWhiteSpace(raw) ? null : raw;
    }

    private sealed class ProblemResponse { public string? Detail { get; set; } }
}
