@page "/organisations/{Slug}/team/{MemberSlug}"
@layout PublicLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.Net
@using System.Net.Http.Json
@using Aethon.Shared.Organisations
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api

<PageTitle>@(_member?.DisplayName ?? "Team member") | @Slug | Aethon</PageTitle>

@if (!_loaded)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">Loading…</div>
    </div>
}
else if (_member is null)
{
    <div class="alert alert-danger rounded-4 mb-0">@(_error ?? "Team member not found.")</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <!-- Header card -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <a href="/organisations/@Slug/team" class="text-secondary small text-decoration-none">← @_member.OrgName team</a>

                <div class="d-flex gap-4 align-items-start flex-wrap mt-3">
                    @if (!string.IsNullOrEmpty(_member.ProfilePictureUrl))
                    {
                        <img src="@_member.ProfilePictureUrl" alt="@_member.DisplayName"
                             style="width:96px;height:96px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-secondary bg-opacity-10 rounded-circle flex-shrink-0"
                             style="width:96px;height:96px;">
                            <i class="bi bi-person text-secondary" style="font-size:2.5rem;"></i>
                        </div>
                    }
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                            <h1 class="h3 fw-bold mb-0">@_member.DisplayName</h1>
                            @if (_member.IsIdentityVerified)
                            {
                                <span class="badge bg-success rounded-pill">
                                    <i class="bi bi-patch-check-fill me-1"></i>ID Verified
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_member.JobTitle))
                        {
                            <div class="text-secondary fw-semibold mb-2">@_member.JobTitle</div>
                        }
                        <div class="d-flex flex-wrap gap-3 small">
                            @if (!string.IsNullOrEmpty(_member.PublicEmail))
                            {
                                <span class="text-secondary"><i class="bi bi-envelope me-1"></i>@_member.PublicEmail</span>
                            }
                            @if (!string.IsNullOrEmpty(_member.PublicPhone))
                            {
                                <span class="text-secondary"><i class="bi bi-telephone me-1"></i>@_member.PublicPhone</span>
                            }
                            @if (!string.IsNullOrEmpty(_member.LinkedInUrl))
                            {
                                <a href="@LinkedInUrl(_member.LinkedInUrl)" target="_blank"
                                   class="text-decoration-none text-secondary">
                                    <i class="bi bi-linkedin me-1 text-primary"></i>LinkedIn
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bio -->
        @if (!string.IsNullOrWhiteSpace(_member.Bio))
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">About</h2>
                    <div style="white-space:pre-wrap;">@_member.Bio</div>
                </div>
            </div>
        }

    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public string MemberSlug { get; set; } = "";

    private bool _loaded;
    private string? _error;
    private PublicTeamMemberDetailDto? _member;

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;
        _error = null;
        _member = null;

        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.GetAsync(
                $"/api/v1/public/organisations/{Uri.EscapeDataString(Slug)}/team/{Uri.EscapeDataString(MemberSlug)}");

            if (resp.StatusCode == HttpStatusCode.NotFound)
            {
                _error = "Team member not found.";
                return;
            }

            if (resp.IsSuccessStatusCode)
                _member = await resp.Content.ReadFromJsonAsync<PublicTeamMemberDetailDto>(AethonApiClient.JsonOptions);
            else
                _error = "Could not load team member.";
        }
        catch
        {
            _error = "Could not load team member.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private static string LinkedInUrl(string value)
    {
        if (value.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            value.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return value;
        return "https://www.linkedin.com/in/" + value.TrimStart('/');
    }
}
