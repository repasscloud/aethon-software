@page "/admin/verification-requests"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Security.Claims
@using Aethon.Shared.Auth
@using Aethon.Shared.Verification
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AethonApiClient Api

<PageTitle>Verification requests | Admin | Aethon</PageTitle>

@if (!_isStaff)
{
    <div class="alert alert-danger rounded-4">Access denied.</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex align-items-center gap-3 flex-wrap">
                <div class="flex-grow-1">
                    <h1 class="h4 fw-bold mb-0">Identity verification requests</h1>
                </div>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm rounded-3" style="width:140px;" @bind="_filterStatus" @bind:after="LoadAsync">
                        <option value="">All</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Denied">Denied</option>
                    </select>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_pageError))
        {
            <div class="alert alert-danger rounded-4">@_pageError</div>
        }
        @if (!string.IsNullOrEmpty(_successMsg))
        {
            <div class="alert alert-success rounded-4">@_successMsg</div>
        }

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                @if (!_loaded)
                {
                    <p class="text-secondary mb-0">Loading…</p>
                }
                else if (_requests.Count == 0)
                {
                    <p class="text-secondary mb-0">No verification requests found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Full name</th>
                                    <th>Contact</th>
                                    <th>Status</th>
                                    <th>Requested</th>
                                    <th>Reviewer</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _requests)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@r.UserDisplayName</div>
                                            <div class="small text-secondary">@r.UserEmail</div>
                                        </td>
                                        <td>@r.FullName</td>
                                        <td>
                                            <div class="small">@r.EmailAddress</div>
                                            <div class="small text-secondary">@r.PhoneNumber</div>
                                        </td>
                                        <td>
                                            <span class="badge @StatusBadge(r.Status) rounded-pill">@r.Status</span>
                                        </td>
                                        <td class="small">@r.RequestedUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                                        <td class="small">@(r.ReviewerType ?? "—")</td>
                                        <td>
                                            @if (r.Status == "Pending")
                                            {
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-sm btn-outline-success rounded-pill"
                                                            @onclick="() => OpenReview(r, approve: true)"
                                                            disabled="@_saving">
                                                        Approve
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger rounded-pill"
                                                            @onclick="() => OpenReview(r, approve: false)"
                                                            disabled="@_saving">
                                                        Deny
                                                    </button>
                                                </div>
                                            }
                                            else if (r.Status == "Denied" && !string.IsNullOrEmpty(r.ReviewNotes))
                                            {
                                                <span class="small text-secondary" title="@r.ReviewNotes">
                                                    <i class="bi bi-chat-left-text"></i>
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Inline review panel -->
        @if (_reviewing is not null)
        {
            <div class="card border-0 shadow-sm rounded-4 border-@(_approving ? "success" : "danger")-subtle">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-1">@(_approving ? "Approve" : "Deny") — @_reviewing.UserDisplayName</h2>
                    <p class="small text-secondary mb-3">
                        @_reviewing.FullName &bull; @_reviewing.EmailAddress &bull; @_reviewing.PhoneNumber
                        @if (!string.IsNullOrEmpty(_reviewing.AdditionalNotes))
                        {
                            <br /><em>@_reviewing.AdditionalNotes</em>
                        }
                    </p>

                    <div class="mb-3" style="max-width:480px;">
                        <label class="form-label small fw-semibold mb-1">
                            @(_approving ? "Notes (optional)" : "Denial reason (required)")
                        </label>
                        <textarea class="form-control form-control-sm rounded-3" rows="3"
                                  @bind="_reviewNotes" maxlength="1000"
                                  placeholder="@(_approving ? "Any internal notes…" : "Explain why the request is denied…")"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        @if (_approving)
                        {
                            <button class="btn btn-sm btn-success rounded-pill"
                                    @onclick="SubmitReviewAsync" disabled="@_saving">
                                @(_saving ? "Approving…" : "Confirm approve")
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-danger rounded-pill"
                                    @onclick="SubmitReviewAsync" disabled="@_saving">
                                @(_saving ? "Denying…" : "Confirm deny")
                            </button>
                        }
                        <button class="btn btn-sm btn-outline-secondary rounded-pill"
                                @onclick="CancelReview" disabled="@_saving">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        }

    </div>
}

@code {
    private bool _isStaff;
    private bool _loaded;
    private bool _saving;
    private string? _pageError;
    private string? _successMsg;
    private string _filterStatus = "Pending";

    private List<AdminVerificationRequestDto> _requests = [];

    private AdminVerificationRequestDto? _reviewing;
    private bool _approving;
    private string _reviewNotes = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var appType = (auth.User.FindFirstValue(AppClaimTypes.AppType) ?? "").ToLowerInvariant();
        _isStaff = appType is "superadmin" or "admin" or "support";

        if (_isStaff)
            await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loaded = false;
        _pageError = null;
        _requests = [];

        try
        {
            var client = await Api.CreateAsync();
            var url = string.IsNullOrEmpty(_filterStatus)
                ? "/api/v1/admin/verification-requests"
                : $"/api/v1/admin/verification-requests?status={Uri.EscapeDataString(_filterStatus)}";
            var resp = await client.GetAsync(url);
            if (resp.IsSuccessStatusCode)
            {
                var paged = await resp.Content.ReadFromJsonAsync<PagedVerificationResponse>(AethonApiClient.JsonOptions);
                _requests = paged?.Items ?? [];
            }
            else
                _pageError = "Could not load verification requests.";
        }
        catch { _pageError = "Could not load verification requests."; }
        finally { _loaded = true; }
    }

    private void OpenReview(AdminVerificationRequestDto request, bool approve)
    {
        _reviewing = request;
        _approving = approve;
        _reviewNotes = "";
        _successMsg = null;
        _pageError = null;
    }

    private void CancelReview()
    {
        _reviewing = null;
        _reviewNotes = "";
    }

    private async Task SubmitReviewAsync()
    {
        if (_reviewing is null) return;
        if (!_approving && string.IsNullOrWhiteSpace(_reviewNotes))
        {
            _pageError = "A denial reason is required.";
            return;
        }

        _saving = true; _pageError = null; _successMsg = null;
        try
        {
            var client = await Api.CreateAsync();
            var endpoint = _approving
                ? $"/api/v1/admin/verification-requests/{_reviewing.Id}/approve"
                : $"/api/v1/admin/verification-requests/{_reviewing.Id}/deny";
            var body = new { notes = string.IsNullOrWhiteSpace(_reviewNotes) ? null : _reviewNotes.Trim() };
            var resp = await client.PostAsJsonAsync(endpoint, body);
            if (resp.IsSuccessStatusCode)
            {
                _successMsg = _approving
                    ? $"Request approved for {_reviewing.UserDisplayName}."
                    : $"Request denied for {_reviewing.UserDisplayName}.";
                CancelReview();
                await LoadAsync();
            }
            else
                _pageError = _approving ? "Could not approve request." : "Could not deny request.";
        }
        catch { _pageError = "Could not submit review."; }
        finally { _saving = false; }
    }

    private static string StatusBadge(string? s) => s switch
    {
        "Pending" => "bg-warning text-dark",
        "Approved" => "bg-success",
        "Denied" => "bg-danger",
        _ => "bg-secondary"
    };

    private sealed class PagedVerificationResponse
    {
        public int Total { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public List<AdminVerificationRequestDto> Items { get; set; } = [];
    }
}
