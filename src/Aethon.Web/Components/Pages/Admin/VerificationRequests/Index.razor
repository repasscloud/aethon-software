@page "/admin/verification-requests"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Security.Claims
@using Aethon.Shared.Auth
@using Aethon.Shared.Verification
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AethonApiClient Api

<PageTitle>Verification requests | Admin | Aethon</PageTitle>

@if (!_isStaff)
{
    <div class="alert alert-danger rounded-4">Access denied.</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h1 class="h4 fw-bold mb-0">Verification Requests</h1>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_pageError))
        {
            <div class="alert alert-danger rounded-4">@_pageError</div>
        }
        @if (!string.IsNullOrEmpty(_successMsg))
        {
            <div class="alert alert-success rounded-4">@_successMsg</div>
        }

        @* ── Tabs ── *@
        <ul class="nav nav-tabs px-1">
            <li class="nav-item">
                <button class="nav-link @(_activeTab == Tab.Identity ? "active" : "")"
                        @onclick="() => SwitchTab(Tab.Identity)">
                    Identity Verification
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(_activeTab == Tab.Organisation ? "active" : "") position-relative"
                        @onclick="() => SwitchTab(Tab.Organisation)">
                    Organisation Verification
                    @if (_orgPendingCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.65rem;">
                            @_orgPendingCount
                        </span>
                    }
                </button>
            </li>
        </ul>

        @* ── Identity verification tab ── *@
        @if (_activeTab == Tab.Identity)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 d-flex align-items-center gap-3 flex-wrap">
                    <div class="flex-grow-1">
                        <h2 class="h5 fw-semibold mb-0">Identity verification requests</h2>
                    </div>
                    <select class="form-select form-select-sm rounded-3" style="width:140px;" @bind="_filterStatus" @bind:after="LoadIdentityAsync">
                        <option value="">All</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Denied">Denied</option>
                    </select>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    @if (!_identityLoaded)
                    {
                        <p class="text-secondary mb-0">Loading…</p>
                    }
                    else if (_identityRequests.Count == 0)
                    {
                        <p class="text-secondary mb-0">No identity verification requests found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Full name</th>
                                        <th>Contact</th>
                                        <th>Status</th>
                                        <th>Requested</th>
                                        <th>Reviewer</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in _identityRequests)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@r.UserDisplayName</div>
                                                <div class="small text-secondary">@r.UserEmail</div>
                                            </td>
                                            <td>@r.FullName</td>
                                            <td>
                                                <div class="small">@r.EmailAddress</div>
                                                <div class="small text-secondary">@r.PhoneNumber</div>
                                            </td>
                                            <td>
                                                <span class="badge @StatusBadge(r.Status) rounded-pill">@r.Status</span>
                                            </td>
                                            <td class="small">@r.RequestedUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                                            <td class="small">@(r.ReviewerType ?? "—")</td>
                                            <td>
                                                @if (r.Status == "Pending")
                                                {
                                                    <div class="d-flex gap-1">
                                                        <button class="btn btn-sm btn-outline-success rounded-pill"
                                                                @onclick="() => OpenIdentityReview(r, approve: true)"
                                                                disabled="@_saving">
                                                            Approve
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger rounded-pill"
                                                                @onclick="() => OpenIdentityReview(r, approve: false)"
                                                                disabled="@_saving">
                                                            Deny
                                                        </button>
                                                    </div>
                                                }
                                                else if (r.Status == "Denied" && !string.IsNullOrEmpty(r.ReviewNotes))
                                                {
                                                    <span class="small text-secondary" title="@r.ReviewNotes">
                                                        <i class="bi bi-chat-left-text"></i>
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @if (_identityReviewing is not null)
            {
                <div class="card border-0 shadow-sm rounded-4 border-@(_identityApproving ? "success" : "danger")-subtle">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-1">@(_identityApproving ? "Approve" : "Deny") — @_identityReviewing.UserDisplayName</h2>
                        <p class="small text-secondary mb-3">
                            @_identityReviewing.FullName &bull; @_identityReviewing.EmailAddress &bull; @_identityReviewing.PhoneNumber
                            @if (!string.IsNullOrEmpty(_identityReviewing.AdditionalNotes))
                            {
                                <br /><em>@_identityReviewing.AdditionalNotes</em>
                            }
                        </p>

                        <div class="mb-3" style="max-width:480px;">
                            <label class="form-label small fw-semibold mb-1">
                                @(_identityApproving ? "Notes (optional)" : "Denial reason (required)")
                            </label>
                            <textarea class="form-control form-control-sm rounded-3" rows="3"
                                      @bind="_reviewNotes" maxlength="1000"
                                      placeholder="@(_identityApproving ? "Any internal notes…" : "Explain why the request is denied…")"></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            @if (_identityApproving)
                            {
                                <button class="btn btn-sm btn-success rounded-pill"
                                        @onclick="SubmitIdentityReviewAsync" disabled="@_saving">
                                    @(_saving ? "Approving…" : "Confirm approve")
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-danger rounded-pill"
                                        @onclick="SubmitIdentityReviewAsync" disabled="@_saving">
                                    @(_saving ? "Denying…" : "Confirm deny")
                                </button>
                            }
                            <button class="btn btn-sm btn-outline-secondary rounded-pill"
                                    @onclick="CancelIdentityReview" disabled="@_saving">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            }
        }

        @* ── Organisation verification tab ── *@
        @if (_activeTab == Tab.Organisation)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-0">Pending organisation verifications</h2>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    @if (!_orgLoaded)
                    {
                        <p class="text-secondary mb-0">Loading…</p>
                    }
                    else if (_orgRequests.Count == 0)
                    {
                        <p class="text-secondary mb-0">No pending organisation verifications.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Organisation</th>
                                        <th>Type</th>
                                        <th>Tier requested</th>
                                        <th>Primary contact</th>
                                        <th>Paid at</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in _orgRequests)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@r.Name</div>
                                                @if (!string.IsNullOrEmpty(r.WebsiteUrl))
                                                {
                                                    <div class="small text-secondary">@r.WebsiteUrl</div>
                                                }
                                            </td>
                                            <td class="small">@r.OrgType</td>
                                            <td>
                                                <span class="badge @TierBadge(r.PendingTier) rounded-pill">@r.PendingTier</span>
                                            </td>
                                            <td>
                                                <div class="small">@(r.PrimaryContactName ?? "—")</div>
                                                <div class="small text-secondary">@(r.PrimaryContactEmail ?? "—")</div>
                                            </td>
                                            <td class="small">@(r.VerificationPaidAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-sm btn-outline-success rounded-pill"
                                                            @onclick="() => OpenOrgReview(r, approve: true)"
                                                            disabled="@_saving">
                                                        Approve
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger rounded-pill"
                                                            @onclick="() => OpenOrgReview(r, approve: false)"
                                                            disabled="@_saving">
                                                        Deny
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @if (_orgReviewing is not null)
            {
                <div class="card border-0 shadow-sm rounded-4 border-@(_orgApproving ? "success" : "danger")-subtle">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-1">@(_orgApproving ? "Approve" : "Deny") verification — @_orgReviewing.Name</h2>
                        <p class="small text-secondary mb-3">
                            @_orgReviewing.PendingTier tier &bull; Contact: @(_orgReviewing.PrimaryContactEmail ?? "—")
                        </p>

                        @if (!_orgApproving)
                        {
                            <div class="mb-3" style="max-width:480px;">
                                <label class="form-label small fw-semibold mb-1">Denial reason (optional)</label>
                                <textarea class="form-control form-control-sm rounded-3" rows="3"
                                          @bind="_reviewNotes" maxlength="1000"
                                          placeholder="Internal notes on why the request is being denied…"></textarea>
                            </div>
                        }

                        <div class="d-flex gap-2">
                            @if (_orgApproving)
                            {
                                <button class="btn btn-sm btn-success rounded-pill"
                                        @onclick="SubmitOrgReviewAsync" disabled="@_saving">
                                    @(_saving ? "Approving…" : "Confirm approve")
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-danger rounded-pill"
                                        @onclick="SubmitOrgReviewAsync" disabled="@_saving">
                                    @(_saving ? "Denying…" : "Confirm deny")
                                </button>
                            }
                            <button class="btn btn-sm btn-outline-secondary rounded-pill"
                                    @onclick="CancelOrgReview" disabled="@_saving">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            }
        }

    </div>
}

@code {
    private enum Tab { Identity, Organisation }

    private bool _isStaff;
    private bool _saving;
    private string? _pageError;
    private string? _successMsg;
    private Tab _activeTab = Tab.Identity;

    // ── Identity tab state ─────────────────────────────────────────────────────
    private bool _identityLoaded;
    private string _filterStatus = "Pending";
    private List<AdminVerificationRequestDto> _identityRequests = [];
    private AdminVerificationRequestDto? _identityReviewing;
    private bool _identityApproving;
    private string _reviewNotes = "";

    // ── Org tab state ──────────────────────────────────────────────────────────
    private bool _orgLoaded;
    private int _orgPendingCount;
    private List<OrgVerificationItem> _orgRequests = [];
    private OrgVerificationItem? _orgReviewing;
    private bool _orgApproving;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var appType = (auth.User.FindFirstValue(AppClaimTypes.AppType) ?? "").ToLowerInvariant();
        _isStaff = appType is "superadmin" or "admin" or "support";

        if (_isStaff)
        {
            await LoadIdentityAsync();
            await LoadOrgAsync();
        }
    }

    private async Task SwitchTab(Tab tab)
    {
        _activeTab = tab;
        _pageError = null;
        _successMsg = null;
        CancelIdentityReview();
        CancelOrgReview();

        if (tab == Tab.Identity && !_identityLoaded)
            await LoadIdentityAsync();
        else if (tab == Tab.Organisation && !_orgLoaded)
            await LoadOrgAsync();
    }

    // ── Identity verification ─────────────────────────────────────────────────

    private async Task LoadIdentityAsync()
    {
        _identityLoaded = false;
        _pageError = null;
        _identityRequests = [];

        try
        {
            var client = await Api.CreateAsync();
            var url = string.IsNullOrEmpty(_filterStatus)
                ? "/api/v1/admin/verification-requests"
                : $"/api/v1/admin/verification-requests?status={Uri.EscapeDataString(_filterStatus)}";
            var resp = await client.GetAsync(url);
            if (resp.IsSuccessStatusCode)
            {
                var paged = await resp.Content.ReadFromJsonAsync<PagedIdentityResponse>(AethonApiClient.JsonOptions);
                _identityRequests = paged?.Items ?? [];
            }
            else
                _pageError = "Could not load identity verification requests.";
        }
        catch { _pageError = "Could not load identity verification requests."; }
        finally { _identityLoaded = true; }
    }

    private void OpenIdentityReview(AdminVerificationRequestDto request, bool approve)
    {
        _identityReviewing = request;
        _identityApproving = approve;
        _reviewNotes = "";
        _successMsg = null;
        _pageError = null;
    }

    private void CancelIdentityReview()
    {
        _identityReviewing = null;
        _reviewNotes = "";
    }

    private async Task SubmitIdentityReviewAsync()
    {
        if (_identityReviewing is null) return;
        if (!_identityApproving && string.IsNullOrWhiteSpace(_reviewNotes))
        {
            _pageError = "A denial reason is required.";
            return;
        }

        _saving = true; _pageError = null; _successMsg = null;
        try
        {
            var client = await Api.CreateAsync();
            var endpoint = _identityApproving
                ? $"/api/v1/admin/verification-requests/{_identityReviewing.Id}/approve"
                : $"/api/v1/admin/verification-requests/{_identityReviewing.Id}/deny";
            var body = new { notes = string.IsNullOrWhiteSpace(_reviewNotes) ? null : _reviewNotes.Trim() };
            var resp = await client.PostAsJsonAsync(endpoint, body);
            if (resp.IsSuccessStatusCode)
            {
                _successMsg = _identityApproving
                    ? $"Request approved for {_identityReviewing.UserDisplayName}."
                    : $"Request denied for {_identityReviewing.UserDisplayName}.";
                CancelIdentityReview();
                await LoadIdentityAsync();
            }
            else
                _pageError = _identityApproving ? "Could not approve request." : "Could not deny request.";
        }
        catch { _pageError = "Could not submit review."; }
        finally { _saving = false; }
    }

    // ── Organisation verification ─────────────────────────────────────────────

    private async Task LoadOrgAsync()
    {
        _orgLoaded = false;
        _orgRequests = [];

        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.GetAsync("/api/v1/admin/org-verification-requests");
            if (resp.IsSuccessStatusCode)
            {
                var paged = await resp.Content.ReadFromJsonAsync<PagedOrgResponse>(AethonApiClient.JsonOptions);
                _orgRequests = paged?.Items ?? [];
                _orgPendingCount = paged?.Total ?? 0;
            }
            else
                _pageError = "Could not load organisation verification requests.";
        }
        catch { _pageError = "Could not load organisation verification requests."; }
        finally { _orgLoaded = true; }
    }

    private void OpenOrgReview(OrgVerificationItem request, bool approve)
    {
        _orgReviewing = request;
        _orgApproving = approve;
        _reviewNotes = "";
        _successMsg = null;
        _pageError = null;
    }

    private void CancelOrgReview()
    {
        _orgReviewing = null;
        _reviewNotes = "";
    }

    private async Task SubmitOrgReviewAsync()
    {
        if (_orgReviewing is null) return;

        _saving = true; _pageError = null; _successMsg = null;
        try
        {
            var client = await Api.CreateAsync();
            var endpoint = _orgApproving
                ? $"/api/v1/admin/org-verification-requests/{_orgReviewing.Id}/approve"
                : $"/api/v1/admin/org-verification-requests/{_orgReviewing.Id}/deny";
            var body = new { notes = string.IsNullOrWhiteSpace(_reviewNotes) ? null : _reviewNotes.Trim() };
            var resp = await client.PostAsJsonAsync(endpoint, body);
            if (resp.IsSuccessStatusCode)
            {
                _successMsg = _orgApproving
                    ? $"Verification approved for {_orgReviewing.Name}."
                    : $"Verification denied for {_orgReviewing.Name}.";
                CancelOrgReview();
                await LoadOrgAsync();
            }
            else
                _pageError = _orgApproving ? "Could not approve verification." : "Could not deny verification.";
        }
        catch { _pageError = "Could not submit review."; }
        finally { _saving = false; }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string StatusBadge(string? s) => s switch
    {
        "Pending"  => "bg-warning text-dark",
        "Approved" => "bg-success",
        "Denied"   => "bg-danger",
        _          => "bg-secondary"
    };

    private static string TierBadge(string? tier) => tier switch
    {
        "EnhancedTrusted"   => "bg-warning text-dark",
        "StandardEmployer"  => "bg-primary",
        _                   => "bg-secondary"
    };

    // ── Response models ───────────────────────────────────────────────────────

    private sealed class PagedIdentityResponse
    {
        public int Total { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public List<AdminVerificationRequestDto> Items { get; set; } = [];
    }

    private sealed class PagedOrgResponse
    {
        public int Total { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public List<OrgVerificationItem> Items { get; set; } = [];
    }

    private sealed class OrgVerificationItem
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string? OrgType { get; set; }
        public string? PendingTier { get; set; }
        public DateTime? VerificationPaidAt { get; set; }
        public string? PrimaryContactName { get; set; }
        public string? PrimaryContactEmail { get; set; }
        public string? PrimaryContactPhone { get; set; }
        public string? WebsiteUrl { get; set; }
        public string? LinkedInUrl { get; set; }
        public string? TwitterHandle { get; set; }
        public string? FacebookUrl { get; set; }
        public string? TikTokHandle { get; set; }
        public string? InstagramHandle { get; set; }
        public string? YouTubeUrl { get; set; }
        public string? RegisteredAddressLine1 { get; set; }
        public string? RegisteredCity { get; set; }
        public string? RegisteredState { get; set; }
        public string? RegisteredPostcode { get; set; }
        public string? RegisteredCountry { get; set; }
        public string? TaxRegistrationNumber { get; set; }
        public string? BusinessRegistrationNumber { get; set; }
    }
}
