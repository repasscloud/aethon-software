    private async Task RotateImportApiKey()
    {
        _importKeyMsg = null;
        _importKeyNewValue = null;
        _saving = true;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.PostAsync("/api/v1/admin/settings/import-api-key/rotate", null);
            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<RotateImportApiKeyResult>();
                _importKeySuccess    = true;
                _importKeyNewValue   = result?.NewKey;
                _importKeyConfigured = true;
                _importKeyStoredInDb  = true;
                _importKeyStoredInEnv = false;
                _importKeyMasked     = string.IsNullOrEmpty(result?.NewKey)
                    ? "••••••••"
                    : result.NewKey[..8] + "••••••••";
                _importKeyMsg = "Key rotated successfully.";
            }
            else
            {
                _importKeySuccess = false;
                _importKeyMsg = "Failed to rotate key.";
            }
        }
        catch
        {
            _importKeySuccess = false;
            _importKeyMsg = "Unable to reach settings service.";
        }
        finally { _saving = false; }
    }

