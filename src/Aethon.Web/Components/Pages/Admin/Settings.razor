            tasks.Add(client.PutAsJsonAsync("/api/v1/admin/settings/Email__FromEmail",         new { Value = _emailFromEmail }));
            tasks.Add(client.PutAsJsonAsync("/api/v1/admin/settings/Email__FromEmailSupport",  new { Value = _emailFromEmailSupport }));
            tasks.Add(client.PutAsJsonAsync("/api/v1/admin/settings/Email__FromName",          new { Value = _emailFromName }));
            tasks.Add(client.PutAsJsonAsync("/api/v1/admin/settings/Email__WebBaseUrl",        new { Value = _emailWebBaseUrl }));

