    private async Task DeleteTemplate(string name)
    {
        _saving = true;
        try
        {
            var client = await Api.CreateAsync();
            await client.DeleteAsync($"/api/v1/admin/settings/EmailTemplate__{name}__Subject");
            await client.DeleteAsync($"/api/v1/admin/settings/EmailTemplate__{name}__Html");
            _emailTemplates.RemoveAll(t => t.Name == name);
        }
        catch { /* ignore */ }
        finally { _saving = false; }
    }

    private void AddNewTemplate()
    {
        _newTemplateMsg = null;
        var name = _newTemplateName.Trim();
        if (string.IsNullOrEmpty(name))
        {
            _newTemplateMsg = "Template name is required.";
            return;
        }
        if (name.Contains(' ') || name.Contains("__"))
        {
            _newTemplateMsg = "Name must not contain spaces or double underscores.";
            return;
        }
        if (_emailTemplates.Any(t => t.Name.Equals(name, StringComparison.OrdinalIgnoreCase)))
        {
            _newTemplateMsg = "A template with that name already exists.";
            return;
        }
        _emailTemplates.Add(new EmailTemplateModel { Name = name });
        _newTemplateName = "";
    }

