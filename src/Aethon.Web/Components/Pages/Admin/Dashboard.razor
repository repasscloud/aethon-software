@page "/admin"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Security.Claims
@using System.Text.Json
@using Aethon.Shared.Auth
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AethonApiClient Api
@inject NavigationManager Nav

<PageTitle>Admin Dashboard | Aethon</PageTitle>

@if (!_isStaff)
{
    <div class="alert alert-danger rounded-4">Access denied.</div>
}
else if (!_ready)
{
    <div class="card border-0 shadow-sm rounded-4"><div class="card-body p-4">Loading…</div></div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h1 class="h3 fw-bold mb-1">Admin Dashboard</h1>
                <p class="text-secondary mb-0">Signed in as <strong>@_displayName</strong></p>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-6 col-xl-2">
                <a href="/admin/organisations" class="text-decoration-none">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="small text-secondary mb-1">Organisations</div>
                            <div class="fw-bold fs-2 text-dark">@_stats.Organisations</div>
                            <div class="small text-success mt-1">@_stats.VerifiedOrganisations verified</div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-6 col-xl-2">
                <a href="/admin/jobs" class="text-decoration-none">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="small text-secondary mb-1">Jobs</div>
                            <div class="fw-bold fs-2 text-dark">@_stats.Jobs</div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-6 col-xl-2">
                <a href="/admin/users" class="text-decoration-none">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="small text-secondary mb-1">Users</div>
                            <div class="fw-bold fs-2 text-dark">@_stats.Users</div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-6 col-xl-2">
                <a href="/admin/files" class="text-decoration-none">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="small text-secondary mb-1">Files</div>
                            <div class="fw-bold fs-2 text-dark">@_stats.Files</div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-6 col-xl-2">
                <a href="/admin/stripe-events" class="text-decoration-none">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="small text-secondary mb-1">Pending Stripe Events</div>
                            <div class="fw-bold fs-2 @(_stats.PendingStripeEvents > 0 ? "text-warning" : "text-dark")">@_stats.PendingStripeEvents</div>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        @if (!_stats.EmailConfigured)
        {
            <div class="card border-warning shadow-sm rounded-4">
                <div class="card-body p-4 d-flex align-items-center gap-3">
                    <span class="fs-3">⚠️</span>
                    <div>
                        <div class="fw-bold text-warning">Email is not configured</div>
                        <div class="small text-secondary">
                            MailerSendApiKey or FromEmail is missing. Transactional emails (verification, password reset) will not be sent.
                            Configure email settings in <a href="/admin/settings">Admin → Settings</a>.
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>
}

@code {
    private bool _ready;
    private bool _isSuperAdmin;
    private bool _isStaff;
    private string _displayName = "";
    private AdminStats _stats = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _displayName = user.FindFirstValue(AppClaimTypes.DisplayName) ?? "";
        _isSuperAdmin = string.Equals(user.FindFirstValue(AppClaimTypes.IsSuperAdmin), "true", StringComparison.OrdinalIgnoreCase);
        var isAdmin = string.Equals(user.FindFirstValue(AppClaimTypes.IsAdmin), "true", StringComparison.OrdinalIgnoreCase);
        var isSupport = string.Equals(user.FindFirstValue(AppClaimTypes.IsSupport), "true", StringComparison.OrdinalIgnoreCase);
        _isStaff = _isSuperAdmin || isAdmin || isSupport;

        if (!_isStaff) { _ready = true; return; }

        try
        {
            var client = await Api.CreateAsync();
            var json = await client.GetFromJsonAsync<JsonElement>("/api/v1/admin/stats", AethonApiClient.JsonOptions);
            _stats = new AdminStats
            {
                Organisations = json.GetProperty("organisations").GetInt32(),
                Jobs = json.GetProperty("jobs").GetInt32(),
                Users = json.GetProperty("users").GetInt32(),
                Files = json.GetProperty("files").GetInt32(),
                VerifiedOrganisations = json.GetProperty("verifiedOrganisations").GetInt32(),
                PendingStripeEvents = json.TryGetProperty("pendingStripeEvents", out var pse) ? pse.GetInt32() : 0,
            EmailConfigured = !json.TryGetProperty("emailConfigured", out var ec) || ec.GetBoolean()
            };
        }
        catch { }

        _ready = true;
    }

    private sealed class AdminStats
    {
        public int Organisations { get; set; }
        public int Jobs { get; set; }
        public int Users { get; set; }
        public int Files { get; set; }
        public int VerifiedOrganisations { get; set; }
        public int PendingStripeEvents { get; set; }
        public bool EmailConfigured { get; set; } = true;
    }
}
