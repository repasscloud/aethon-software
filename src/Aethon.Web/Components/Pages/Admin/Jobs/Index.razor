@page "/admin/jobs"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Security.Claims
@using Aethon.Shared.Auth
@using Aethon.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AethonApiClient Api
@inject NavigationManager Nav

<PageTitle>Jobs | Admin | Aethon</PageTitle>

@if (!_isStaff)
{
    <div class="alert alert-danger rounded-4">Access denied.</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex align-items-center gap-3 flex-wrap">
                <div class="flex-grow-1">
                    <h1 class="h4 fw-bold mb-0">All Jobs</h1>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <input class="form-control form-control-sm" style="width:200px;" placeholder="Search title…"
                           @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKey" />
                    <select class="form-select form-select-sm" style="width:160px;" @bind="_statusFilter" @bind:after="FilterChanged">
                        <option value="">All statuses</option>
                        @foreach (var s in Enum.GetValues<JobStatus>())
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-primary" @onclick="LoadAsync">Search</button>
                </div>
            </div>
        </div>

        @if (_loading)
        {
            <div class="card border-0 shadow-sm rounded-4"><div class="card-body p-4">Loading…</div></div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Title</th>
                                    <th>Organisation</th>
                                    <th>Status</th>
                                    <th>Category</th>
                                    <th>Apps</th>
                                    <th class="pe-4">Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_jobs.Count == 0)
                                {
                                    <tr><td colspan="6" class="ps-4 text-secondary py-4">No jobs found.</td></tr>
                                }
                                @foreach (var j in _jobs)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-semibold">@j.Title</div>
                                            <div class="text-secondary small">@j.LocationText &bull; @j.EmploymentType &bull; @j.WorkplaceType</div>
                                        </td>
                                        <td>
                                            <a href="/admin/organisations/@j.OrganisationId" class="text-decoration-none small">@j.OrganisationName</a>
                                        </td>
                                        <td><span class="badge @JobStatusBadge(j.Status) rounded-pill small">@j.Status</span></td>
                                        <td class="small text-secondary">@j.Category</td>
                                        <td>@j.ApplicationCount</td>
                                        <td class="pe-4 text-secondary small">@j.CreatedUtc?.ToString("dd MMM yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @if (_total > _pageSize)
            {
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-secondary small">@_total total</span>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">← Prev</button>
                        <span class="btn btn-sm disabled">@_page</span>
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_page * _pageSize >= _total)" @onclick="NextPage">Next →</button>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private bool _isSuperAdmin;
    private bool _isStaff;
    private bool _loading = true;
    private string _search = "";
    private string _statusFilter = "";
    private List<JobRow> _jobs = [];
    private int _total, _page = 1;
    private const int _pageSize = 50;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isSuperAdmin = string.Equals(user.FindFirstValue(AppClaimTypes.IsSuperAdmin), "true", StringComparison.OrdinalIgnoreCase);
        var isAdmin = string.Equals(user.FindFirstValue(AppClaimTypes.IsAdmin), "true", StringComparison.OrdinalIgnoreCase);
        var isSupport = string.Equals(user.FindFirstValue(AppClaimTypes.IsSupport), "true", StringComparison.OrdinalIgnoreCase);
        _isStaff = _isSuperAdmin || isAdmin || isSupport;
        if (_isStaff) await LoadAsync();
        else _loading = false;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var client = await Api.CreateAsync();
            var url = $"/api/v1/admin/jobs?page={_page}&search={Uri.EscapeDataString(_search)}"
                + (string.IsNullOrEmpty(_statusFilter) ? "" : $"&status={Uri.EscapeDataString(_statusFilter)}");
            var result = await client.GetFromJsonAsync<PagedResult<JobRow>>(url, AethonApiClient.JsonOptions);
            if (result is not null) { _jobs = result.Items; _total = result.Total; }
        }
        catch { _jobs = []; }
        _loading = false;
    }

    private async Task FilterChanged() { _page = 1; await LoadAsync(); }
    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }
    private async Task OnSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") { _page = 1; await LoadAsync(); } }

    private static string JobStatusBadge(string? s) => s switch
    {
        "Published" => "bg-success",
        "Draft" => "bg-secondary",
        "Closed" or "Cancelled" => "bg-danger",
        "OnHold" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private sealed record JobRow(Guid Id, string Title, string? Status, string? Visibility, string? Category,
        string? LocationText, string? EmploymentType, string? WorkplaceType,
        Guid OrganisationId, string OrganisationName, int ApplicationCount,
        DateTime? PublishedUtc, DateTime? CreatedUtc);

    private sealed class PagedResult<T>
    {
        public int Total { get; set; }
        public List<T> Items { get; set; } = [];
    }
}
