@page "/admin/ats-queue"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using System.Net.Http.Json
@using Aethon.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@inject AethonApiClient Api

<PageTitle>ATS Match Queue | Admin</PageTitle>

<div class="d-flex flex-column gap-4">

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 fw-bold mb-1">ATS Match Queue</h1>
            <p class="text-secondary mb-0">Monitor and manage the AI candidate matching queue.</p>
        </div>
    </div>

    @* ── Filters ── *@
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-sm-4">
                    <label class="form-label fw-semibold small">Status</label>
                    <select class="form-select rounded-4" @bind="_filterStatus">
                        <option value="">All</option>
                        <option value="Pending">Pending</option>
                        <option value="Processing">Processing</option>
                        <option value="Completed">Completed</option>
                        <option value="Failed">Failed</option>
                        <option value="Skipped">Skipped</option>
                    </select>
                </div>
                <div class="col-12 col-sm-4">
                    <label class="form-label fw-semibold small">Provider</label>
                    <select class="form-select rounded-4" @bind="_filterProvider">
                        <option value="">All</option>
                        <option value="Claude">Claude</option>
                        <option value="Ollama">Ollama</option>
                    </select>
                </div>
                <div class="col-12 col-sm-4">
                    <button class="btn btn-dark rounded-4 w-100" @onclick="LoadAsync">Search</button>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger rounded-4">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_actionMessage))
    {
        <div class="alert alert-success rounded-4">@_actionMessage</div>
    }

    @* ── Results table ── *@
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            @if (!_loaded)
            {
                <p class="text-secondary mb-0">Loading…</p>
            }
            else if (_items.Count == 0)
            {
                <p class="text-secondary mb-0">No queue items match the current filter.</p>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-secondary small">@_total total items</span>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle small mb-0">
                        <thead>
                            <tr>
                                <th>Application</th>
                                <th>Provider</th>
                                <th>Status</th>
                                <th class="text-center">Priority</th>
                                <th class="text-center">Attempts</th>
                                <th>Last Attempt</th>
                                <th>Error</th>
                                <th>Created</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _items)
                            {
                                <tr>
                                    <td class="font-monospace" style="font-size:0.75rem;">
                                        <a href="/app/applications/@item.JobApplicationId" target="_blank">@item.JobApplicationId.ToString()[..8]…</a>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill @(item.Provider == "Claude" ? "bg-primary-subtle text-primary" : "bg-secondary-subtle text-secondary")">
                                            @item.Provider
                                        </span>
                                    </td>
                                    <td>@((MarkupString)StatusBadge(item.Status))</td>
                                    <td class="text-center">@item.Priority</td>
                                    <td class="text-center">@item.Attempts</td>
                                    <td class="text-secondary">@(item.LastAttemptUtc?.ToLocalTime().ToString("dd MMM HH:mm") ?? "—")</td>
                                    <td class="text-danger" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@item.ErrorMessage">
                                        @(item.ErrorMessage ?? "—")
                                    </td>
                                    <td class="text-secondary">@item.CreatedUtc.ToLocalTime().ToString("dd MMM HH:mm")</td>
                                    <td class="text-end text-nowrap">
                                        @if (item.Status is "Failed" or "Processing")
                                        {
                                            <button class="btn btn-sm btn-outline-warning rounded-4 me-1"
                                                    disabled="@_busy"
                                                    @onclick="() => RetryAsync(item.Id)">
                                                Retry
                                            </button>
                                        }
                                        @if (item.Status == "Pending")
                                        {
                                            <button class="btn btn-sm btn-outline-secondary rounded-4"
                                                    disabled="@_busy"
                                                    @onclick="() => PromoteAsync(item.Id)">
                                                Promote
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (_items.Count < _total)
                {
                    <div class="mt-3 text-secondary small">Showing @_items.Count of @_total. Adjust filters to narrow results.</div>
                }
            }
        </div>
    </div>
</div>

@code {
    private bool _loaded;
    private bool _busy;
    private string? _error;
    private string? _actionMessage;
    private string _filterStatus   = "Pending";
    private string _filterProvider = "";

    private List<QueueItemRow> _items = [];
    private int _total;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loaded = false;
        _error  = null;
        _actionMessage = null;

        try
        {
            var client = await Api.CreateAsync();

            var qs = new List<string> { "pageSize=100" };
            if (!string.IsNullOrEmpty(_filterStatus))   qs.Add($"status={_filterStatus}");
            if (!string.IsNullOrEmpty(_filterProvider)) qs.Add($"provider={_filterProvider}");

            var response = await client.GetAsync($"/api/v1/admin/ats-queue?{string.Join("&", qs)}");

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not load ATS queue.";
                return;
            }

            var data = await response.Content.ReadFromJsonAsync<QueueResponse>(AethonApiClient.JsonOptions);
            _items = data?.Items ?? [];
            _total = data?.Total ?? 0;
        }
        catch
        {
            _error = "Could not load ATS queue.";
        }
        finally
        {
            _loaded = true;
        }
    }

    private async Task RetryAsync(Guid id)
    {
        _busy = true;
        _actionMessage = null;
        _error = null;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsync($"/api/v1/admin/ats-queue/{id}/retry", null);

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not retry item.";
                return;
            }

            _actionMessage = "Item reset to Pending.";
            await LoadAsync();
        }
        catch
        {
            _error = "Could not retry item.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task PromoteAsync(Guid id)
    {
        _busy = true;
        _actionMessage = null;
        _error = null;

        try
        {
            var client = await Api.CreateAsync();
            var response = await client.PostAsync($"/api/v1/admin/ats-queue/{id}/promote", null);

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not promote item.";
                return;
            }

            _actionMessage = "Item priority increased.";
            await LoadAsync();
        }
        catch
        {
            _error = "Could not promote item.";
        }
        finally
        {
            _busy = false;
        }
    }

    private static string StatusBadge(string status) => status switch
    {
        "Completed"  => "<span class=\"badge rounded-pill bg-success-subtle text-success\">Completed</span>",
        "Failed"     => "<span class=\"badge rounded-pill bg-danger-subtle text-danger\">Failed</span>",
        "Processing" => "<span class=\"badge rounded-pill bg-info-subtle text-info\">Processing</span>",
        "Pending"    => "<span class=\"badge rounded-pill bg-warning-subtle text-warning\">Pending</span>",
        _            => $"<span class=\"badge rounded-pill bg-secondary-subtle text-secondary\">{status}</span>"
    };

    private sealed class QueueResponse
    {
        public int Total    { get; set; }
        public int Page     { get; set; }
        public int PageSize { get; set; }
        public List<QueueItemRow> Items { get; set; } = [];
    }

    private sealed class QueueItemRow
    {
        public Guid     Id               { get; set; }
        public Guid     JobApplicationId { get; set; }
        public Guid     JobId            { get; set; }
        public Guid     CandidateUserId  { get; set; }
        public string   Provider         { get; set; } = "";
        public int      Priority         { get; set; }
        public string   Status           { get; set; } = "";
        public int      Attempts         { get; set; }
        public DateTime? LastAttemptUtc  { get; set; }
        public string?  ErrorMessage     { get; set; }
        public DateTime CreatedUtc       { get; set; }
        public DateTime? ProcessedUtc    { get; set; }
    }
}
