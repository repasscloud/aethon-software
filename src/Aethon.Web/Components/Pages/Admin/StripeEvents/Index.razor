@page "/admin/stripe-events"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Security.Claims
@using Aethon.Shared.Auth
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AethonApiClient Api

<PageTitle>Stripe Events | Admin | Aethon</PageTitle>

@if (!_isStaff)
{
    <div class="alert alert-danger rounded-4">Access denied.</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex align-items-center gap-3 flex-wrap">
                <div class="flex-grow-1">
                    <h1 class="h4 fw-bold mb-0">Stripe Events</h1>
                </div>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm" style="width:150px;" @bind="_statusFilter" @bind:after="FilterChanged">
                        <option value="">All</option>
                        <option value="Pending">Pending</option>
                        <option value="Reviewed">Reviewed</option>
                        <option value="Completed">Completed</option>
                    </select>
                    <button class="btn btn-sm btn-primary" @onclick="LoadAsync">Refresh</button>
                </div>
            </div>
        </div>

        @if (_loading)
        {
            <div class="card border-0 shadow-sm rounded-4"><div class="card-body p-4">Loading…</div></div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Event</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                    <th>Customer</th>
                                    <th>Status</th>
                                    <th>Received</th>
                                    <th class="pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_events.Count == 0)
                                {
                                    <tr><td colspan="7" class="ps-4 text-secondary py-4">No events found.</td></tr>
                                }
                                @foreach (var e in _events)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-semibold small">@e.StripeEventId</div>
                                        </td>
                                        <td class="small text-secondary">@e.EventType</td>
                                        <td class="small">@FormatAmount(e.AmountTotal, e.Currency)</td>
                                        <td class="small text-secondary">@(e.CustomerEmail ?? "—")</td>
                                        <td>
                                            <span class="badge @StatusBadge(e.Status) rounded-pill small">@e.Status</span>
                                        </td>
                                        <td class="small text-secondary">@e.CreatedUtc?.ToString("dd MMM yyyy HH:mm")</td>
                                        <td class="pe-4">
                                            @if (e.Status != "Completed")
                                            {
                                                <button class="btn btn-xs btn-outline-success rounded-pill" style="font-size:.75rem;padding:.2rem .6rem;"
                                                        @onclick="@(() => OpenModal(e))">Review</button>
                                            }
                                            else
                                            {
                                                <span class="text-secondary small">—</span>
                                            }
                                        </td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(e.InternalNotes))
                                    {
                                        <tr class="table-light">
                                            <td colspan="7" class="ps-4 pe-4 py-2 small text-secondary">
                                                <i class="bi bi-chat-left-text me-1"></i>@e.InternalNotes
                                                @if (e.CompletedUtc.HasValue)
                                                {
                                                    <span class="ms-2">— completed @e.CompletedUtc.Value.ToString("dd MMM yyyy")</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @if (_total > _pageSize)
            {
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-secondary small">@_total total</span>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">← Prev</button>
                        <span class="btn btn-sm disabled">@_page</span>
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_page * _pageSize >= _total)" @onclick="NextPage">Next →</button>
                    </div>
                </div>
            }
        }
    </div>
}

@if (_modalEvent is not null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Review event</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <div class="small text-secondary mb-1">Stripe Event ID</div>
                        <code class="small">@_modalEvent.StripeEventId</code>
                    </div>
                    <div class="mb-3">
                        <div class="small text-secondary mb-1">Type</div>
                        <div class="small">@_modalEvent.EventType</div>
                    </div>
                    <div class="mb-3">
                        <div class="small text-secondary mb-1">Amount</div>
                        <div class="small">@FormatAmount(_modalEvent.AmountTotal, _modalEvent.Currency)</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Status</label>
                        <select class="form-select form-select-sm" @bind="_modalStatus">
                            <option value="Pending">Pending</option>
                            <option value="Reviewed">Reviewed</option>
                            <option value="Completed">Completed</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Internal notes</label>
                        <textarea class="form-control form-control-sm" rows="3" @bind="_modalNotes"></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(_modalMessage))
                    {
                        <div class="alert @(_modalSuccess ? "alert-success" : "alert-danger") rounded-3 py-2 small">@_modalMessage</div>
                    }
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-secondary btn-sm rounded-pill" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary btn-sm rounded-pill" @onclick="SaveModal" disabled="@_modalSaving">
                        @(_modalSaving ? "Saving…" : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _isStaff;
    private bool _loading = true;
    private string _statusFilter = "Pending";
    private List<EventRow> _events = [];
    private int _total, _page = 1;
    private const int _pageSize = 50;

    private EventRow? _modalEvent;
    private string _modalStatus = "Pending";
    private string _modalNotes = "";
    private bool _modalSaving;
    private string? _modalMessage;
    private bool _modalSuccess;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var isSuperAdmin = string.Equals(user.FindFirstValue(AppClaimTypes.IsSuperAdmin), "true", StringComparison.OrdinalIgnoreCase);
        var isAdmin = string.Equals(user.FindFirstValue(AppClaimTypes.IsAdmin), "true", StringComparison.OrdinalIgnoreCase);
        var isSupport = string.Equals(user.FindFirstValue(AppClaimTypes.IsSupport), "true", StringComparison.OrdinalIgnoreCase);
        _isStaff = isSuperAdmin || isAdmin || isSupport;
        if (_isStaff) await LoadAsync();
        else _loading = false;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var client = await Api.CreateAsync();
            var url = $"/api/v1/admin/stripe-events?page={_page}&status={Uri.EscapeDataString(_statusFilter)}";
            var result = await client.GetFromJsonAsync<PagedResult<EventRow>>(url, AethonApiClient.JsonOptions);
            if (result is not null) { _events = result.Items; _total = result.Total; }
        }
        catch { _events = []; }
        _loading = false;
    }

    private async Task FilterChanged() { _page = 1; await LoadAsync(); }
    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }

    private void OpenModal(EventRow e)
    {
        _modalEvent = e;
        _modalStatus = e.Status ?? "Pending";
        _modalNotes = e.InternalNotes ?? "";
        _modalMessage = null;
        _modalSuccess = false;
    }

    private void CloseModal() => _modalEvent = null;

    private async Task SaveModal()
    {
        if (_modalEvent is null) return;
        _modalSaving = true;
        _modalMessage = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.PutAsJsonAsync(
                $"/api/v1/admin/stripe-events/{_modalEvent.Id}",
                new { status = _modalStatus, internalNotes = _modalNotes },
                AethonApiClient.JsonOptions);
            if (resp.IsSuccessStatusCode)
            {
                _modalSuccess = true;
                _modalMessage = "Saved.";
                await LoadAsync();
                await Task.Delay(800);
                _modalEvent = null;
            }
            else
            {
                _modalSuccess = false;
                _modalMessage = "Failed to save.";
            }
        }
        catch
        {
            _modalSuccess = false;
            _modalMessage = "An error occurred.";
        }
        _modalSaving = false;
    }

    private static string StatusBadge(string? s) => s switch
    {
        "Completed" => "bg-success",
        "Reviewed" => "bg-info text-dark",
        _ => "bg-warning text-dark"
    };

    private static string FormatAmount(long? cents, string? currency)
    {
        if (cents is null) return "—";
        var val = cents.Value / 100.0;
        var curr = currency?.ToUpperInvariant() ?? "";
        return $"{curr} {val:F2}";
    }

    private sealed record EventRow(Guid Id, string StripeEventId, string EventType,
        long? AmountTotal, string? Currency, string? CustomerEmail,
        string? Status, string? InternalNotes, Guid? CompletedByUserId, DateTime? CompletedUtc,
        DateTime? CreatedUtc);

    private sealed class PagedResult<T>
    {
        public int Total { get; set; }
        public List<T> Items { get; set; } = [];
    }
}
