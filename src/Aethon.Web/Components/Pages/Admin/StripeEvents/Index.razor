@page "/admin/stripe-events"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Security.Claims
@using System.Text.Json
@using Aethon.Shared.Auth
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AethonApiClient Api

<PageTitle>Stripe Events | Admin | Aethon</PageTitle>

@if (!_isStaff)
{
    <div class="alert alert-danger rounded-4">Access denied.</div>
}
else
{
    <div class="d-flex flex-column gap-4">

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex align-items-center gap-3 flex-wrap">
                <div class="flex-grow-1">
                    <h1 class="h4 fw-bold mb-0">Stripe Events</h1>
                </div>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm" style="width:150px;" @bind="_statusFilter" @bind:after="FilterChanged">
                        <option value="">All</option>
                        <option value="Pending">Pending</option>
                        <option value="Reviewed">Reviewed</option>
                        <option value="Completed">Completed</option>
                        <option value="Failed">Failed</option>
                    </select>
                    <button class="btn btn-sm btn-primary" @onclick="LoadAsync">Refresh</button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_actionMessage))
        {
            <div class="alert @(_actionSuccess ? "alert-success" : "alert-danger") rounded-4 py-2">@_actionMessage</div>
        }

        @if (_loading)
        {
            <div class="card border-0 shadow-sm rounded-4"><div class="card-body p-4">Loading…</div></div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Event</th>
                                    <th>Organisation</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Received</th>
                                    <th class="pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_events.Count == 0)
                                {
                                    <tr><td colspan="7" class="ps-4 text-secondary py-4">No events found.</td></tr>
                                }
                                @foreach (var e in _events)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-semibold small">@e.StripeEventId</div>
                                            @if (!string.IsNullOrEmpty(e.PurchaseType))
                                            {
                                                <div class="text-secondary" style="font-size:.7rem;">@e.PurchaseType</div>
                                            }
                                        </td>
                                        <td class="small">
                                            @if (e.OrganisationId.HasValue && !string.IsNullOrEmpty(e.OrganisationName))
                                            {
                                                <a href="/admin/organisations/@e.OrganisationId" class="text-decoration-none fw-semibold">@e.OrganisationName</a>
                                            }
                                            else if (!string.IsNullOrEmpty(e.CustomerEmail))
                                            {
                                                <span class="text-secondary">@e.CustomerEmail</span>
                                            }
                                            else
                                            {
                                                <span class="text-secondary">—</span>
                                            }
                                        </td>
                                        <td class="small text-secondary">@e.EventType</td>
                                        <td class="small">@FormatAmount(e.AmountTotal, e.Currency)</td>
                                        <td>
                                            <span class="badge @StatusBadge(e.Status) rounded-pill small">@e.Status</span>
                                        </td>
                                        <td class="small text-secondary">@e.CreatedUtc?.ToString("dd MMM yyyy HH:mm")</td>
                                        <td class="pe-4">
                                            <div class="d-flex gap-1 flex-wrap">
                                                @if (IsVerificationPending(e))
                                                {
                                                    <button class="btn btn-outline-success rounded-pill" style="font-size:.75rem;padding:.2rem .6rem;"
                                                            @onclick="@(() => OpenApproveModal(e))">Approve</button>
                                                    <button class="btn btn-outline-danger rounded-pill" style="font-size:.75rem;padding:.2rem .6rem;"
                                                            @onclick="@(() => OpenRejectModal(e))">Reject</button>
                                                }
                                                else if (e.Status != "Completed" && e.Status != "Failed")
                                                {
                                                    <button class="btn btn-outline-secondary rounded-pill" style="font-size:.75rem;padding:.2rem .6rem;"
                                                            @onclick="@(() => OpenModal(e))">Review</button>
                                                }
                                                else
                                                {
                                                    <span class="text-secondary small">—</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(e.InternalNotes))
                                    {
                                        <tr class="table-light">
                                            <td colspan="7" class="ps-4 pe-4 py-2 small text-secondary">
                                                <i class="bi bi-chat-left-text me-1"></i>@e.InternalNotes
                                                @if (e.CompletedUtc.HasValue)
                                                {
                                                    <span class="ms-2">— @e.CompletedUtc.Value.ToString("dd MMM yyyy")</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @if (_total > _pageSize)
            {
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-secondary small">@_total total</span>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">← Prev</button>
                        <span class="btn btn-sm disabled">@_page</span>
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_page * _pageSize >= _total)" @onclick="NextPage">Next →</button>
                    </div>
                </div>
            }
        }
    </div>
}

@* ── Generic review modal ── *@
@if (_modalEvent is not null && _modalMode == "review")
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Review event</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <div class="small text-secondary mb-1">Stripe Event ID</div>
                        <code class="small">@_modalEvent.StripeEventId</code>
                    </div>
                    <div class="mb-3">
                        <div class="small text-secondary mb-1">Organisation</div>
                        <div class="small">@(_modalEvent.OrganisationName ?? _modalEvent.CustomerEmail ?? "—")</div>
                    </div>
                    <div class="mb-3">
                        <div class="small text-secondary mb-1">Amount</div>
                        <div class="small">@FormatAmount(_modalEvent.AmountTotal, _modalEvent.Currency)</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Status</label>
                        <select class="form-select form-select-sm" @bind="_modalStatus">
                            <option value="Pending">Pending</option>
                            <option value="Reviewed">Reviewed</option>
                            <option value="Completed">Completed</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Internal notes</label>
                        <textarea class="form-control form-control-sm" rows="3" @bind="_modalNotes"></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(_modalMessage))
                    {
                        <div class="alert @(_modalSuccess ? "alert-success" : "alert-danger") rounded-3 py-2 small">@_modalMessage</div>
                    }
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-secondary btn-sm rounded-pill" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary btn-sm rounded-pill" @onclick="SaveModal" disabled="@_modalSaving">
                        @(_modalSaving ? "Saving…" : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Approve verification modal ── *@
@if (_modalEvent is not null && _modalMode == "approve")
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Approve verification</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning rounded-3 small mb-3">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        This will set <strong>@(_modalEvent.OrganisationName ?? "this organisation")</strong> to
                        <strong>@GetVerificationTierLabel(_modalEvent)</strong> and convert any unused launch promo credits to Premium.
                    </div>
                    @if (!string.IsNullOrEmpty(_modalMessage))
                    {
                        <div class="alert @(_modalSuccess ? "alert-success" : "alert-danger") rounded-3 py-2 small">@_modalMessage</div>
                    }
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-secondary btn-sm rounded-pill" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-success btn-sm rounded-pill" @onclick="ApproveVerification" disabled="@_modalSaving">
                        @(_modalSaving ? "Approving…" : "Approve")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Reject verification modal ── *@
@if (_modalEvent is not null && _modalMode == "reject")
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Reject verification</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Reason (optional — shown in notes)</label>
                        <textarea class="form-control form-control-sm" rows="3" @bind="_rejectReason"
                                  placeholder="e.g. Could not verify business registration number."></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(_modalMessage))
                    {
                        <div class="alert @(_modalSuccess ? "alert-success" : "alert-danger") rounded-3 py-2 small">@_modalMessage</div>
                    }
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-secondary btn-sm rounded-pill" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-danger btn-sm rounded-pill" @onclick="RejectVerification" disabled="@_modalSaving">
                        @(_modalSaving ? "Rejecting…" : "Reject")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _isStaff;
    private bool _loading = true;
    private string _statusFilter = "Pending";
    private List<EventRow> _events = [];
    private int _total, _page = 1;
    private const int _pageSize = 50;

    private EventRow? _modalEvent;
    private string _modalMode = "review"; // "review" | "approve" | "reject"
    private string _modalStatus = "Pending";
    private string _modalNotes = "";
    private string _rejectReason = "";
    private bool _modalSaving;
    private string? _modalMessage;
    private bool _modalSuccess;

    private string? _actionMessage;
    private bool _actionSuccess;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var isSuperAdmin = string.Equals(user.FindFirstValue(AppClaimTypes.IsSuperAdmin), "true", StringComparison.OrdinalIgnoreCase);
        var isAdmin = string.Equals(user.FindFirstValue(AppClaimTypes.IsAdmin), "true", StringComparison.OrdinalIgnoreCase);
        var isSupport = string.Equals(user.FindFirstValue(AppClaimTypes.IsSupport), "true", StringComparison.OrdinalIgnoreCase);
        _isStaff = isSuperAdmin || isAdmin || isSupport;
        if (_isStaff) await LoadAsync();
        else _loading = false;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _actionMessage = null;
        try
        {
            var client = await Api.CreateAsync();
            var url = $"/api/v1/admin/stripe-events?page={_page}&status={Uri.EscapeDataString(_statusFilter)}";
            var result = await client.GetFromJsonAsync<PagedResult<EventRow>>(url, AethonApiClient.JsonOptions);
            if (result is not null) { _events = result.Items; _total = result.Total; }
        }
        catch { _events = []; }
        _loading = false;
    }

    private async Task FilterChanged() { _page = 1; await LoadAsync(); }
    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }

    private void OpenModal(EventRow e)
    {
        _modalEvent = e;
        _modalMode = "review";
        _modalStatus = e.Status ?? "Pending";
        _modalNotes = e.InternalNotes ?? "";
        _modalMessage = null;
        _modalSuccess = false;
    }

    private void OpenApproveModal(EventRow e)
    {
        _modalEvent = e;
        _modalMode = "approve";
        _modalMessage = null;
        _modalSuccess = false;
    }

    private void OpenRejectModal(EventRow e)
    {
        _modalEvent = e;
        _modalMode = "reject";
        _rejectReason = "";
        _modalMessage = null;
        _modalSuccess = false;
    }

    private void CloseModal() => _modalEvent = null;

    private async Task SaveModal()
    {
        if (_modalEvent is null) return;
        _modalSaving = true;
        _modalMessage = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.PutAsJsonAsync(
                $"/api/v1/admin/stripe-events/{_modalEvent.Id}",
                new { status = _modalStatus, internalNotes = _modalNotes },
                AethonApiClient.JsonOptions);
            if (resp.IsSuccessStatusCode)
            {
                _modalSuccess = true;
                _modalMessage = "Saved.";
                await LoadAsync();
                await Task.Delay(800);
                _modalEvent = null;
            }
            else
            {
                _modalSuccess = false;
                _modalMessage = "Failed to save.";
            }
        }
        catch
        {
            _modalSuccess = false;
            _modalMessage = "An error occurred.";
        }
        _modalSaving = false;
    }

    private async Task ApproveVerification()
    {
        if (_modalEvent is null) return;
        _modalSaving = true;
        _modalMessage = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.PostAsync(
                $"/api/v1/admin/stripe-events/{_modalEvent.Id}/approve-verification", null);
            if (resp.IsSuccessStatusCode)
            {
                _actionSuccess = true;
                _actionMessage = $"Verification approved for {_modalEvent.OrganisationName ?? "organisation"}.";
                _modalEvent = null;
                await LoadAsync();
            }
            else
            {
                _modalSuccess = false;
                _modalMessage = "Failed to approve. Check the event has a valid organisation.";
            }
        }
        catch
        {
            _modalSuccess = false;
            _modalMessage = "An error occurred.";
        }
        _modalSaving = false;
    }

    private async Task RejectVerification()
    {
        if (_modalEvent is null) return;
        _modalSaving = true;
        _modalMessage = null;
        try
        {
            var client = await Api.CreateAsync();
            var resp = await client.PostAsJsonAsync(
                $"/api/v1/admin/stripe-events/{_modalEvent.Id}/reject-verification",
                new { reason = _rejectReason },
                AethonApiClient.JsonOptions);
            if (resp.IsSuccessStatusCode)
            {
                _actionSuccess = true;
                _actionMessage = $"Verification rejected for {_modalEvent.OrganisationName ?? "organisation"}.";
                _modalEvent = null;
                await LoadAsync();
            }
            else
            {
                _modalSuccess = false;
                _modalMessage = "Failed to reject.";
            }
        }
        catch
        {
            _modalSuccess = false;
            _modalMessage = "An error occurred.";
        }
        _modalSaving = false;
    }

    private static bool IsVerificationPending(EventRow e) =>
        e.Status == "Pending" &&
        (e.PurchaseType == "verification" || e.PurchaseType == "bundle_verification_post");

    private static string GetVerificationTierLabel(EventRow e)
    {
        if (string.IsNullOrEmpty(e.PurchaseMetaJson)) return "Standard Employer";
        try
        {
            var meta = JsonSerializer.Deserialize<Dictionary<string, string>>(e.PurchaseMetaJson);
            if (meta?.TryGetValue("verification_tier", out var t) == true && t == "enhanced")
                return "Enhanced Trusted Employer";
        }
        catch { }
        return "Standard Employer";
    }

    private static string StatusBadge(string? s) => s switch
    {
        "Completed" => "bg-success",
        "Reviewed"  => "bg-info text-dark",
        "Failed"    => "bg-danger",
        _           => "bg-warning text-dark"
    };

    private static string FormatAmount(long? cents, string? currency)
    {
        if (cents is null) return "—";
        var val = cents.Value / 100.0;
        var curr = currency?.ToUpperInvariant() ?? "";
        return $"{curr} {val:F2}";
    }

    private sealed record EventRow(
        Guid Id, string StripeEventId, string EventType,
        long? AmountTotal, string? Currency, string? CustomerEmail,
        string? Status, string? InternalNotes, Guid? CompletedByUserId, DateTime? CompletedUtc,
        DateTime? CreatedUtc, Guid? OrganisationId, string? OrganisationName,
        string? PurchaseType, string? PurchaseMetaJson);

    private sealed class PagedResult<T>
    {
        public int Total { get; set; }
        public List<T> Items { get; set; } = [];
    }
}
