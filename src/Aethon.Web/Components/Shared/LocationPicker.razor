@using System.Net.Http.Json
@using Aethon.Shared.Locations
@inject AethonApiClient Api
@implements IDisposable

<div class="location-picker-wrapper position-relative">
    <input type="text"
           class="form-control rounded-3"
           placeholder="@Placeholder"
           value="@_inputText"
           @oninput="OnInputChanged"
           @onfocusout="OnFocusOut"
           autocomplete="off" />

    @if (_showDropdown && _suggestions?.Count > 0)
    {
        <div class="position-absolute w-100 bg-white border rounded-3 shadow mt-1" style="z-index:1050; max-height:220px; overflow-y:auto;">
            @foreach (var loc in _suggestions)
            {
                <button type="button"
                        class="btn btn-link text-start text-dark w-100 border-0 rounded-0 py-2 px-3 text-decoration-none"
                        style="font-size:.9rem;"
                        @onmousedown="() => SelectLocation(loc)">
                    <i class="bi bi-geo-alt-fill text-danger me-2"></i>@loc.DisplayName
                </button>
            }
        </div>
    }

    @if (_searching)
    {
        <div class="form-text text-secondary mt-1">
            <span class="spinner-border spinner-border-sm me-1"></span>Searching…
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(LocationCity) || !string.IsNullOrWhiteSpace(LocationCountry))
    {
        <div class="form-text text-success mt-1">
            <i class="bi bi-geo-alt-fill me-1"></i>
            @LocationCity@(!string.IsNullOrWhiteSpace(LocationCity) && !string.IsNullOrWhiteSpace(LocationState) ? ", " : "")@LocationState@(!string.IsNullOrWhiteSpace(LocationCountry) ? " · " + LocationCountry : "")
            @if (LocationLatitude.HasValue)
            {
                <span class="text-secondary ms-2 small">(@LocationLatitude.Value.ToString("F4"), @LocationLongitude!.Value.ToString("F4"))</span>
            }
        </div>
    }
</div>

@code {
    private string? _inputText;
    private List<LocationDto>? _suggestions;
    private bool _showDropdown;
    private bool _searching;
    private CancellationTokenSource? _cts;

    [Parameter] public string? LocationText { get; set; }
    [Parameter] public EventCallback<string?> LocationTextChanged { get; set; }

    [Parameter] public string? LocationCity { get; set; }
    [Parameter] public EventCallback<string?> LocationCityChanged { get; set; }

    [Parameter] public string? LocationState { get; set; }
    [Parameter] public EventCallback<string?> LocationStateChanged { get; set; }

    [Parameter] public string? LocationCountry { get; set; }
    [Parameter] public EventCallback<string?> LocationCountryChanged { get; set; }

    [Parameter] public string? LocationCountryCode { get; set; }
    [Parameter] public EventCallback<string?> LocationCountryCodeChanged { get; set; }

    [Parameter] public double? LocationLatitude { get; set; }
    [Parameter] public EventCallback<double?> LocationLatitudeChanged { get; set; }

    [Parameter] public double? LocationLongitude { get; set; }
    [Parameter] public EventCallback<double?> LocationLongitudeChanged { get; set; }

    [Parameter] public string? LocationPlaceId { get; set; }
    [Parameter] public EventCallback<string?> LocationPlaceIdChanged { get; set; }

    [Parameter] public string Placeholder { get; set; } = "Start typing a city...";

    protected override void OnParametersSet()
    {
        if (_inputText != LocationText)
            _inputText = LocationText;
    }

    private async Task OnInputChanged(ChangeEventArgs e)
    {
        var text = e.Value?.ToString() ?? "";
        _inputText = text;

        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        if (string.IsNullOrWhiteSpace(text))
        {
            _suggestions = null;
            _showDropdown = false;
            await ClearLocationAsync();
            return;
        }

        if (text.Length < 2)
        {
            _suggestions = null;
            _showDropdown = false;
            return;
        }

        try
        {
            await Task.Delay(250, token);
            _searching = true;

            var client = await Api.CreateAsync();
            var results = await client.GetFromJsonAsync<List<LocationDto>>(
                $"/api/v1/public/locations?q={Uri.EscapeDataString(text)}",
                AethonApiClient.JsonOptions, token);

            _suggestions = results ?? [];
            _showDropdown = _suggestions.Count > 0;
        }
        catch (OperationCanceledException) { }
        catch
        {
            _suggestions = null;
            _showDropdown = false;
        }
        finally
        {
            _searching = false;
        }
    }

    // Use onmousedown (fires before onfocusout) so the click registers before the dropdown hides
    private async Task SelectLocation(LocationDto loc)
    {
        _inputText = loc.DisplayName;
        _showDropdown = false;
        _suggestions = null;

        await LocationTextChanged.InvokeAsync(loc.DisplayName);
        await LocationCityChanged.InvokeAsync(loc.City);
        await LocationStateChanged.InvokeAsync(loc.State);
        await LocationCountryChanged.InvokeAsync(loc.Country);
        await LocationCountryCodeChanged.InvokeAsync(loc.CountryCode);
        await LocationLatitudeChanged.InvokeAsync(loc.Latitude);
        await LocationLongitudeChanged.InvokeAsync(loc.Longitude);
        await LocationPlaceIdChanged.InvokeAsync(loc.Id.ToString());
    }

    private async Task OnFocusOut()
    {
        // Small delay so onmousedown on dropdown items fires first
        await Task.Delay(200);
        _showDropdown = false;

        if (!string.IsNullOrWhiteSpace(_inputText))
            await LocationTextChanged.InvokeAsync(_inputText);
    }

    private async Task ClearLocationAsync()
    {
        await LocationTextChanged.InvokeAsync(null);
        await LocationCityChanged.InvokeAsync(null);
        await LocationStateChanged.InvokeAsync(null);
        await LocationCountryChanged.InvokeAsync(null);
        await LocationCountryCodeChanged.InvokeAsync(null);
        await LocationLatitudeChanged.InvokeAsync(null);
        await LocationLongitudeChanged.InvokeAsync(null);
        await LocationPlaceIdChanged.InvokeAsync(null);
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
