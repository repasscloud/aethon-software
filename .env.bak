# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# JWT signing key — must be at least 32 characters, keep secret
Auth__JwtKey=mOmjIKlkJZfBZCTAgMFVxJbm12mmF14hkt5m0fb0V5Vcscg8

# DataProtection key encryption certificate (X.509 PFX, base64-encoded).
# Generate once with: ./generate-dp-cert.sh
# Reuse the same value across all instances sharing the /keys volume.
DataProtection__

# ── Optional — leave blank to disable ─────────────────────────────────────────

# MailerSend API key for transactional email (invites, claim tokens, apply confirmations)
Email__MailerSendApiKey=

# Claude (Anthropic) API key for resume intelligence
Claude__ApiKey=

# ── Defaults (override if needed) ─────────────────────────────────────────────
Auth__Issuer=aethon-api
Auth__Audience=aethon-web
Email__MailerSendApiKey=mlsn.eada98bba516082eda2cbf68827a5502c7508716cc0f9af811053848f7e25d18
Email__FromEmail=do-not-reply@repasscloud.com
Email__FromName="Aethon Software"
Email__WebBaseUrl=https://dev.app.aethonsoftware.com
GooglePlaces__ApiKey=yAIzaSyD6QFWuxdwlj6avDT729JK_Kh50dylbWaw

# Stripe secret key (from Stripe Dashboard → Developers → API keys)
