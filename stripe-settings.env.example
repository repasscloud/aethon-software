# Secret API Key
Stripe.SecretKey=sk_test_xxx

# Webhook
Stripe.WebhookSecret=whsec_123

# Verification
Stripe.Price.VerificationStandard=price_standard_verification
Stripe.Price.VerificationEnhanced=price_enhanced_verification

# Bundles
Stripe.Price.Bundle.StandardVerificationPost=price_bundle_standard
Stripe.Price.Bundle.EnhancedVerificationPost=price_bundle_enhanced

# Job Credits - Standard
Stripe.Price.Job.Standard.1x=price_std_1
Stripe.Price.Job.Standard.5x=price_std_5
Stripe.Price.Job.Standard.10x=price_std_10
Stripe.Price.Job.Standard.20x=price_std_20

# Job Credits - Premium
Stripe.Price.Job.Premium.1x=price_prem_1
Stripe.Price.Job.Premium.5x=price_prem_5
Stripe.Price.Job.Premium.10x=price_prem_10
Stripe.Price.Job.Premium.20x=price_prem_20

# Sticky - Verified
Stripe.Price.Sticky.Verified.24h=abc
Stripe.Price.Sticky.Verified.7d=xyz
Stripe.Price.Sticky.Verified.30d=qwe

# Sticky - Unverified
Stripe.Price.Sticky.Unverified.24h=aaa
Stripe.Price.Sticky.Unverified.7d=bbb
Stripe.Price.Sticky.Unverified.30d=ccc

# Add-ons
Stripe.Price.Addon.Highlight=price_highlight
Stripe.Price.Addon.Video=price_video
Stripe.Price.Addon.AiMatching=price_ai

# ── Display Prices ────────────────────────────────────────────────────────────
# Plain numbers (no currency symbol). Shown as A$xx in the UI.
# Update these whenever Stripe pricing changes.

Display.Price.Job.Standard.1x=0
Display.Price.Job.Standard.5x=0
Display.Price.Job.Standard.10x=0
Display.Price.Job.Standard.20x=0

Display.Price.Job.Premium.1x=0
Display.Price.Job.Premium.5x=0
Display.Price.Job.Premium.10x=0
Display.Price.Job.Premium.20x=0

Display.Price.Verification.Standard=0
Display.Price.Verification.Enhanced=0
Display.Price.Bundle.StandardVerificationPost=0
Display.Price.Bundle.EnhancedVerificationPost=0

Display.Price.Addon.Highlight=0
Display.Price.Addon.Video=0
Display.Price.Addon.AiMatching=0

Display.Price.Sticky.Verified.24h=0
Display.Price.Sticky.Verified.7d=0
Display.Price.Sticky.Verified.30d=0
Display.Price.Sticky.Unverified.24h=0
