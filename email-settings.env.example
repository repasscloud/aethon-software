# email-settings.env.example
#
# Copy to email-settings.env (gitignored), fill in your values, then run:
#   ./seed-email-settings.zsh email-settings.env
#
# Keys are pushed to the DB via PUT /api/v1/admin/settings/{key}.
# DB settings take priority over environment variables at runtime.

# ── Email service ─────────────────────────────────────────────────────────────
# MailerSend API key — SuperAdmin required to write this key.
Email__MailerSendApiKey=mlsn.xxxx

# Sender identity for automated transactional emails
Email__FromEmail=do-not-reply@example.com
Email__FromName=Aethon Software

# Sender identity for admin-composed emails (used in Compose Email page, also set as reply-to)
Email__FromEmailSupport=support@example.com

# Base URL used to build links in emails (no trailing slash)
Email__WebBaseUrl=https://app.example.com

# ── Email templates (optional overrides) ──────────────────────────────────────
# Leave these commented out to use the built-in defaults.
# Uncomment and fill in to override a system template.
# Use {{VarName}} tokens for dynamic substitution.

# Email__Verification__Subject=Verify your Aethon account
# Email__Verification__Html=<full html — paste from your design tool>

# EmailTemplate__PasswordReset__Subject=Reset your Aethon password
# EmailTemplate__PasswordReset__Html=<full html>

# EmailTemplate__PasswordResetConfirm__Subject=Your Aethon password has been reset
# EmailTemplate__PasswordResetConfirm__Html=<full html>

# EmailTemplate__StaffWelcome__Subject=Welcome to Aethon — your account is ready
# EmailTemplate__StaffWelcome__Html=<full html>

# EmailTemplate__IdentityRejection__Subject=Your Aethon identity verification was unsuccessful
# EmailTemplate__IdentityRejection__Html=<full html>
